@inject IJSRuntime JS

<div class="modal fade" id="@Id" tabindex="-1" aria-labelledby="@(Id)-label" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="@(Id)-label">@Title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @ChildContent
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@CancelText</button>
                <button type="button" class="btn btn-@ConfirmButtonType" @onclick="HandleConfirm">@ConfirmText</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Id { get; set; } = "confirmDialog";

    [Parameter]
    public string Title { get; set; } = "Confirm";

    [Parameter]
    public string ConfirmText { get; set; } = "Confirm";

    [Parameter]
    public string CancelText { get; set; } = "Cancel";

    [Parameter]
    public string ConfirmButtonType { get; set; } = "danger";

    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public EventCallback OnConfirmed { get; set; }

    private async Task HandleConfirm()
    {
        await JS.InvokeVoidAsync("bootstrap.Modal.getInstance", $"#{Id}");
        await OnConfirmed.InvokeAsync();
    }
}
