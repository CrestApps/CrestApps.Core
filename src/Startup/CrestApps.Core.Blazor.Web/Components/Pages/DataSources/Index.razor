@page "/DataSources"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.Blazor.Web.Areas.DataSources.Services
@using CrestApps.Core.Services
@inject ICatalogManager<AIDataSource> Manager
@inject IMvcAIDataSourceIndexingQueue IndexingQueue
@inject NavigationManager NavigationManager

<PageTitle>Data Sources</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-collection"></i> Data Sources</h2>
    <a href="/DataSources/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Data Source
    </a>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (DataSources is null)
{
    <p><em>Loading...</em></p>
}
else if (!DataSources.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No data sources found.
        Create one to map data from an existing search index into a knowledge base.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Source Index</th>
                    <th>Knowledge Base Index</th>
                    <th style="width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in DataSources)
                {
                    <tr>
                        <td><strong>@item.DisplayText</strong></td>
                        <td><code>@(item.SourceIndexProfileName ?? "—")</code></td>
                        <td><code>@(item.AIKnowledgeBaseIndexProfileName ?? "—")</code></td>
                        <td>
                            <button class="btn btn-sm btn-outline-success" @onclick="() => SyncDataSource(item)">
                                <i class="bi bi-arrow-repeat"></i> Sync
                            </button>
                            <a href="/DataSources/Edit/@item.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(item.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this data source?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private IReadOnlyCollection<AIDataSource>? DataSources;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        DataSources = (await Manager.GetAllAsync()).ToList();
    }

    private async Task SyncDataSource(AIDataSource dataSource)
    {
        await IndexingQueue.QueueSyncDataSourceAsync(dataSource);
        SuccessMessage = "Data source synchronization has been queued.";
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            var ds = await Manager.FindByIdAsync(DeleteTargetId);
            if (ds != null) await Manager.DeleteAsync(ds);
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        SuccessMessage = "Data source deleted successfully. Knowledge-base cleanup has been queued.";
        await LoadAsync();
    }
}
