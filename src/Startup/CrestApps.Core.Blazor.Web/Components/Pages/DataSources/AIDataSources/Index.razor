@page "/datasources"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Services
@using CrestApps.Core.Services
@using Microsoft.Extensions.Options
@inject ICatalogManager<AIDataSource> Manager
@inject IAIDataSourceIndexingQueue IndexingQueue
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ToastNotificationService ToastNotifications
@inject IOptions<AIDataSourceSourceOptions> SourceOptions

<PageTitle>Data Sources</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-collection"></i> Data Sources</h2>
    <a href="/datasources/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Data Source
    </a>
</div>

@if (_dataSources == null)
{
    <p><em>Loading...</em></p>
}
else if (_dataSources.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No data sources found.
        Create one to map data from an existing search index into a knowledge base.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Source</th>
                    <th>Source Index</th>
                    <th>Knowledge Base Index</th>
                    <th style="width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _dataSources)
                {
                    <tr>
                        <td><strong>@item.DisplayText</strong></td>
                        <td>@GetSourceDisplayName(item)</td>
                        <td><code>@GetSourceReference(item)</code></td>
                        <td><code>@(item.AIKnowledgeBaseIndexProfileName ?? "—")</code></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => SyncAsync(item.ItemId)">
                                <i class="bi bi-arrow-repeat"></i> Sync
                            </button>
                            <a href="/datasources/edit/@item.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AIDataSource> _dataSources;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await Manager.GetAllAsync();

        _dataSources = all.ToList();
    }

    private async Task SyncAsync(string id)
    {
        var dataSource = await Manager.FindByIdAsync(id);

        if (dataSource == null)
        {
            ToastNotifications.ShowError("Data source not found.");

            return;
        }

        await IndexingQueue.QueueSyncDataSourceAsync(dataSource);
        ToastNotifications.ShowSuccess("Data source synchronization has been queued.");
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this data source?");

        if (!confirmed)
        {
            return;
        }

        var dataSource = await Manager.FindByIdAsync(id);

        if (dataSource == null)
        {
            ToastNotifications.ShowError("Data source not found.");

            return;
        }

        await Manager.DeleteAsync(dataSource);
        await StoreCommitter.CommitAsync();
        ToastNotifications.ShowSuccess("Data source deleted successfully. Knowledge-base cleanup has been queued.");
        await LoadAsync();
    }

    private string GetSourceDisplayName(AIDataSource dataSource)
    {
        var sourceType = string.IsNullOrWhiteSpace(dataSource.Source)
            ? AIDataSourceSourceTypes.SearchIndexProfile
            : dataSource.Source;

        return SourceOptions.Value.Sources.FirstOrDefault(x => string.Equals(x.SourceType, sourceType, StringComparison.OrdinalIgnoreCase))?.DisplayName.Value ?? sourceType;
    }

    private static string GetSourceReference(AIDataSource dataSource)
    {
        if (string.IsNullOrWhiteSpace(dataSource.Source) ||
            string.Equals(dataSource.Source, AIDataSourceSourceTypes.SearchIndexProfile, StringComparison.OrdinalIgnoreCase))
        {
            return dataSource.SourceIndexProfileName ?? "—";
        }

        if (string.Equals(dataSource.Source, AIDataSourceSourceTypes.Elasticsearch, StringComparison.OrdinalIgnoreCase) &&
            dataSource.TryGet<ElasticsearchSourceMetadata>(out var elasticsearchMetadata))
        {
            return elasticsearchMetadata.IndexName ?? "—";
        }

        if (string.Equals(dataSource.Source, AIDataSourceSourceTypes.AzureAISearch, StringComparison.OrdinalIgnoreCase) &&
            dataSource.TryGet<AzureAISearchSourceMetadata>(out var azureAISearchMetadata))
        {
            return azureAISearchMetadata.IndexName ?? "—";
        }

        if (string.Equals(dataSource.Source, AIDataSourceSourceTypes.PostgreSQL, StringComparison.OrdinalIgnoreCase) &&
            dataSource.TryGet<PostgreSQLSourceMetadata>(out var postgreSQLMetadata))
        {
            return postgreSQLMetadata.TableName ?? "—";
        }

        return "—";
    }
}
