@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Dashboard - Blazor AI Integration Sample</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <div class="alert alert-warning mb-4">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Getting Started:</strong> <a href="/account/login">Sign in</a> to access the admin features and start using AI chat.
        </div>
    </NotAuthorized>
</AuthorizeView>

<div class="card mb-4 border-primary">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-rocket-takeoff"></i> Getting Started</h5>
    </div>
    <div class="card-body">
        <p class="mb-2">Follow these steps to start using AI features in your application:</p>
        <ol class="mb-3">
            <li><strong>Add an AI Connection</strong> — configure a connection to your AI provider (OpenAI, Azure OpenAI, Ollama, etc.).</li>
            <li><strong>Add an AI Deployment</strong> — map a model deployment (e.g., <code>gpt-4o-mini</code>) to your connection.</li>
            <li><strong>Start testing</strong> — open <strong>Chat Interactions</strong> first to validate your connection and deployment immediately, then create an <strong>AI Profile</strong> when you want reusable chat, agent, or orchestration behavior.</li>
        </ol>
        <div class="alert alert-secondary mb-0 py-2">
            <i class="bi bi-info-circle"></i>
            <strong>Technical name</strong> — you'll see this field throughout the UI. It's an auto-generated, machine-friendly identifier (e.g., <code>MyOpenAIConnection</code>) used internally to reference entities. It is set once during creation and cannot be changed afterward.
        </div>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    <div class="col">
        <div class="card h-100 border-success">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-plug fs-2 text-success me-3"></i>
                    <h5 class="card-title mb-0">AI Connections</h5>
                </div>
                <p class="card-text">Configure connections to AI providers (OpenAI, Azure OpenAI, Ollama, Azure AI Inference).</p>
                <a href="/ai/connections" class="btn btn-success">
                    <i class="bi bi-arrow-right"></i> Manage Connections
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-box-seam fs-2 text-warning me-3"></i>
                    <h5 class="card-title mb-0">AI Deployments</h5>
                </div>
                <p class="card-text">Map model deployments to connections for fine-grained control over which models are used.</p>
                <a href="/ai/deployments" class="btn btn-warning">
                    <i class="bi bi-arrow-right"></i> Manage Deployments
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-danger">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-chat-left-dots fs-2 text-danger me-3"></i>
                    <h5 class="card-title mb-0">Chat Interactions</h5>
                </div>
                <p class="card-text">The fastest way to test a new setup with a real conversation before creating reusable profiles.</p>
                <a href="/chat-interactions" class="btn btn-danger">
                    <i class="bi bi-arrow-right"></i> Manage Interactions
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-primary">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-person-gear fs-2 text-primary me-3"></i>
                    <h5 class="card-title mb-0">AI Profiles</h5>
                </div>
                <p class="card-text">Create reusable AI behavior for chat, agents, tools, data sources, memory, and session processing.</p>
                <a href="/ai/profiles" class="btn btn-primary">
                    <i class="bi bi-arrow-right"></i> Manage Profiles
                </a>
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card h-100 border-dark">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-database-gear fs-2 text-dark me-3"></i>
                    <h5 class="card-title mb-0">Index Profiles</h5>
                </div>
                <p class="card-text">Define search index profiles for Elasticsearch or Azure AI Search vector stores.</p>
                <a href="/indexing/profiles" class="btn btn-dark">
                    <i class="bi bi-arrow-right"></i> Manage Index Profiles
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100" style="border-color: #6f42c1;">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-collection fs-2 me-3" style="color: #6f42c1;"></i>
                    <h5 class="card-title mb-0">Data Sources</h5>
                </div>
                <p class="card-text">Map existing search indexes to a knowledge base for AI-powered retrieval.</p>
                <a href="/datasources" class="btn text-white" style="background-color: #6f42c1;">
                    <i class="bi bi-arrow-right"></i> Manage Data Sources
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-secondary">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-file-earmark-text fs-2 text-secondary me-3"></i>
                    <h5 class="card-title mb-0">Templates</h5>
                </div>
                <p class="card-text">Create reusable system prompt and profile templates for consistent AI behavior.</p>
                <a href="/ai/templates" class="btn btn-secondary">
                    <i class="bi bi-arrow-right"></i> Manage Templates
                </a>
            </div>
        </div>
    </div>
</div>

<section class="mt-5">
    <h3 class="mb-3">Agent to Agent Protocol</h3>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        <div class="col">
            <div class="card h-100 border-info">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-diagram-3 fs-2 text-info me-3"></i>
                        <h5 class="card-title mb-0">Agent to Agent Hosts</h5>
                    </div>
                    <p class="card-text">Manage remote A2A hosts and make their agents available to Blazor orchestration.</p>
                    <a href="/a2a/connections" class="btn btn-info text-white">
                        <i class="bi bi-arrow-right"></i> Manage A2A Hosts
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mt-5">
    <h3 class="mb-3">Model Context Protocol (MCP)</h3>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        <div class="col">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-hdd-network fs-2 text-primary me-3"></i>
                        <h5 class="card-title mb-0">MCP Hosts</h5>
                    </div>
                    <p class="card-text">Configure remote SSE MCP servers and local stdio MCP tools for orchestration.</p>
                    <a href="/mcp/connections" class="btn btn-primary">
                        <i class="bi bi-arrow-right"></i> Manage MCP Hosts
                    </a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-secondary">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-chat-square-text fs-2 text-secondary me-3"></i>
                        <h5 class="card-title mb-0">MCP Prompts</h5>
                    </div>
                    <p class="card-text">Define MCP prompts with optional arguments so external clients can discover reusable prompt templates.</p>
                    <a href="/mcp/prompts" class="btn btn-secondary">
                        <i class="bi bi-arrow-right"></i> Manage MCP Prompts
                    </a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-dark">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-folder2-open fs-2 text-dark me-3"></i>
                        <h5 class="card-title mb-0">MCP Resources</h5>
                    </div>
                    <p class="card-text">Register FTP and SFTP-backed MCP resources, including template-based URI patterns for dynamic resources.</p>
                    <a href="/mcp/resources" class="btn btn-dark">
                        <i class="bi bi-arrow-right"></i> Manage MCP Resources
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<AuthorizeView>
    <Authorized>
        <div class="mt-5">
            <a href="/admin/settings" class="btn btn-outline-secondary">
                <i class="bi bi-gear"></i> Open Settings
            </a>
        </div>
    </Authorized>
</AuthorizeView>
