@page "/indexing/profiles"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Infrastructure.Indexing.Models
@using CrestApps.Core.Services
@inject ISearchIndexProfileManager IndexProfileManager
@inject IStoreCommitter StoreCommitter
@inject IServiceProvider ServiceProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<CrestApps.Core.Blazor.Web.Components.Pages.Indexing.IndexProfiles.Index> Logger

<PageTitle>Index Profiles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-database-gear"></i> Index Profiles</h2>
    <a href="/indexing/profiles/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Index Profile
    </a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_profiles == null)
{
    <p><em>Loading...</em></p>
}
else if (_profiles.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No index profiles found.
        Create one to connect to Elasticsearch or Azure AI Search.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Index Name</th>
                    <th>Provider</th>
                    <th>Type</th>
                    <th style="width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _profiles)
                {
                    <tr>
                        <td><strong>@(item.DisplayText ?? item.Name)</strong></td>
                        <td><code>@item.IndexName</code></td>
                        <td><span class="badge bg-secondary">@item.ProviderName</span></td>
                        <td><span class="badge bg-info">@item.Type</span></td>
                        <td>
                            <a href="/indexing/profiles/edit/@item.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<SearchIndexProfile> _profiles;
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await IndexProfileManager.GetAllAsync();

        _profiles = all.ToList();
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this index profile?");

        if (!confirmed)
        {
            return;
        }

        var profile = await IndexProfileManager.FindByIdAsync(id);

        if (profile == null)
        {
            _errorMessage = "Index profile not found.";

            return;
        }

        var indexManager = ServiceProvider.GetKeyedService<ISearchIndexManager>(profile.ProviderName ?? string.Empty);

        if (indexManager == null)
        {
            Logger.LogWarning("Skipping remote delete for index profile '{IndexProfileId}' because provider '{ProviderName}' is not registered.", profile.ItemId, profile.ProviderName);
            await IndexProfileManager.DeleteAsync(profile);
            await StoreCommitter.CommitAsync();
            await LoadAsync();

            return;
        }

        profile.IndexFullName ??= indexManager.ComposeIndexFullName(profile);

        bool remoteIndexExists;
        try
        {
            remoteIndexExists = await indexManager.ExistsAsync(profile);
        }
        catch (ArgumentException ex)
        {
            Logger.LogWarning(ex, "Skipping remote delete for index profile '{IndexProfileId}' because the resolved remote index name '{IndexName}' is invalid.", profile.ItemId, profile.IndexFullName);
            remoteIndexExists = false;
        }

        if (remoteIndexExists)
        {
            try
            {
                await indexManager.DeleteAsync(profile);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to delete remote index '{IndexName}' for provider '{ProviderName}'.", profile.IndexFullName, profile.ProviderName);
                _errorMessage = $"Unable to delete the remote index '{profile.IndexFullName}'. The index profile was not removed.";

                return;
            }
        }

        await IndexProfileManager.DeleteAsync(profile);
        await StoreCommitter.CommitAsync();
        await LoadAsync();
    }
}
