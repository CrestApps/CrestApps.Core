@page "/indexing/profiles"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Infrastructure.Indexing.Models
@using CrestApps.Core.Services
@using Microsoft.Extensions.DependencyInjection
@inject ISearchIndexProfileManager IndexProfileManager
@inject IStoreCommitter StoreCommitter
@inject IServiceProvider ServiceProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<CrestApps.Core.Blazor.Web.Components.Pages.Indexing.IndexProfiles.Index> Logger

<PageTitle>Index Profiles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-database-gear"></i> Index Profiles</h2>
    <a href="/indexing/profiles/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Index Profile
    </a>
</div>

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_profiles == null)
{
    <p><em>Loading...</em></p>
}
else if (_profiles.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No index profiles found.
        Create one to connect to Elasticsearch or Azure AI Search.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Index Name</th>
                    <th>Provider</th>
                    <th>Type</th>
                    <th style="width: 420px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _profiles)
                {
                    <tr>
                        <td><strong>@(item.DisplayText ?? item.Name)</strong></td>
                        <td><code>@item.IndexName</code></td>
                        <td><span class="badge bg-secondary">@item.ProviderName</span></td>
                        <td><span class="badge bg-info">@item.Type</span></td>
                        <td>
                            <div class="d-flex flex-nowrap gap-2">
                                <button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => RebuildAsync(item.ItemId)">
                                    <i class="bi bi-arrow-clockwise"></i> Rebuild
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => ReindexAsync(item.ItemId)">
                                    <i class="bi bi-arrow-repeat"></i> Reindex
                                </button>
                                <a href="/indexing/profiles/edit/@item.ItemId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.ItemId)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<SearchIndexProfile> _profiles;
    private string _errorMessage;
    private string _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await IndexProfileManager.GetAllAsync();

        _profiles = all.ToList();
    }

    private async Task RebuildAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Rebuild this index? This will delete the existing remote index, recreate it, and repopulate data.");

        if (!confirmed)
        {
            return;
        }

        var profile = await IndexProfileManager.FindByIdAsync(id);

        if (profile == null)
        {
            _errorMessage = "Index profile not found.";
            _successMessage = null;

            return;
        }

        var indexManager = ResolveIndexManager(profile);

        if (indexManager == null)
        {
            _errorMessage = $"The search provider '{profile.ProviderName}' is not configured for remote index provisioning.";
            _successMessage = null;

            return;
        }

        try
        {
            profile.IndexFullName ??= indexManager.ComposeIndexFullName(profile);

            if (await indexManager.ExistsAsync(profile))
            {
                await indexManager.DeleteAsync(profile);
            }

            var fields = await IndexProfileManager.GetFieldsAsync(profile);

            if (fields == null)
            {
                _errorMessage = $"The index type '{profile.Type}' does not support rebuild.";
                _successMessage = null;

                return;
            }

            await indexManager.CreateAsync(profile, fields);
            await IndexProfileManager.SynchronizeAsync(profile);
            _successMessage = $"The index '{GetIndexDisplayName(profile)}' was rebuilt successfully.";
            _errorMessage = null;
        }
        catch (ArgumentException ex)
        {
            Logger.LogWarning(ex, "Unable to rebuild index profile '{IndexProfileId}' because the resolved remote index name is invalid.", profile.ItemId);
            _errorMessage = "Unable to rebuild the index because the remote index name is invalid.";
            _successMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to rebuild remote index '{IndexName}' for provider '{ProviderName}'.", GetIndexDisplayName(profile), profile.ProviderName);
            _errorMessage = $"Unable to rebuild the remote index '{GetIndexDisplayName(profile)}'.";
            _successMessage = null;
        }
    }

    private async Task ReindexAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Reindex this profile? This will clear indexed data and repopulate it from the beginning.");

        if (!confirmed)
        {
            return;
        }

        var profile = await IndexProfileManager.FindByIdAsync(id);

        if (profile == null)
        {
            _errorMessage = "Index profile not found.";
            _successMessage = null;

            return;
        }

        try
        {
            await IndexProfileManager.ResetAsync(profile);
            await IndexProfileManager.SynchronizeAsync(profile);
            _successMessage = $"The index '{GetIndexDisplayName(profile)}' was reindexed successfully.";
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reindex remote index '{IndexName}' for provider '{ProviderName}'.", GetIndexDisplayName(profile), profile.ProviderName);
            _errorMessage = $"Unable to reindex the remote index '{GetIndexDisplayName(profile)}'.";
            _successMessage = null;
        }
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this index profile?");

        if (!confirmed)
        {
            return;
        }

        var profile = await IndexProfileManager.FindByIdAsync(id);

        if (profile == null)
        {
            _errorMessage = "Index profile not found.";
            _successMessage = null;

            return;
        }

        var indexManager = ResolveIndexManager(profile);

        if (indexManager == null)
        {
            Logger.LogWarning("Skipping remote delete for index profile '{IndexProfileId}' because provider '{ProviderName}' is not registered.", profile.ItemId, profile.ProviderName);
            await IndexProfileManager.DeleteAsync(profile);
            await StoreCommitter.CommitAsync();
            _successMessage = "Index profile deleted successfully.";
            _errorMessage = null;
            await LoadAsync();

            return;
        }

        profile.IndexFullName ??= indexManager.ComposeIndexFullName(profile);

        bool remoteIndexExists;
        try
        {
            remoteIndexExists = await indexManager.ExistsAsync(profile);
        }
        catch (ArgumentException ex)
        {
            Logger.LogWarning(ex, "Skipping remote delete for index profile '{IndexProfileId}' because the resolved remote index name '{IndexName}' is invalid.", profile.ItemId, profile.IndexFullName);
            remoteIndexExists = false;
        }

        if (remoteIndexExists)
        {
            try
            {
                await indexManager.DeleteAsync(profile);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to delete remote index '{IndexName}' for provider '{ProviderName}'.", profile.IndexFullName, profile.ProviderName);
                _errorMessage = $"Unable to delete the remote index '{profile.IndexFullName}'. The index profile was not removed.";
                _successMessage = null;

                return;
            }
        }

        await IndexProfileManager.DeleteAsync(profile);
        await StoreCommitter.CommitAsync();
        _successMessage = "Index profile deleted successfully.";
        _errorMessage = null;
        await LoadAsync();
    }

    private ISearchIndexManager ResolveIndexManager(SearchIndexProfile profile)
    {
        try
        {
            return ServiceProvider.GetKeyedService<ISearchIndexManager>(profile.ProviderName ?? string.Empty);
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex, "Skipping remote index operation for index profile '{IndexProfileId}' because provider '{ProviderName}' is not registered.", profile.ItemId, profile.ProviderName);

            return null;
        }
    }

    private static string GetIndexDisplayName(SearchIndexProfile profile)
    {
        return profile.IndexFullName ?? profile.IndexName ?? profile.Name ?? profile.ItemId;
    }
}
