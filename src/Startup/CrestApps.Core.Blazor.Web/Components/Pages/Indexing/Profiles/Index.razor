@page "/Indexing/Profiles"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Infrastructure.Indexing.Models
@inject ISearchIndexProfileManager IndexProfileManager
@inject NavigationManager NavigationManager

<PageTitle>Index Profiles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-database-gear"></i> Index Profiles</h2>
    <a href="/Indexing/Profiles/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Index Profile
    </a>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
    </div>
}

@if (Profiles is null)
{
    <p><em>Loading...</em></p>
}
else if (!Profiles.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No index profiles found.
        Create one to connect to Elasticsearch or Azure AI Search.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Index Name</th>
                    <th>Provider</th>
                    <th>Type</th>
                    <th style="width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Profiles)
                {
                    <tr>
                        <td><strong>@(item.DisplayText ?? item.Name)</strong></td>
                        <td><code>@item.IndexName</code></td>
                        <td><span class="badge bg-secondary">@item.ProviderName</span></td>
                        <td><span class="badge bg-info">@item.Type</span></td>
                        <td>
                            <a href="/Indexing/Profiles/Edit/@item.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(item.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this index profile? This will also attempt to delete the remote index.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private IReadOnlyCollection<SearchIndexProfile>? Profiles;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;
    private string? ErrorMessage;

    [Inject] private IServiceProvider ServiceProvider { get; set; } = default!;
    [Inject] private ILogger<Pages.Indexing.Profiles.Index> Logger { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Profiles = (await IndexProfileManager.GetAllAsync()).ToList();
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        ShowDeleteConfirmation = false;
        if (string.IsNullOrEmpty(DeleteTargetId)) return;

        var profile = await IndexProfileManager.FindByIdAsync(DeleteTargetId);
        DeleteTargetId = null;
        if (profile is null) return;

        var indexManager = ServiceProvider.GetKeyedService<ISearchIndexManager>(profile.ProviderName ?? string.Empty);

        if (indexManager is not null)
        {
            profile.IndexFullName ??= indexManager.ComposeIndexFullName(profile);
            try
            {
                if (await indexManager.ExistsAsync(profile))
                {
                    try { await indexManager.DeleteAsync(profile); }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "Failed to delete remote index '{IndexName}'.", profile.IndexFullName);
                        ErrorMessage = $"Unable to delete the remote index '{profile.IndexFullName}'. The index profile was not removed.";
                        return;
                    }
                }
            }
            catch (ArgumentException) { /* ignore invalid index names */ }
        }

        await IndexProfileManager.DeleteAsync(profile);
        SuccessMessage = "Index profile deleted successfully.";
        await LoadAsync();
    }
}
