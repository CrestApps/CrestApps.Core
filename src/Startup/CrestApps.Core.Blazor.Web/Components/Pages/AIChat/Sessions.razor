@page "/AIChat/Sessions/{ProfileId}"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Chat
@using CrestApps.Core.AI.Profiles
@inject IAIProfileManager ProfileManager
@inject IAIChatSessionManager SessionManager

<PageTitle>Chat Sessions</PageTitle>

@if (_notFound)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle"></i> Profile not found.
        <a href="/AI/Profiles">Return to AI Profiles</a>.
    </div>
}
else if (_profile is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-clock-history"></i> Chat History — @(_profile.DisplayText ?? _profile.Name)</h2>
        <div class="d-flex gap-2">
            <a href="/AIChat/Chat/@ProfileId" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> New Chat
            </a>
            @if (_sessions?.Sessions.Any() == true)
            {
                <button type="button" class="btn btn-outline-danger" @onclick="ConfirmDeleteAll">
                    <i class="bi bi-trash"></i> Delete All
                </button>
            }
            <a href="/AI/Profiles" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Profiles
            </a>
        </div>
    </div>

    @if (_sessions is null)
    {
        <p><em>Loading sessions...</em></p>
    }
    else if (!_sessions.Sessions.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No chat sessions found for this profile. Start a new chat to get going.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Created</th>
                        <th>Last Activity</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in _sessions.Sessions.OrderByDescending(s => s.CreatedUtc))
                    {
                        <tr>
                            <td>
                                <a href="/AIChat/Chat/@session.ProfileId/@session.SessionId" class="text-decoration-none">
                                    <strong>@(session.Title ?? "Untitled")</strong>
                                </a>
                            </td>
                            <td><small class="text-muted">@session.CreatedUtc.ToString("g")</small></td>
                            <td><small class="text-muted">@session.LastActivityUtc.ToString("g")</small></td>
                            <td>
                                <a href="/AIChat/Chat/@session.ProfileId/@session.SessionId" class="btn btn-sm btn-outline-primary" title="Resume chat">
                                    <i class="bi bi-chat-left-text"></i> Resume
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(session.SessionId)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (_showDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>@(_deleteAllSessions ? "Delete all chat sessions for this profile? This cannot be undone." : "Delete this session?")</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDeleteAsync">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ProfileId { get; set; } = default!;

    private AIProfile? _profile;
    private AIChatSessionResult? _sessions;
    private bool _notFound;
    private bool _showDeleteConfirmation;
    private bool _deleteAllSessions;
    private string? _deleteTargetSessionId;

    protected override async Task OnInitializedAsync()
    {
        _profile = await ProfileManager.FindByIdAsync(ProfileId);
        if (_profile is null)
        {
            _notFound = true;
            return;
        }

        await LoadSessionsAsync();
    }

    private async Task LoadSessionsAsync()
    {
        _sessions = await SessionManager.PageAsync(1, 100, new AIChatSessionQueryContext { ProfileId = ProfileId });
    }

    private void ConfirmDelete(string sessionId)
    {
        _deleteAllSessions = false;
        _deleteTargetSessionId = sessionId;
        _showDeleteConfirmation = true;
    }

    private void ConfirmDeleteAll()
    {
        _deleteAllSessions = true;
        _deleteTargetSessionId = null;
        _showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        _deleteAllSessions = false;
        _deleteTargetSessionId = null;
        _showDeleteConfirmation = false;
    }

    private async Task ExecuteDeleteAsync()
    {
        if (_deleteAllSessions && _sessions is not null)
        {
            foreach (var session in _sessions.Sessions)
            {
                await SessionManager.DeleteAsync(session.SessionId);
            }
        }
        else if (!string.IsNullOrEmpty(_deleteTargetSessionId))
        {
            await SessionManager.DeleteAsync(_deleteTargetSessionId);
        }

        _deleteAllSessions = false;
        _showDeleteConfirmation = false;
        _deleteTargetSessionId = null;
        await LoadSessionsAsync();
    }
}
