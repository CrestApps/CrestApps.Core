@page "/AIChat/Sessions/{ProfileId}"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Chat
@using CrestApps.Core.AI.Profiles
@inject IAIProfileManager ProfileManager
@inject IAIChatSessionManager SessionManager
@inject NavigationManager NavigationManager

<PageTitle>Chat Sessions</PageTitle>

@if (_notFound)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle"></i> Profile not found.
        <a href="/AIChat">Return to AI Chat</a>.
    </div>
}
else if (_profile is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2><i class="bi bi-clock-history"></i> Sessions — @(_profile.DisplayText ?? _profile.Name)</h2>
            <p class="text-muted mb-0">Manage chat sessions for this profile.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-primary" @onclick="CreateSessionAsync">
                <i class="bi bi-plus-lg"></i> New Session
            </button>
            <a href="/AIChat" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>
    <hr />

    @if (_sessions is null)
    {
        <p><em>Loading sessions...</em></p>
    }
    else if (!_sessions.Sessions.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No sessions found for this profile.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Last Activity</th>
                        <th style="min-width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in _sessions.Sessions)
                    {
                        <tr>
                            <td><strong>@(session.Title ?? "Untitled")</strong></td>
                            <td>
                                @if (session.Status == ChatSessionStatus.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Closed</span>
                                }
                            </td>
                            <td><small class="text-muted">@session.CreatedUtc.ToString("g")</small></td>
                            <td><small class="text-muted">@session.LastActivityUtc.ToString("g")</small></td>
                            <td>
                                @if (session.Status == ChatSessionStatus.Active)
                                {
                                    <a href="/AIChat/Chat/@session.ProfileId/@session.SessionId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-chat-left-text"></i> Continue
                                    </a>
                                }
                                else
                                {
                                    <a href="/AIChat/Chat/@session.ProfileId/@session.SessionId" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                }
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1" @onclick="() => ConfirmDelete(session.SessionId)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (_showDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this session?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDeleteAsync">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ProfileId { get; set; } = default!;

    private AIProfile? _profile;
    private AIChatSessionResult? _sessions;
    private bool _notFound;
    private bool _showDeleteConfirmation;
    private string? _deleteTargetSessionId;

    protected override async Task OnInitializedAsync()
    {
        _profile = await ProfileManager.FindByIdAsync(ProfileId);
        if (_profile is null)
        {
            _notFound = true;
            return;
        }

        await LoadSessionsAsync();
    }

    private async Task LoadSessionsAsync()
    {
        _sessions = await SessionManager.PageAsync(1, 100, new AIChatSessionQueryContext { ProfileId = ProfileId });
    }

    private async Task CreateSessionAsync()
    {
        if (_profile is null) return;

        var session = await SessionManager.NewAsync(_profile, new NewAIChatSessionContext());
        session.Title = _profile.DisplayText ?? _profile.Name;
        await SessionManager.SaveAsync(session);

        NavigationManager.NavigateTo($"/AIChat/Chat/{_profile.ItemId}/{session.SessionId}");
    }

    private void ConfirmDelete(string sessionId)
    {
        _deleteTargetSessionId = sessionId;
        _showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        _deleteTargetSessionId = null;
        _showDeleteConfirmation = false;
    }

    private async Task ExecuteDeleteAsync()
    {
        if (!string.IsNullOrEmpty(_deleteTargetSessionId))
        {
            await SessionManager.DeleteAsync(_deleteTargetSessionId);
        }

        _showDeleteConfirmation = false;
        _deleteTargetSessionId = null;
        await LoadSessionsAsync();
    }
}
