@page "/AIChat/ExtractedData"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.Blazor.Web.Areas.AIChat.Services
@using System.Text
@using Microsoft.JSInterop
@inject IAIProfileManager ProfileManager
@inject MvcAIChatSessionExtractedDataService ExtractedDataService
@inject TimeProvider TimeProvider
@inject IJSRuntime JS

<PageTitle>Chat extracted data</PageTitle>

<h2><i class="bi bi-table"></i> Chat extracted data</h2>
<p class="text-muted">Review extracted session values for a selected AI Profile.</p>
<hr />

<div class="card mb-4">
    <div class="card-body">
        <EditForm Model="_filter" OnValidSubmit="RunReportAsync" FormName="extractedDataFilter" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">AI Profile</label>
                <select class="form-select" @bind="_filter.ProfileId" required>
                    @foreach (var p in _profileOptions)
                    {
                        <option value="@p.Value">@p.Text</option>
                    }
                </select>
                @if (_showProfileError)
                {
                    <div class="text-danger small mt-1">AI Profile is required.</div>
                }
            </div>
            <div class="col-md-3">
                <label class="form-label">From</label>
                <input type="date" class="form-control" @bind="_filter.StartDateUtc" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To</label>
                <input type="date" class="form-control" @bind="_filter.EndDateUtc" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel"></i> Show
                </button>
            </div>
        </EditForm>
    </div>
</div>

@if (!_showReport)
{
    <div class="alert alert-info">
        Select an AI Profile to generate the extracted data report.
    </div>
}
else if (_rows.Count == 0)
{
    <div class="alert alert-warning">
        No extracted data was found for the selected filters.
    </div>
}
else
{
    <div class="d-flex justify-content-end mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="ExportCsvAsync">
            <i class="bi bi-filetype-csv"></i> Export CSV
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Session date</th>
                    <th>Session ID</th>
                    @foreach (var column in _columns)
                    {
                        <th>@column</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td>@row.SessionStartedUtc.ToString("g")</td>
                        <td class="font-monospace small">@row.SessionId</td>
                        @foreach (var column in _columns)
                        {
                            row.Values.TryGetValue(column, out var value);
                            <td>@value</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private sealed class FilterModel
    {
        public string? ProfileId { get; set; }
        public DateTime? StartDateUtc { get; set; }
        public DateTime? EndDateUtc { get; set; }
    }

    private sealed class ProfileOption
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }

    private sealed class ExtractedDataRow
    {
        public DateTime SessionStartedUtc { get; set; }
        public string SessionId { get; set; } = string.Empty;
        public IReadOnlyDictionary<string, string> Values { get; set; } = new Dictionary<string, string>();
    }

    private readonly FilterModel _filter = new();
    private List<ProfileOption> _profileOptions = [];
    private bool _showReport;
    private bool _showProfileError;
    private List<ExtractedDataRow> _rows = [];
    private IReadOnlyList<string> _columns = [];

    protected override async Task OnInitializedAsync()
    {
        var profiles = await ProfileManager.GetAsync(AIProfileType.Chat);
        _profileOptions =
        [
            new ProfileOption { Value = string.Empty, Text = "Select a profile" },
            .. profiles
                .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
                .Select(p => new ProfileOption { Value = p.ItemId, Text = p.DisplayText ?? p.Name }),
        ];
    }

    private async Task RunReportAsync()
    {
        _showProfileError = string.IsNullOrEmpty(_filter.ProfileId);
        if (_showProfileError)
        {
            _showReport = false;
            return;
        }

        var records = await ExtractedDataService.GetAsync(_filter.ProfileId, _filter.StartDateUtc, _filter.EndDateUtc);
        _rows = records.Select(r => new ExtractedDataRow
        {
            SessionId = r.SessionId,
            SessionStartedUtc = r.SessionStartedUtc,
            Values = r.Values.ToDictionary(
                pair => pair.Key,
                pair => string.Join(", ", pair.Value),
                StringComparer.OrdinalIgnoreCase),
        }).ToList();

        _columns = _rows
            .SelectMany(r => r.Values.Keys)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        _showReport = true;
    }

    private async Task ExportCsvAsync()
    {
        var builder = new StringBuilder();
        builder.Append("SessionStartedUtc,SessionId");
        foreach (var col in _columns)
        {
            builder.Append(',').Append(EscapeCsv(col));
        }
        builder.AppendLine();

        foreach (var row in _rows)
        {
            builder.Append(row.SessionStartedUtc.ToString("o")).Append(',').Append(EscapeCsv(row.SessionId));
            foreach (var col in _columns)
            {
                row.Values.TryGetValue(col, out var value);
                builder.Append(',').Append(EscapeCsv(value));
            }
            builder.AppendLine();
        }

        var fileName = $"chat-extracted-data-{TimeProvider.GetUtcNow():yyyyMMdd-HHmmss}.csv";
        var bytes = Encoding.UTF8.GetBytes(builder.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $"{{ const a = document.createElement('a'); a.href = 'data:text/csv;base64,{base64}'; a.download = '{fileName}'; a.click(); }}");
    }

    private static string EscapeCsv(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }
}
