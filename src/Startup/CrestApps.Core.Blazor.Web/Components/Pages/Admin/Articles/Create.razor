@page "/Admin/Articles/Create"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.Blazor.Web.Areas.Admin.Models
@using CrestApps.Core.Blazor.Web.Services
@inject ArticleService ArticleService
@inject NavigationManager NavigationManager

<PageTitle>Create Article</PageTitle>

<h2><i class="bi bi-journal-plus"></i> Create Article</h2>
<hr />

<EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="CreateArticle">
    <DataAnnotationsValidator />

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Article Details</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <InputText id="title" @bind-Value="Model.Title" class="form-control" placeholder="Enter article title" />
                        <ValidationMessage For="() => Model.Title" />
                        @if (!string.IsNullOrEmpty(TitleError))
                        {
                            <div class="text-danger">@TitleError</div>
                        }
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <InputTextArea id="description" @bind-Value="Model.Description" class="form-control" rows="15"
                                       placeholder="Write your article content using Markdown..." />
                        <div class="form-text">
                            Supports <a href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noopener noreferrer">Markdown</a> formatting.
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Create Article
                </button>
                <a href="/Admin/Articles" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private ArticleFormModel Model { get; set; } = new();
    private string? TitleError;

    private async Task HandleSubmit()
    {
        TitleError = null;

        if (string.IsNullOrWhiteSpace(Model.Title))
        {
            TitleError = "Title is required.";
            return;
        }

        var article = new Article
        {
            Title = Model.Title.Trim(),
            Description = Model.Description?.Trim() ?? string.Empty,
            CreatedUtc = DateTime.UtcNow,
        };

        await ArticleService.CreateAsync(article);

        NavigationManager.NavigateTo("/Admin/Articles?success=Article created successfully.");
    }

    private sealed class ArticleFormModel
    {
        public string? Title { get; set; }
        public string? Description { get; set; }
    }
}
