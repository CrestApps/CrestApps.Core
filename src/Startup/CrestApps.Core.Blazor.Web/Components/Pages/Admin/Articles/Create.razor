@page "/admin/articles/create"
@attribute [Authorize(Policy = "Admin")]

@using CrestApps.Core.Startup.Shared.Models
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Services

@inject ICatalogManager<Article> ArticleManager
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation

<PageTitle>Create Article - CrestApps AI</PageTitle>

<h2><i class="bi bi-journal-plus"></i> Create Article</h2>
<hr />

<EditForm FormName="admin-articles-create" Model="_model" OnValidSubmit="HandleSubmitAsync">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Article Details</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <InputText id="title" @bind-Value="_model.Title" class="form-control" placeholder="Enter article title" />
                        @if (!string.IsNullOrEmpty(_titleError))
                        {
                            <span class="text-danger">@_titleError</span>
                        }
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <InputTextArea id="description" @bind-Value="_model.Description" class="form-control" rows="15"
                                       placeholder="Write your article content using Markdown..." />
                        <div class="form-text">
                            Supports <a href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noopener noreferrer">Markdown</a> formatting.
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Create Article
                </button>
                <a href="/admin/articles" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private ArticleViewModel _model = new();
    private string _titleError;

    private async Task HandleSubmitAsync()
    {
        _titleError = null;

        if (string.IsNullOrWhiteSpace(_model.Title))
        {
            _titleError = "Title is required.";

            return;
        }

        var article = await ArticleManager.NewAsync();
        article.Title = _model.Title?.Trim();
        article.Description = _model.Description?.Trim();
        article.CreatedUtc = DateTime.UtcNow;

        await ArticleManager.CreateAsync(article);
        await StoreCommitter.CommitAsync();

        Navigation.NavigateTo("/admin/articles");
    }
}
