@page "/admin/articles"
@attribute [Authorize(Policy = "Admin")]

@using CrestApps.Core.Startup.Shared.Models
@using CrestApps.Core.Blazor.Web.Models
@using CrestApps.Core.Blazor.Web.Services
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Models
@using CrestApps.Core.Services

@inject ICatalogManager<Article> ArticleManager
@inject IStoreCommitter StoreCommitter
@inject SiteSettingsStore SiteSettingsStore
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Articles - Blazor AI Integration Sample</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-journal-text"></i> Articles</h2>
    <a href="/admin/articles/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Article
    </a>
</div>

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (_model == null)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!_model.Articles.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No articles found.
        Create one to add knowledge base content that can be indexed into Elasticsearch or Azure AI Search.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Created</th>
                    <th style="min-width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var article in _model.Articles)
                {
                    <tr>
                        <td><strong>@(article.Title ?? "Untitled")</strong></td>
                        <td>
                            <small class="text-muted">@article.CreatedUtc.ToString("g")</small>
                        </td>
                        <td>
                            <a href="/articles/@article.ItemId" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i> Display
                            </a>
                            <a href="/admin/articles/edit/@article.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteArticleAsync(article.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pager CurrentPage="_model.Page"
           TotalPages="_model.TotalPages"
           TotalCount="_model.TotalCount"
           PageChanged="OnPageChangedAsync" />
}

@code {
    private ArticleIndexViewModel _model;
    private string _successMessage;
    private int _currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadArticlesAsync();
    }

    private async Task LoadArticlesAsync()
    {
        var pagination = SiteSettingsStore.Get<PaginationSettings>();
        var pageSize = pagination.AdminPageSize;

        if (_currentPage < 1)
        {
            _currentPage = 1;
        }

        var result = await ArticleManager.PageAsync(_currentPage, pageSize, new QueryContext());

        _model = new ArticleIndexViewModel
        {
            Page = _currentPage,
            PageSize = pageSize,
            TotalCount = result.Count,
            Articles = result.Entries
                .Select(a => new ArticleListEntry
                {
                    ItemId = a.ItemId,
                    Title = a.Title,
                    CreatedUtc = a.CreatedUtc,
                })
                .ToList(),
        };
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        await LoadArticlesAsync();
    }

    private async Task DeleteArticleAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this article?");

        if (!confirmed)
        {
            return;
        }

        var article = await ArticleManager.FindByIdAsync(id);

        if (article != null)
        {
            await ArticleManager.DeleteAsync(article);
            await StoreCommitter.CommitAsync();
        }

        _successMessage = "Article deleted successfully.";
        _currentPage = 1;
        await LoadArticlesAsync();
    }
}
