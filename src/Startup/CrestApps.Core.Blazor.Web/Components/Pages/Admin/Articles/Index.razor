@page "/Admin/Articles"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.Blazor.Web.Areas.Admin.Models
@using CrestApps.Core.Blazor.Web.Models
@using CrestApps.Core.Blazor.Web.Services
@inject ArticleService ArticleService
@inject NavigationManager NavigationManager
@inject SiteSettingsStore SiteSettingsStore

<PageTitle>Articles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-journal-text"></i> Articles</h2>
    <a href="/Admin/Articles/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Article
    </a>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Articles is null)
{
    <p><em>Loading...</em></p>
}
else if (!Articles.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No articles found.
        Create one to add knowledge base content that can be indexed into Elasticsearch or Azure AI Search.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Created</th>
                    <th style="min-width: 250px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var article in Articles)
                {
                    <tr>
                        <td><strong>@(article.Title ?? "Untitled")</strong></td>
                        <td>
                            <small class="text-muted">@article.CreatedUtc.ToString("g")</small>
                        </td>
                        <td>
                            <a href="/Articles/@article.ItemId" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i> Display
                            </a>
                            <a href="/Admin/Articles/Edit/@article.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(article.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pager TItem="Article"
           Page="Page"
           TotalPages="TotalPages"
           TotalCount="TotalCount"
           BaseUrl="/Admin/Articles" />
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this article?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public int Page { get; set; } = 1;

    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private List<Article>? Articles;
    private int TotalCount;
    private int PageSize;
    private int TotalPages => PageSize > 0 ? (int)Math.Ceiling((double)TotalCount / PageSize) : 1;

    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    protected override async Task OnInitializedAsync()
    {
        if (Page < 1) Page = 1;

        var pagination = SiteSettingsStore.Get<PaginationSettings>();
        PageSize = pagination.AdminPageSize;

        var result = await ArticleService.PageAsync(Page, PageSize);
        Articles = result.Items;
        TotalCount = result.Total;
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            await ArticleService.DeleteAsync(DeleteTargetId);
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        SuccessMessage = "Article deleted successfully.";

        var result = await ArticleService.PageAsync(Page, PageSize);
        Articles = result.Items;
        TotalCount = result.Total;
    }
}
