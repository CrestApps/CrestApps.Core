@page "/Admin/Settings"
@attribute [Authorize(Policy = "Admin")]
@using System.Text.RegularExpressions
@using CrestApps.Core.AI.Copilot.Models
@using CrestApps.Core.AI.Deployments
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.Blazor.Web.Areas.Admin.Models
@using CrestApps.Core.Blazor.Web.Areas.AIChat.Models
@using CrestApps.Core.Blazor.Web.Areas.ChatInteractions.Models
@using CrestApps.Core.Blazor.Web.Models
@using CrestApps.Core.Blazor.Web.Services
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Infrastructure.Indexing.Models
@using Microsoft.AspNetCore.DataProtection
@inject SiteSettingsStore SiteSettingsStore
@inject IAIDeploymentManager DeploymentManager
@inject IAIProfileManager ProfileManager
@inject ISearchIndexProfileStore IndexProfileStore
@inject IDataProtectionProvider DataProtectionProvider

<PageTitle>AI Settings</PageTitle>

<h2><i class="bi bi-gear"></i> AI Settings</h2>
<hr />

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
    </div>
}

@if (!IsLoaded)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="this" OnValidSubmit="HandleSave" FormName="AdminSettings">
        <div class="row">
            <div class="col-md-8">

                @* ─── Default Deployments ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Default Deployments</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Select the default deployment for each capability. These are used as a
                            fallback when a specific deployment is not configured at the profile or
                            connection level.
                        </p>

                        <div class="mb-3">
                            <label for="defaultChatDeployment" class="form-label">Default chat deployment</label>
                            <select id="defaultChatDeployment" @bind="DefaultChatDeploymentName" class="form-select">
                                <option value="">None</option>
                                @foreach (var group in GroupDeployments(ChatDeployments))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var d in group.Value)
                                        {
                                            <option value="@d.Name">@FormatDeploymentLabel(d)</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <div class="form-text">The default deployment used for chat sessions and chat interactions when no specific chat deployment is configured.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultUtilityDeployment" class="form-label">Default utility deployment</label>
                            <select id="defaultUtilityDeployment" @bind="DefaultUtilityDeploymentName" class="form-select">
                                <option value="">None</option>
                                @foreach (var group in GroupDeployments(UtilityDeployments))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var d in group.Value)
                                        {
                                            <option value="@d.Name">@FormatDeploymentLabel(d)</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <div class="form-text">The default deployment used for auxiliary tasks such as planning, intent detection, query rewriting, and chart generation.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultEmbeddingDeployment" class="form-label">Default embedding deployment</label>
                            <select id="defaultEmbeddingDeployment" @bind="DefaultEmbeddingDeploymentName" class="form-select">
                                <option value="">None</option>
                                @foreach (var group in GroupDeployments(EmbeddingDeployments))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var d in group.Value)
                                        {
                                            <option value="@d.Name">@FormatDeploymentLabel(d)</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <div class="form-text">The default deployment used for embedding generation in document indexing, data sources, and vector search.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultImageDeployment" class="form-label">Default image deployment</label>
                            <select id="defaultImageDeployment" @bind="DefaultImageDeploymentName" class="form-select">
                                <option value="">None</option>
                                @foreach (var group in GroupDeployments(ImageDeployments))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var d in group.Value)
                                        {
                                            <option value="@d.Name">@FormatDeploymentLabel(d)</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <div class="form-text">The default deployment used for image generation.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultSpeechToTextDeployment" class="form-label">Default speech-to-text deployment</label>
                            <select id="defaultSpeechToTextDeployment" @bind="DefaultSpeechToTextDeploymentName" class="form-select">
                                <option value="">None</option>
                                @foreach (var group in GroupDeployments(SpeechToTextDeployments))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var d in group.Value)
                                        {
                                            <option value="@d.Name">@FormatDeploymentLabel(d)</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <div class="form-text">The default deployment used for speech-to-text transcription.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultTextToSpeechDeployment" class="form-label">Default text-to-speech deployment</label>
                            <select id="defaultTextToSpeechDeployment" @bind="DefaultTextToSpeechDeploymentName" class="form-select">
                                <option value="">None</option>
                                @foreach (var group in GroupDeployments(TextToSpeechDeployments))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var d in group.Value)
                                        {
                                            <option value="@d.Name">@FormatDeploymentLabel(d)</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <div class="form-text">The default deployment used for text-to-speech synthesis.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultTtsVoice" class="form-label">Default text-to-speech voice</label>
                            <InputText id="defaultTtsVoice" @bind-Value="DefaultTextToSpeechVoiceId" class="form-control" placeholder="Default voice" />
                            <div class="form-text">The default voice used for text-to-speech when a profile does not specify one. Available voices depend on the selected text-to-speech deployment.</div>
                        </div>
                    </div>
                </div>

                @* ─── Memory ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Memory</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="memoryIndexProfile" class="form-label">Default memory index</label>
                            <select id="memoryIndexProfile" @bind="MemoryIndexProfileName" class="form-select">
                                <option value="">None</option>
                                @foreach (var p in MemoryIndexProfiles)
                                {
                                    <option value="@p.Name">@(p.DisplayText ?? p.Name)</option>
                                }
                            </select>
                            <div class="form-text">Choose the AI Memory index profile used to store and retrieve user memories.</div>
                        </div>

                        <div class="mb-3">
                            <label for="memoryTopN" class="form-label">Default memory Top N</label>
                            <InputNumber id="memoryTopN" @bind-Value="MemoryTopN" class="form-control" min="1" max="20" style="max-width: 200px;" />
                            <div class="form-text">The default number of memory entries retrieved when memory is enabled.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="enableUserMemoryByDefault" @bind-Value="EnableUserMemoryByDefault" class="form-check-input" />
                                <label for="enableUserMemoryByDefault" class="form-check-label">Enable user memory by default</label>
                            </div>
                            <div class="form-text">When enabled, chat interactions automatically remember user preferences and context across sessions. Individual profiles can override this setting.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="enablePreemptiveMemoryRetrieval" @bind-Value="EnablePreemptiveMemoryRetrieval" class="form-check-input" />
                                <label for="enablePreemptiveMemoryRetrieval" class="form-check-label">Enable preemptive memory retrieval</label>
                            </div>
                            <div class="form-text">Allow the orchestrator to preload relevant user memory before generation when memory is enabled for the request.</div>
                        </div>
                    </div>
                </div>

                @* ─── Orchestration ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Orchestration</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="enableAIUsageTracking" @bind-Value="EnableAIUsageTracking" class="form-check-input" />
                                <label for="enableAIUsageTracking" class="form-check-label">Enable AI usage tracking</label>
                            </div>
                            <div class="form-text">Disabled by default to avoid extra provider-call tracking overhead. Enable this to capture future AI usage data for the AI Usage Analytics report. This does not affect per-profile session metrics.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="defaultOrchestratorEnablePreemptiveRag" @bind-Value="DefaultOrchestratorEnablePreemptiveRag" class="form-check-input" />
                                <label for="defaultOrchestratorEnablePreemptiveRag" class="form-check-label">Enable preemptive retrieval-augmented generation (RAG)</label>
                            </div>
                            <div class="form-text">When enabled, the default orchestrator retrieves relevant context from connected knowledge sources before the main AI call.</div>
                        </div>

                        <div class="mb-3">
                            <label for="chatInteractionChatMode" class="form-label">Chat Interactions mode</label>
                            <select id="chatInteractionChatMode" @bind="ChatInteractionChatMode" class="form-select">
                                <option value="@ChatMode.TextInput">Text input</option>
                                <option value="@ChatMode.AudioInput">Audio input</option>
                                <option value="@ChatMode.Conversation">Conversation</option>
                            </select>
                            <div class="form-text">Controls whether Chat Interactions use text input only, microphone dictation, or full two-way conversation mode.</div>
                        </div>

                        <div class="mb-3">
                            <label for="maximumIterationsPerRequest" class="form-label">Maximum iterations per request</label>
                            <InputNumber id="maximumIterationsPerRequest" @bind-Value="MaximumIterationsPerRequest" class="form-control" min="1" max="100" style="max-width: 200px;" />
                            <div class="form-text">This caps the number of orchestrator iterations allowed per request. Default is 10.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="enableDistributedCaching" @bind-Value="EnableDistributedCaching" class="form-check-input" />
                                <label for="enableDistributedCaching" class="form-check-label">Enable distributed caching</label>
                            </div>
                            <div class="form-text">Cache AI responses across nodes for improved performance.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="enableOpenTelemetry" @bind-Value="EnableOpenTelemetry" class="form-check-input" />
                                <label for="enableOpenTelemetry" class="form-check-label">Enable OpenTelemetry</label>
                            </div>
                            <div class="form-text">Enable distributed tracing and diagnostics for AI operations.</div>
                        </div>

                        <div class="mb-3">
                            <label for="adminPageSize" class="form-label">Items per page</label>
                            <InputNumber id="adminPageSize" @bind-Value="AdminPageSize" class="form-control" min="1" max="200" style="max-width: 200px;" />
                            <div class="form-text">Controls pagination size for admin lists throughout the application.</div>
                        </div>
                    </div>
                </div>

                @* ─── Admin Widget ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Admin widget</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="adminWidgetProfileId" class="form-label">Chat profile</label>
                            <select id="adminWidgetProfileId" @bind="AdminWidgetProfileId" class="form-select">
                                <option value="">No profile (Disable)</option>
                                @foreach (var p in AdminWidgetProfiles)
                                {
                                    <option value="@p.ItemId">@(p.DisplayText ?? p.Name)</option>
                                }
                            </select>
                            <div class="form-text">Select the chat profile used by the floating admin widget. Leave this empty to disable the widget completely.</div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(AdminWidgetProfileId))
                        {
                            <div class="mb-3">
                                <label for="adminWidgetPrimaryColor" class="form-label">Widget accent color override</label>
                                <div class="input-group">
                                    <input type="color" class="form-control form-control-color"
                                           value="@(string.IsNullOrWhiteSpace(AdminWidgetPrimaryColor) ? AIChatAdminWidgetSettings.DefaultSecondaryColor : AdminWidgetPrimaryColor)"
                                           @onchange="OnColorPickerChanged" />
                                    <InputText id="adminWidgetPrimaryColor" @bind-Value="AdminWidgetPrimaryColor"
                                               class="form-control" placeholder="@AIChatAdminWidgetSettings.DefaultSecondaryColor" />
                                </div>
                                <div class="form-text">Defaults to the admin theme secondary color (<code>@AIChatAdminWidgetSettings.DefaultSecondaryColor</code>).</div>
                            </div>
                        }
                    </div>
                </div>

                @* ─── Documents ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Documents</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure the default AI Documents index used to store embedded chunks for profile and session documents.
                            Uploading files alone is not enough for knowledge-base search; the app also needs an <strong>AI Documents</strong> index profile.
                        </p>

                        <div class="mb-3">
                            <label for="documentIndexProfile" class="form-label">Default AI Documents index</label>
                            <select id="documentIndexProfile" @bind="DocumentIndexProfileName" class="form-select">
                                <option value="">None</option>
                                @foreach (var p in DocumentIndexProfiles)
                                {
                                    <option value="@p.Name">@(p.DisplayText ?? p.Name)</option>
                                }
                            </select>
                            <div class="form-text">Choose the AI Documents index profile that stores embedded document chunks for retrieval during chat.</div>
                        </div>

                        <div class="mb-3">
                            <label for="documentTopN" class="form-label">Default document Top N</label>
                            <InputNumber id="documentTopN" @bind-Value="DocumentTopN" class="form-control" min="1" max="20" style="max-width: 200px;" />
                            <div class="form-text">The default number of matching document chunks to include when a profile does not override it.</div>
                        </div>
                    </div>
                </div>

                @* ─── Data Sources ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Data sources</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="dataSourceDefaultStrictness" class="form-label">Default strictness</label>
                                    <InputNumber id="dataSourceDefaultStrictness" @bind-Value="DataSourceDefaultStrictness" class="form-control"
                                                 min="@AIDataSourceSettings.MinStrictness" max="@AIDataSourceSettings.MaxStrictness" />
                                    <div class="form-text">The default strictness threshold applied when a profile does not specify its own data source strictness.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="dataSourceDefaultTopNDocuments" class="form-label">Default retrieved documents</label>
                                    <InputNumber id="dataSourceDefaultTopNDocuments" @bind-Value="DataSourceDefaultTopNDocuments" class="form-control"
                                                 min="@AIDataSourceSettings.MinTopNDocuments" max="@AIDataSourceSettings.MaxTopNDocuments" />
                                    <div class="form-text">The default number of data source documents retrieved when a profile does not override it.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ─── Copilot ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Copilot</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure how the Copilot orchestrator authenticates with the AI provider.
                        </p>

                        <div class="mb-3">
                            <label for="copilotAuthType" class="form-label">Authentication type</label>
                            <select id="copilotAuthType" @bind="CopilotAuthenticationType" class="form-select">
                                <option value="@CopilotAuthenticationType.NotConfigured">Not configured</option>
                                <option value="@CopilotAuthenticationType.GitHubOAuth">GitHub signed-in user</option>
                                <option value="@CopilotAuthenticationType.ApiKey">API key (BYOK)</option>
                            </select>
                            <div class="form-text">Choose how the Copilot orchestrator authenticates. "Not configured" keeps Copilot disabled until you explicitly select and save an authentication mode.</div>
                        </div>

                        @if (CopilotAuthenticationType == CopilotAuthenticationType.GitHubOAuth)
                        {
                            <div class="mb-4">
                                <h6 class="mb-2">How to create a GitHub app</h6>
                                <div class="ps-3">
                                    <ol>
                                        <li>
                                            In GitHub, go to <strong>Settings</strong> &rarr; <strong>Developer settings</strong> &rarr; <strong>GitHub Apps</strong> and click <strong>New GitHub App</strong>.
                                            You can also open <a href="https://github.com/settings/apps/new" target="_blank" rel="noopener noreferrer">this link</a>.
                                        </li>
                                        <li>Enter an <strong>App name</strong> (e.g., "Blazor Copilot Integration") and your site's <strong>Homepage URL</strong>.</li>
                                        <li>Under <strong>Callback URL</strong>, enter the OAuth callback URL for your application.</li>
                                        <li>Webhooks are <strong>not required</strong> for this integration. Under <strong>Webhook</strong>, uncheck <strong>Active</strong>.</li>
                                        <li>Under <strong>Permissions</strong>, grant <strong>Copilot Chat &rarr; Read-only</strong> access under "Account permissions" to allow model listing.</li>
                                        <li>Choose where the app can be installed and click <strong>Create GitHub App</strong>.</li>
                                        <li>On the app's settings page, copy the <strong>Client ID</strong> and paste it below.</li>
                                        <li>Click <strong>Generate a new client secret</strong>, copy the secret, and paste it below.</li>
                                    </ol>
                                    <p class="text-muted">
                                        Docs: <a href="https://docs.github.com/en/apps/creating-github-apps/about-creating-github-apps/about-creating-github-apps" target="_blank" rel="noopener noreferrer">About creating GitHub Apps</a>
                                    </p>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotClientId" class="form-label">Client ID</label>
                                <InputText id="copilotClientId" @bind-Value="CopilotClientId" class="form-control" />
                                <div class="form-text">The client ID from your GitHub app.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotClientSecret" class="form-label">Client secret</label>
                                <InputText id="copilotClientSecret" @bind-Value="CopilotClientSecret" type="password" class="form-control" placeholder="Enter a new secret to update" />
                                @if (CopilotHasSecret)
                                {
                                    <div class="form-text text-success">A client secret has been securely stored. Enter a new value to replace it, or leave empty to keep the existing secret.</div>
                                }
                                else
                                {
                                    <div class="form-text">The client secret from your GitHub app.</div>
                                }
                            </div>
                        }

                        @if (CopilotAuthenticationType == CopilotAuthenticationType.ApiKey)
                        {
                            <div class="mb-4">
                                <h6 class="mb-2">API key (BYOK) configuration</h6>
                                <p class="text-muted">Use your own API key from a model provider. No GitHub Copilot subscription is required.
                                    <a href="https://github.com/github/copilot-sdk/blob/main/docs/auth/byok.md" target="_blank" rel="noopener noreferrer">Learn more about BYOK</a>
                                </p>
                            </div>

                            <div class="mb-3">
                                <label for="copilotProviderType" class="form-label">Provider type</label>
                                <select id="copilotProviderType" @bind="CopilotProviderType" class="form-select">
                                    <option value="openai">OpenAI / OpenAI-compatible</option>
                                    <option value="azure">Azure OpenAI</option>
                                    <option value="anthropic">Anthropic</option>
                                </select>
                                <div class="form-text">Select the AI provider type.</div>
                            </div>

                            @if (CopilotProviderType == "openai")
                            {
                                <div class="alert alert-info py-2 mb-3">
                                    <strong>OpenAI / OpenAI-compatible</strong><br />
                                    Works with OpenAI API and any OpenAI-compatible endpoint (Ollama, vLLM, LiteLLM, etc.).<br />
                                    <strong>Base URL</strong> should include the full path, e.g., <code>https://api.openai.com/v1</code> or <code>http://localhost:11434/v1</code> for Ollama.<br />
                                    API key is optional for local providers like Ollama.
                                </div>
                            }
                            else if (CopilotProviderType == "azure")
                            {
                                <div class="alert alert-info py-2 mb-3">
                                    <strong>Azure OpenAI</strong><br />
                                    Use for native Azure OpenAI endpoints at <code>*.openai.azure.com</code>.<br />
                                    <strong>Base URL</strong> should be the deployment URL, e.g., <code>https://&lt;deployment-name&gt;.openai.azure.com/</code>. Do <strong>not</strong> include <code>/openai/v1</code>.<br />
                                    An <strong>API key</strong> and <strong>Azure API version</strong> are required.
                                </div>
                            }
                            else if (CopilotProviderType == "anthropic")
                            {
                                <div class="alert alert-info py-2 mb-3">
                                    <strong>Anthropic</strong><br />
                                    For direct Anthropic API access to Claude models.<br />
                                    <strong>Base URL</strong> should be <code>https://api.anthropic.com</code>.
                                </div>
                            }

                            <div class="mb-3">
                                <label for="copilotBaseUrl" class="form-label">Base URL</label>
                                <InputText id="copilotBaseUrl" @bind-Value="CopilotBaseUrl" class="form-control"
                                           placeholder="@GetCopilotBaseUrlPlaceholder()" />
                                <div class="form-text">The API endpoint URL for your provider.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotApiKey" class="form-label">API key</label>
                                <InputText id="copilotApiKey" @bind-Value="CopilotApiKey" type="password" class="form-control" placeholder="Enter API key" />
                                @if (CopilotHasApiKey)
                                {
                                    <div class="form-text text-success">An API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key.</div>
                                }
                                else
                                {
                                    <div class="form-text">The API key from your provider. Optional for local providers like Ollama.</div>
                                }
                            </div>

                            <div class="mb-3">
                                <label for="copilotDefaultModel" class="form-label">Default model</label>
                                <InputText id="copilotDefaultModel" @bind-Value="CopilotDefaultModel" class="form-control" placeholder="gpt-4o" />
                                <div class="form-text">The model name or deployment name to use (e.g., "gpt-4o", "claude-3.5-sonnet"). This is required for BYOK.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotWireApi" class="form-label">Wire API format</label>
                                <select id="copilotWireApi" @bind="CopilotWireApi" class="form-select">
                                    <option value="completions">Chat completions</option>
                                    <option value="responses">Responses</option>
                                </select>
                                <div class="form-text">"Chat completions" works for most models. Use "Responses" for GPT-5 series models that support the newer responses format.</div>
                            </div>

                            @if (CopilotProviderType == "azure")
                            {
                                <div class="mb-3">
                                    <label for="copilotAzureApiVersion" class="form-label">Azure API version</label>
                                    <InputText id="copilotAzureApiVersion" @bind-Value="CopilotAzureApiVersion" class="form-control" placeholder="2024-10-21" />
                                    <div class="form-text">Required for Azure provider. Default: <code>2024-10-21</code>.</div>
                                </div>
                            }
                        }
                    </div>
                </div>

                @* ─── Claude ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-chat-square-dots me-1"></i> Claude</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure direct Claude access for the Claude orchestrator. No external executable or separate Anthropic installation is required.
                        </p>

                        <div class="mb-3">
                            <label for="claudeAuthType" class="form-label">Authentication type</label>
                            <select id="claudeAuthType" @bind="ClaudeAuthenticationType" class="form-select">
                                <option value="@Areas.AIChat.Models.ClaudeAuthenticationType.NotConfigured">Not configured</option>
                                <option value="@Areas.AIChat.Models.ClaudeAuthenticationType.ApiKey">API key</option>
                            </select>
                            <div class="form-text">Choose how the Claude orchestrator authenticates. "Not configured" keeps Claude disabled until you explicitly enable API key authentication.</div>
                        </div>

                        @if (ClaudeAuthenticationType == Areas.AIChat.Models.ClaudeAuthenticationType.ApiKey)
                        {
                            <div class="mb-3">
                                <label for="claudeBaseUrl" class="form-label">Base URL</label>
                                <InputText id="claudeBaseUrl" @bind-Value="ClaudeBaseUrl" class="form-control" placeholder="https://api.anthropic.com" />
                                <div class="form-text">Use the standard Anthropic API base URL unless you have a custom gateway.</div>
                            </div>

                            <div class="mb-3">
                                <label for="claudeApiKey" class="form-label">API key</label>
                                <InputText id="claudeApiKey" @bind-Value="ClaudeApiKey" type="password" class="form-control" placeholder="Enter API key" />
                                @if (ClaudeHasApiKey)
                                {
                                    <div class="form-text text-success">A Claude API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key.</div>
                                }
                                else
                                {
                                    <div class="form-text">The Claude API key used for live model discovery and Claude-orchestrated chats.</div>
                                }
                            </div>

                            <div class="mb-3">
                                <label for="claudeDefaultModel" class="form-label">Default model</label>
                                <InputText id="claudeDefaultModel" @bind-Value="ClaudeDefaultModel" class="form-control" placeholder="claude-sonnet-4-6" />
                                <div class="form-text">Optionally set the Claude model ID used when a profile or interaction does not override it.</div>
                            </div>
                        }
                    </div>
                </div>

                @* ─── MCP Server ─── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Model Context Protocol (MCP) server</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure how external MCP clients access the application's MCP endpoint at <code>/mcp</code>.
                        </p>

                        <div class="mb-3">
                            <label for="mcpServerAuthType" class="form-label">Authentication type</label>
                            <select id="mcpServerAuthType" @bind="McpServerAuthenticationType" class="form-select">
                                @foreach (var authType in Enum.GetValues<McpServerAuthenticationType>())
                                {
                                    <option value="@authType">@authType</option>
                                }
                            </select>
                        </div>

                        @if (McpServerAuthenticationType == McpServerAuthenticationType.ApiKey)
                        {
                            <div class="mb-3">
                                <label for="mcpServerApiKey" class="form-label">API key</label>
                                <InputText id="mcpServerApiKey" @bind-Value="McpServerApiKey" class="form-control" />
                                <div class="form-text">Clients may send this as <code>Bearer key</code>, <code>ApiKey key</code>, or the raw value in the <code>Authorization</code> header.</div>
                            </div>
                        }

                        <div class="form-check form-switch">
                            <InputCheckbox id="mcpServerRequireAccessPermission" @bind-Value="McpServerRequireAccessPermission" class="form-check-input" />
                            <label for="mcpServerRequireAccessPermission" class="form-check-label">Require administrator access for OpenId mode</label>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Saving...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg"></i>
                            <span> Save Settings</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    private const string CopilotProtectorPurpose = "CrestApps.Core.Blazor.Web.CopilotSettings";

    // State flags
    private bool IsLoaded;
    private bool IsSaving;
    private string? SuccessMessage;
    private string? ErrorMessage;

    // General AI Settings
    private bool EnableAIUsageTracking;
    private bool EnablePreemptiveMemoryRetrieval = true;
    private int MaximumIterationsPerRequest = 10;
    private bool EnableDistributedCaching = true;
    private bool EnableOpenTelemetry;

    // Orchestrator
    private bool DefaultOrchestratorEnablePreemptiveRag = true;

    // Chat Interaction
    private ChatMode ChatInteractionChatMode;

    // Memory
    private string? MemoryIndexProfileName;
    private int MemoryTopN = 5;
    private bool EnableUserMemoryByDefault = true;

    // Default Deployments
    private string? DefaultChatDeploymentName;
    private string? DefaultUtilityDeploymentName;
    private string? DefaultEmbeddingDeploymentName;
    private string? DefaultImageDeploymentName;
    private string? DefaultSpeechToTextDeploymentName;
    private string? DefaultTextToSpeechDeploymentName;
    private string? DefaultTextToSpeechVoiceId;

    // Documents
    private string? DocumentIndexProfileName;
    private int DocumentTopN = 3;

    // Data Source
    private int DataSourceDefaultStrictness = AIDataSourceSettings.MinStrictness;
    private int DataSourceDefaultTopNDocuments = AIDataSourceSettings.MinTopNDocuments;

    // MCP Server
    private McpServerAuthenticationType McpServerAuthenticationType = McpServerAuthenticationType.OpenId;
    private string? McpServerApiKey;
    private bool McpServerRequireAccessPermission = true;

    // Copilot
    private CopilotAuthenticationType CopilotAuthenticationType;
    private string? CopilotClientId;
    private string? CopilotClientSecret;
    private bool CopilotHasSecret;
    private string? CopilotProviderType;
    private string? CopilotBaseUrl;
    private string? CopilotApiKey;
    private bool CopilotHasApiKey;
    private string? CopilotWireApi = "completions";
    private string? CopilotDefaultModel;
    private string? CopilotAzureApiVersion;

    // Claude
    private const string ClaudeProtectorPurpose = "CrestApps.Core.Mvc.Web.ClaudeSettings";
    private ClaudeAuthenticationType ClaudeAuthenticationType;
    private string? ClaudeBaseUrl;
    private string? ClaudeApiKey;
    private bool ClaudeHasApiKey;
    private string? ClaudeDefaultModel;

    // Pagination
    private int AdminPageSize = 25;

    // Admin Widget
    private string? AdminWidgetProfileId;
    private string? AdminWidgetPrimaryColor;

    // Dropdown data
    private List<AIDeployment> ChatDeployments = [];
    private List<AIDeployment> UtilityDeployments = [];
    private List<AIDeployment> EmbeddingDeployments = [];
    private List<AIDeployment> ImageDeployments = [];
    private List<AIDeployment> SpeechToTextDeployments = [];
    private List<AIDeployment> TextToSpeechDeployments = [];
    private List<SearchIndexProfile> MemoryIndexProfiles = [];
    private List<SearchIndexProfile> DocumentIndexProfiles = [];
    private List<AIProfile> AdminWidgetProfiles = [];

    protected override async Task OnInitializedAsync()
    {
        var settings = SiteSettingsStore.Get<GeneralAISettings>();
        var chatInteractionSettings = SiteSettingsStore.Get<ChatInteractionSettings>();
        var defaultOrchestratorSettings = SiteSettingsStore.Get<DefaultOrchestratorSettings>();
        var deploymentDefaults = SiteSettingsStore.Get<DefaultAIDeploymentSettings>();
        var memorySettings = SiteSettingsStore.Get<AIMemorySettings>();
        var documentSettings = SiteSettingsStore.Get<InteractionDocumentSettings>();
        var dataSourceSettings = SiteSettingsStore.Get<AIDataSourceSettings>();
        var mcpServerSettings = SiteSettingsStore.Get<McpServerOptions>();
        var chatInteractionMemorySettings = SiteSettingsStore.Get<MemoryMetadata>();
        var copilotSettings = SiteSettingsStore.Get<CopilotSettings>();
        var paginationSettings = SiteSettingsStore.Get<PaginationSettings>();
        var adminWidgetSettings = SiteSettingsStore.Get<AIChatAdminWidgetSettings>();

        // General AI Settings
        EnableAIUsageTracking = settings.EnableAIUsageTracking;
        EnablePreemptiveMemoryRetrieval = settings.EnablePreemptiveMemoryRetrieval;
        MaximumIterationsPerRequest = settings.MaximumIterationsPerRequest;
        EnableDistributedCaching = settings.EnableDistributedCaching;
        EnableOpenTelemetry = settings.EnableOpenTelemetry;

        // Orchestrator
        DefaultOrchestratorEnablePreemptiveRag = defaultOrchestratorSettings.EnablePreemptiveRag;

        // Chat Interaction
        ChatInteractionChatMode = chatInteractionSettings.ChatMode;

        // Memory
        MemoryIndexProfileName = memorySettings.IndexProfileName;
        MemoryTopN = memorySettings.TopN;
        EnableUserMemoryByDefault = chatInteractionMemorySettings.EnableUserMemory ?? true;

        // Default Deployments
        DefaultChatDeploymentName = deploymentDefaults.DefaultChatDeploymentName;
        DefaultUtilityDeploymentName = deploymentDefaults.DefaultUtilityDeploymentName;
        DefaultEmbeddingDeploymentName = deploymentDefaults.DefaultEmbeddingDeploymentName;
        DefaultImageDeploymentName = deploymentDefaults.DefaultImageDeploymentName;
        DefaultSpeechToTextDeploymentName = deploymentDefaults.DefaultSpeechToTextDeploymentName;
        DefaultTextToSpeechDeploymentName = deploymentDefaults.DefaultTextToSpeechDeploymentName;
        DefaultTextToSpeechVoiceId = deploymentDefaults.DefaultTextToSpeechVoiceId;

        // Documents
        DocumentIndexProfileName = documentSettings.IndexProfileName;
        DocumentTopN = documentSettings.TopN;

        // Data Source
        DataSourceDefaultStrictness = dataSourceSettings.DefaultStrictness;
        DataSourceDefaultTopNDocuments = dataSourceSettings.DefaultTopNDocuments;

        // MCP Server
        McpServerAuthenticationType = mcpServerSettings.AuthenticationType;
        McpServerApiKey = mcpServerSettings.ApiKey;
        McpServerRequireAccessPermission = mcpServerSettings.RequireAccessPermission;

        // Copilot
        CopilotAuthenticationType = copilotSettings.AuthenticationType;
        CopilotClientId = copilotSettings.ClientId;
        CopilotHasSecret = !string.IsNullOrWhiteSpace(copilotSettings.ProtectedClientSecret);
        CopilotProviderType = copilotSettings.ProviderType;
        CopilotBaseUrl = copilotSettings.BaseUrl;
        CopilotHasApiKey = !string.IsNullOrWhiteSpace(copilotSettings.ProtectedApiKey);
        CopilotWireApi = copilotSettings.WireApi ?? "completions";
        CopilotDefaultModel = copilotSettings.DefaultModel;
        CopilotAzureApiVersion = copilotSettings.AzureApiVersion;

        // Claude
        var claudeSettings = SiteSettingsStore.Get<ClaudeSettings>();
        ClaudeAuthenticationType = claudeSettings.AuthenticationType;
        ClaudeBaseUrl = claudeSettings.BaseUrl;
        ClaudeHasApiKey = !string.IsNullOrWhiteSpace(claudeSettings.ProtectedApiKey);
        ClaudeDefaultModel = claudeSettings.DefaultModel;

        // Pagination
        AdminPageSize = paginationSettings.AdminPageSize;

        // Admin Widget
        AdminWidgetProfileId = adminWidgetSettings.ProfileId;
        AdminWidgetPrimaryColor = string.IsNullOrWhiteSpace(adminWidgetSettings.PrimaryColor)
            ? AIChatAdminWidgetSettings.DefaultSecondaryColor
            : adminWidgetSettings.PrimaryColor;

        // Populate dropdowns
        await PopulateDropdownsAsync();

        IsLoaded = true;
    }

    private async Task PopulateDropdownsAsync()
    {
        ChatDeployments = (await DeploymentManager.GetByTypeAsync(AIDeploymentType.Chat)).ToList();
        UtilityDeployments = (await DeploymentManager.GetByTypeAsync(AIDeploymentType.Utility)).ToList();
        EmbeddingDeployments = (await DeploymentManager.GetByTypeAsync(AIDeploymentType.Embedding)).ToList();
        ImageDeployments = (await DeploymentManager.GetByTypeAsync(AIDeploymentType.Image)).ToList();
        SpeechToTextDeployments = (await DeploymentManager.GetByTypeAsync(AIDeploymentType.SpeechToText)).ToList();
        TextToSpeechDeployments = (await DeploymentManager.GetByTypeAsync(AIDeploymentType.TextToSpeech)).ToList();

        DocumentIndexProfiles = (await IndexProfileStore.GetByTypeAsync(IndexProfileTypes.AIDocuments))
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        MemoryIndexProfiles = (await IndexProfileStore.GetByTypeAsync(IndexProfileTypes.AIMemory))
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        AdminWidgetProfiles = (await ProfileManager.GetAsync(AIProfileType.Chat))
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task HandleSave()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        // Validation
        if (MaximumIterationsPerRequest < 1)
        {
            ErrorMessage = "Maximum iterations per request must be at least 1.";
            return;
        }

        if (DocumentTopN < 1)
        {
            ErrorMessage = "Document Top N must be at least 1.";
            return;
        }

        if (MemoryTopN < 1 || MemoryTopN > 20)
        {
            ErrorMessage = "Memory Top N must be between 1 and 20.";
            return;
        }

        if (DataSourceDefaultStrictness < AIDataSourceSettings.MinStrictness || DataSourceDefaultStrictness > AIDataSourceSettings.MaxStrictness)
        {
            ErrorMessage = $"Data source strictness must be between {AIDataSourceSettings.MinStrictness} and {AIDataSourceSettings.MaxStrictness}.";
            return;
        }

        if (DataSourceDefaultTopNDocuments < AIDataSourceSettings.MinTopNDocuments || DataSourceDefaultTopNDocuments > AIDataSourceSettings.MaxTopNDocuments)
        {
            ErrorMessage = $"Data source retrieved documents must be between {AIDataSourceSettings.MinTopNDocuments} and {AIDataSourceSettings.MaxTopNDocuments}.";
            return;
        }

        if (McpServerAuthenticationType == McpServerAuthenticationType.ApiKey &&
            string.IsNullOrWhiteSpace(McpServerApiKey))
        {
            ErrorMessage = "API key is required when the MCP server uses API key authentication.";
            return;
        }

        // Claude validation
        if (ClaudeAuthenticationType == Areas.AIChat.Models.ClaudeAuthenticationType.ApiKey)
        {
            var existingClaudeForValidation = SiteSettingsStore.Get<ClaudeSettings>();
            if (string.IsNullOrWhiteSpace(ClaudeApiKey) &&
                string.IsNullOrWhiteSpace(existingClaudeForValidation.ProtectedApiKey))
            {
                ErrorMessage = "API key is required when Claude uses API key authentication.";
                return;
            }
        }

        if (AdminPageSize < 1 || AdminPageSize > 200)
        {
            ErrorMessage = "Page size must be between 1 and 200.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(AdminWidgetPrimaryColor) &&
            !Regex.IsMatch(AdminWidgetPrimaryColor, "^#(?:[0-9a-fA-F]{3}){1,2}$", RegexOptions.CultureInvariant, TimeSpan.FromMilliseconds(100)))
        {
            ErrorMessage = "Widget color must be a valid hex value such as #6c757d.";
            return;
        }

        IsSaving = true;

        try
        {
            // Save general AI settings.
            SiteSettingsStore.Set<GeneralAISettings>(s =>
            {
                s.EnablePreemptiveMemoryRetrieval = EnablePreemptiveMemoryRetrieval;
                s.EnableAIUsageTracking = EnableAIUsageTracking;
                s.MaximumIterationsPerRequest = MaximumIterationsPerRequest;
                s.EnableDistributedCaching = EnableDistributedCaching;
                s.EnableOpenTelemetry = EnableOpenTelemetry;
            });

            SiteSettingsStore.Set<ChatInteractionSettings>(s =>
            {
                s.ChatMode = ChatInteractionChatMode;
            });

            SiteSettingsStore.Set(new DefaultOrchestratorSettings
            {
                EnablePreemptiveRag = DefaultOrchestratorEnablePreemptiveRag,
            });

            SiteSettingsStore.Set(new DefaultAIDeploymentSettings
            {
                DefaultChatDeploymentName = DefaultChatDeploymentName,
                DefaultUtilityDeploymentName = DefaultUtilityDeploymentName,
                DefaultEmbeddingDeploymentName = DefaultEmbeddingDeploymentName,
                DefaultImageDeploymentName = DefaultImageDeploymentName,
                DefaultSpeechToTextDeploymentName = DefaultSpeechToTextDeploymentName,
                DefaultTextToSpeechDeploymentName = DefaultTextToSpeechDeploymentName,
                DefaultTextToSpeechVoiceId = DefaultTextToSpeechVoiceId?.Trim(),
            });

            SiteSettingsStore.Set(new AIMemorySettings
            {
                IndexProfileName = string.IsNullOrWhiteSpace(MemoryIndexProfileName)
                    ? string.Empty
                    : MemoryIndexProfileName.Trim(),
                TopN = MemoryTopN,
            });

            SiteSettingsStore.Set(new InteractionDocumentSettings
            {
                IndexProfileName = DocumentIndexProfileName?.Trim(),
                TopN = DocumentTopN,
            });

            SiteSettingsStore.Set(new AIDataSourceSettings
            {
                DefaultStrictness = DataSourceDefaultStrictness,
                DefaultTopNDocuments = DataSourceDefaultTopNDocuments,
            });

            SiteSettingsStore.Set(new McpServerOptions
            {
                AuthenticationType = McpServerAuthenticationType,
                ApiKey = McpServerApiKey?.Trim(),
                RequireAccessPermission = McpServerRequireAccessPermission,
            });

            SiteSettingsStore.Set(new MemoryMetadata
            {
                EnableUserMemory = EnableUserMemoryByDefault,
            });

            // Save Copilot settings, preserving existing protected secrets.
            var existingCopilot = SiteSettingsStore.Get<CopilotSettings>();
            var protector = DataProtectionProvider.CreateProtector(CopilotProtectorPurpose);

            var copilotSettings = new CopilotSettings
            {
                AuthenticationType = CopilotAuthenticationType,
                ClientId = CopilotClientId?.Trim() ?? string.Empty,
                ProtectedClientSecret = existingCopilot.ProtectedClientSecret,
                ProviderType = CopilotProviderType ?? string.Empty,
                BaseUrl = CopilotBaseUrl?.Trim() ?? string.Empty,
                ProtectedApiKey = existingCopilot.ProtectedApiKey,
                WireApi = CopilotWireApi ?? string.Empty,
                DefaultModel = CopilotDefaultModel?.Trim() ?? string.Empty,
                AzureApiVersion = CopilotAzureApiVersion?.Trim() ?? string.Empty,
            };

            if (!string.IsNullOrWhiteSpace(CopilotClientSecret))
            {
                copilotSettings.ProtectedClientSecret = protector.Protect(CopilotClientSecret.Trim());
            }

            if (!string.IsNullOrWhiteSpace(CopilotApiKey))
            {
                copilotSettings.ProtectedApiKey = protector.Protect(CopilotApiKey.Trim());
            }

            SiteSettingsStore.Set(copilotSettings);

            // Save Claude settings, preserving existing protected API key.
            var existingClaude = SiteSettingsStore.Get<ClaudeSettings>();
            var claudeProtector = DataProtectionProvider.CreateProtector(ClaudeProtectorPurpose);

            var claudeSettings = new ClaudeSettings
            {
                AuthenticationType = ClaudeAuthenticationType,
                BaseUrl = string.IsNullOrWhiteSpace(ClaudeBaseUrl)
                    ? "https://api.anthropic.com"
                    : ClaudeBaseUrl.Trim(),
                ProtectedApiKey = existingClaude.ProtectedApiKey,
                DefaultModel = ClaudeDefaultModel?.Trim(),
            };

            if (!string.IsNullOrWhiteSpace(ClaudeApiKey))
            {
                claudeSettings.ProtectedApiKey = claudeProtector.Protect(ClaudeApiKey.Trim());
            }

            SiteSettingsStore.Set(claudeSettings);

            SiteSettingsStore.Set(new PaginationSettings
            {
                AdminPageSize = AdminPageSize,
            });

            SiteSettingsStore.Set(new AIChatAdminWidgetSettings
            {
                ProfileId = string.IsNullOrWhiteSpace(AdminWidgetProfileId) ? string.Empty : AdminWidgetProfileId.Trim(),
                PrimaryColor = string.IsNullOrWhiteSpace(AdminWidgetPrimaryColor)
                    ? AIChatAdminWidgetSettings.DefaultSecondaryColor
                    : AdminWidgetPrimaryColor.Trim(),
            });

            await SiteSettingsStore.SaveChangesAsync();

            // Clear secret fields after save to avoid re-submitting them.
            CopilotClientSecret = null;
            CopilotApiKey = null;
            CopilotHasSecret = !string.IsNullOrWhiteSpace(copilotSettings.ProtectedClientSecret);
            CopilotHasApiKey = !string.IsNullOrWhiteSpace(copilotSettings.ProtectedApiKey);

            ClaudeApiKey = null;
            ClaudeHasApiKey = !string.IsNullOrWhiteSpace(claudeSettings.ProtectedApiKey);

            SuccessMessage = "Settings saved successfully.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private static Dictionary<string, List<AIDeployment>> GroupDeployments(List<AIDeployment> deployments)
    {
        return deployments
            .OrderBy(d => d.ConnectionName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(d => d.Name, StringComparer.OrdinalIgnoreCase)
            .GroupBy(d => d.ConnectionName ?? "Default")
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private static string FormatDeploymentLabel(AIDeployment d)
    {
        return string.Equals(d.Name, d.ModelName, StringComparison.OrdinalIgnoreCase)
            ? d.Name
            : $"{d.Name} ({d.ModelName})";
    }

    private string GetCopilotBaseUrlPlaceholder()
    {
        return CopilotProviderType switch
        {
            "azure" => "https://<deployment-name>.openai.azure.com/",
            "anthropic" => "https://api.anthropic.com",
            _ => "https://api.openai.com/v1",
        };
    }

    private void OnColorPickerChanged(ChangeEventArgs e)
    {
        AdminWidgetPrimaryColor = e.Value?.ToString();
    }
}
