@page "/admin/settings"
@attribute [Authorize(Policy = "Admin")]

@using System.Text.RegularExpressions
@using CrestApps.Core.AI.Claude.Models
@using CrestApps.Core.AI.Claude.Services
@using CrestApps.Core.AI.Copilot.Models
@using CrestApps.Core.AI.Deployments
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.Blazor.Web.Areas.AIChat.Services
@using CrestApps.Core.Blazor.Web.Areas.ChatInteractions.Models
@using CrestApps.Core.Blazor.Web.Models
@using CrestApps.Core.Blazor.Web.Services
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Infrastructure.Indexing
@using Microsoft.AspNetCore.DataProtection

@inject SiteSettingsStore SiteSettings
@inject IAIDeploymentManager DeploymentManager
@inject IAIProfileManager ProfileManager
@inject ISearchIndexProfileStore IndexProfileStore
@inject IDataProtectionProvider DataProtectionProvider
@inject ClaudeClientService ClaudeClientService

<PageTitle>AI Settings - CrestApps AI</PageTitle>

<h2><i class="bi bi-gear"></i> AI Settings</h2>
<hr />

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (_model == null)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <EditForm FormName="admin-settings-index" Model="_model" OnValidSubmit="HandleSaveAsync">
        <div class="row">
            <div class="col-md-8">

                @* ── Default Deployments ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Default Deployments</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Select the default deployment for each capability. These are used as a
                            fallback when a specific deployment is not configured at the profile or
                            connection level.
                        </p>

                        <div class="mb-3">
                            <label for="defaultChat" class="form-label">Default chat deployment</label>
                            <select id="defaultChat" class="form-select" @bind="_model.DefaultChatDeploymentName">
                                <option value="">None</option>
                                @foreach (var d in _model.ChatDeployments)
                                {
                                    <option value="@d.Key">@d.Value</option>
                                }
                            </select>
                            <div class="form-text">The default deployment used for chat sessions and chat interactions when no specific chat deployment is configured.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultUtility" class="form-label">Default utility deployment</label>
                            <select id="defaultUtility" class="form-select" @bind="_model.DefaultUtilityDeploymentName">
                                <option value="">None</option>
                                @foreach (var d in _model.UtilityDeployments)
                                {
                                    <option value="@d.Key">@d.Value</option>
                                }
                            </select>
                            <div class="form-text">The default deployment used for auxiliary tasks such as planning, intent detection, query rewriting, and chart generation.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultEmbedding" class="form-label">Default embedding deployment</label>
                            <select id="defaultEmbedding" class="form-select" @bind="_model.DefaultEmbeddingDeploymentName">
                                <option value="">None</option>
                                @foreach (var d in _model.EmbeddingDeployments)
                                {
                                    <option value="@d.Key">@d.Value</option>
                                }
                            </select>
                            <div class="form-text">The default deployment used for embedding generation in document indexing, data sources, and vector search.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultImage" class="form-label">Default image deployment</label>
                            <select id="defaultImage" class="form-select" @bind="_model.DefaultImageDeploymentName">
                                <option value="">None</option>
                                @foreach (var d in _model.ImageDeployments)
                                {
                                    <option value="@d.Key">@d.Value</option>
                                }
                            </select>
                            <div class="form-text">The default deployment used for image generation.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultStt" class="form-label">Default speech-to-text deployment</label>
                            <select id="defaultStt" class="form-select" @bind="_model.DefaultSpeechToTextDeploymentName">
                                <option value="">None</option>
                                @foreach (var d in _model.SpeechToTextDeployments)
                                {
                                    <option value="@d.Key">@d.Value</option>
                                }
                            </select>
                            <div class="form-text">The default deployment used for speech-to-text transcription.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultTts" class="form-label">Default text-to-speech deployment</label>
                            <select id="defaultTts" class="form-select" @bind="_model.DefaultTextToSpeechDeploymentName">
                                <option value="">None</option>
                                @foreach (var d in _model.TextToSpeechDeployments)
                                {
                                    <option value="@d.Key">@d.Value</option>
                                }
                            </select>
                            <div class="form-text">The default deployment used for text-to-speech synthesis.</div>
                        </div>

                        <div class="mb-3">
                            <label for="defaultTtsVoice" class="form-label">Default text-to-speech voice</label>
                            <InputText id="defaultTtsVoice" @bind-Value="_model.DefaultTextToSpeechVoiceId" class="form-control" placeholder="Default voice" />
                            <div class="form-text">The default voice used for text-to-speech when a profile does not specify one.</div>
                        </div>
                    </div>
                </div>

                @* ── Memory ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Memory</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="memoryIndex" class="form-label">Default memory index</label>
                            <select id="memoryIndex" class="form-select" @bind="_model.MemoryIndexProfileName">
                                <option value="">None</option>
                                @foreach (var p in _model.MemoryIndexProfiles)
                                {
                                    <option value="@p.Key">@p.Value</option>
                                }
                            </select>
                            @if (_errors.TryGetValue(nameof(_model.MemoryIndexProfileName), out var memIdxErr))
                            {
                                <span class="text-danger">@memIdxErr</span>
                            }
                            <div class="form-text">Choose the AI Memory index profile used to store and retrieve user memories.</div>
                        </div>

                        <div class="mb-3">
                            <label for="memoryTopN" class="form-label">Default memory Top N</label>
                            <InputNumber id="memoryTopN" @bind-Value="_model.MemoryTopN" class="form-control" style="max-width: 200px;" />
                            @if (_errors.TryGetValue(nameof(_model.MemoryTopN), out var memTopNErr))
                            {
                                <span class="text-danger">@memTopNErr</span>
                            }
                            <div class="form-text">The default number of memory entries retrieved when memory is enabled.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="enableUserMemory" @bind-Value="_model.EnableUserMemoryByDefault" class="form-check-input" />
                                <label for="enableUserMemory" class="form-check-label">Enable user memory by default</label>
                            </div>
                            <div class="form-text">When enabled, chat interactions automatically remember user preferences and context across sessions. Individual profiles can override this setting.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="preemptiveMemory" @bind-Value="_model.EnablePreemptiveMemoryRetrieval" class="form-check-input" />
                                <label for="preemptiveMemory" class="form-check-label">Enable preemptive memory retrieval</label>
                            </div>
                            <div class="form-text">Allow the orchestrator to preload relevant user memory before generation when memory is enabled for the request.</div>
                        </div>
                    </div>
                </div>

                @* ── Orchestration ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Orchestration</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="usageTracking" @bind-Value="_model.EnableAIUsageTracking" class="form-check-input" />
                                <label for="usageTracking" class="form-check-label">Enable AI usage tracking</label>
                            </div>
                            <div class="form-text">Disabled by default to avoid extra provider-call tracking overhead. Enable this to capture future AI usage data for the AI Usage Analytics report. This does not affect per-profile session metrics.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="preemptiveRag" @bind-Value="_model.DefaultOrchestratorEnablePreemptiveRag" class="form-check-input" />
                                <label for="preemptiveRag" class="form-check-label">Enable preemptive retrieval-augmented generation (RAG)</label>
                            </div>
                            <div class="form-text">When enabled, the default orchestrator retrieves relevant context from connected knowledge sources before the main AI call.</div>
                        </div>

                        <div class="mb-3">
                            <label for="chatMode" class="form-label">Chat Interactions mode</label>
                            <select id="chatMode" class="form-select" @bind="_model.ChatInteractionChatMode">
                                <option value="@ChatMode.TextInput">Text input</option>
                                <option value="@ChatMode.AudioInput">Audio input</option>
                                <option value="@ChatMode.Conversation">Conversation</option>
                            </select>
                            <div class="form-text">Controls whether Chat Interactions use text input only, microphone dictation, or full two-way conversation mode.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="ttsPlayback" @bind-Value="_model.ChatInteractionEnableTextToSpeechPlayback" class="form-check-input" />
                                <label for="ttsPlayback" class="form-check-label">Enable text-to-speech playback for Chat Interactions</label>
                            </div>
                            <div class="form-text">When enabled, assistant messages in Chat Interactions show a play button that reads the response aloud using the configured text-to-speech deployment.</div>
                        </div>

                        <div class="mb-3">
                            <label for="maxIterations" class="form-label">Maximum iterations per request</label>
                            <InputNumber id="maxIterations" @bind-Value="_model.MaximumIterationsPerRequest" class="form-control" style="max-width: 200px;" />
                            @if (_errors.TryGetValue(nameof(_model.MaximumIterationsPerRequest), out var maxIterErr))
                            {
                                <span class="text-danger">@maxIterErr</span>
                            }
                            <div class="form-text">This caps the number of orchestrator iterations allowed per request. Default is 10.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="distributedCaching" @bind-Value="_model.EnableDistributedCaching" class="form-check-input" />
                                <label for="distributedCaching" class="form-check-label">Enable distributed caching</label>
                            </div>
                            <div class="form-text">Cache AI responses across nodes for improved performance.</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="openTelemetry" @bind-Value="_model.EnableOpenTelemetry" class="form-check-input" />
                                <label for="openTelemetry" class="form-check-label">Enable OpenTelemetry</label>
                            </div>
                            <div class="form-text">Enable distributed tracing and diagnostics for AI operations.</div>
                        </div>

                        <div class="mb-3">
                            <label for="adminPageSize" class="form-label">Items per page</label>
                            <InputNumber id="adminPageSize" @bind-Value="_model.AdminPageSize" class="form-control" style="max-width: 200px;" />
                            @if (_errors.TryGetValue(nameof(_model.AdminPageSize), out var pageSizeErr))
                            {
                                <span class="text-danger">@pageSizeErr</span>
                            }
                            <div class="form-text">Controls pagination size for admin lists throughout the Blazor application.</div>
                        </div>
                    </div>
                </div>

                @* ── Admin Widget ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Admin widget</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="widgetProfile" class="form-label">Chat profile</label>
                            <select id="widgetProfile" class="form-select" @bind="_model.AdminWidgetProfileId">
                                <option value="">No profile (Disable)</option>
                                @foreach (var p in _model.AdminWidgetProfiles)
                                {
                                    <option value="@p.Key">@p.Value</option>
                                }
                            </select>
                            @if (_errors.TryGetValue(nameof(_model.AdminWidgetProfileId), out var widgetProfileErr))
                            {
                                <span class="text-danger">@widgetProfileErr</span>
                            }
                            <div class="form-text">Select the chat profile used by the floating admin widget. Leave this empty to disable the widget completely.</div>
                        </div>

                        <div class="mb-3">
                            <label for="widgetColor" class="form-label">Widget accent color override</label>
                            <div class="input-group">
                                <input type="color" class="form-control form-control-color"
                                       value="@(string.IsNullOrWhiteSpace(_model.AdminWidgetPrimaryColor) ? AIChatAdminWidgetSettings.DefaultSecondaryColor : _model.AdminWidgetPrimaryColor)"
                                       @onchange="e => _model.AdminWidgetPrimaryColor = e.Value?.ToString()" />
                                <InputText @bind-Value="_model.AdminWidgetPrimaryColor"
                                           class="form-control"
                                           placeholder="@AIChatAdminWidgetSettings.DefaultSecondaryColor" />
                            </div>
                            @if (_errors.TryGetValue(nameof(_model.AdminWidgetPrimaryColor), out var colorErr))
                            {
                                <span class="text-danger">@colorErr</span>
                            }
                            <div class="form-text">Defaults to the admin theme secondary color (<code>@AIChatAdminWidgetSettings.DefaultSecondaryColor</code>).</div>
                        </div>
                    </div>
                </div>

                @* ── Documents ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Documents</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure the default AI Documents index used to store embedded chunks for profile and session documents.
                            Uploading files alone is not enough for knowledge-base search; the app also needs an <strong>AI Documents</strong> index profile.
                        </p>

                        <div class="mb-3">
                            <label for="docIndex" class="form-label">Default AI Documents index</label>
                            <select id="docIndex" class="form-select" @bind="_model.DocumentIndexProfileName">
                                <option value="">None</option>
                                @foreach (var p in _model.DocumentIndexProfiles)
                                {
                                    <option value="@p.Key">@p.Value</option>
                                }
                            </select>
                            <div class="form-text">Choose the AI Documents index profile that stores embedded document chunks for retrieval during chat.</div>
                        </div>

                        <div class="mb-3">
                            <label for="docTopN" class="form-label">Default document Top N</label>
                            <InputNumber id="docTopN" @bind-Value="_model.DocumentTopN" class="form-control" style="max-width: 200px;" />
                            @if (_errors.TryGetValue(nameof(_model.DocumentTopN), out var docTopNErr))
                            {
                                <span class="text-danger">@docTopNErr</span>
                            }
                            <div class="form-text">The default number of matched chunks or documents to include when a profile does not override it.</div>
                        </div>

                        <div class="mb-3">
                            <label for="docRetrieval" class="form-label">Default retrieval mode</label>
                            <InputSelect id="docRetrieval" @bind-Value="_model.DocumentRetrievalMode" class="form-select" style="max-width: 320px;">
                                @foreach (var mode in Enum.GetValues<DocumentRetrievalMode>())
                                {
                                    <option value="@mode">@mode</option>
                                }
                            </InputSelect>
                            <div class="form-text">Use <strong>Chunk</strong> for chunk-level RAG, or <strong>Hierarchical</strong> to match on chunks and then inject the full text of the matched documents.</div>
                        </div>
                    </div>
                </div>

                @* ── Data Sources ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Data sources</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="dsStrictness" class="form-label">Default strictness</label>
                                    <InputNumber id="dsStrictness" @bind-Value="_model.DataSourceDefaultStrictness" class="form-control" />
                                    @if (_errors.TryGetValue(nameof(_model.DataSourceDefaultStrictness), out var strictErr))
                                    {
                                        <span class="text-danger">@strictErr</span>
                                    }
                                    <div class="form-text">The default strictness threshold applied when a profile does not specify its own data source strictness.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="dsTopN" class="form-label">Default retrieved documents</label>
                                    <InputNumber id="dsTopN" @bind-Value="_model.DataSourceDefaultTopNDocuments" class="form-control" />
                                    @if (_errors.TryGetValue(nameof(_model.DataSourceDefaultTopNDocuments), out var dsTopNErr))
                                    {
                                        <span class="text-danger">@dsTopNErr</span>
                                    }
                                    <div class="form-text">The default number of data source documents retrieved when a profile does not override it.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── Copilot ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-github"></i> Copilot</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure how the Copilot orchestrator authenticates with the AI provider.
                        </p>

                        <div class="mb-3">
                            <label for="copilotAuth" class="form-label">Authentication type</label>
                            <select id="copilotAuth" class="form-select" value="@_model.CopilotAuthenticationType" @onchange="OnCopilotAuthTypeChanged">
                                <option value="@CopilotAuthenticationType.NotConfigured">Not configured</option>
                                <option value="@CopilotAuthenticationType.GitHubOAuth">GitHub signed-in user</option>
                                <option value="@CopilotAuthenticationType.ApiKey">API key (BYOK)</option>
                            </select>
                            <div class="form-text">Choose how the Copilot orchestrator authenticates. "Not configured" keeps Copilot disabled until you explicitly select and save an authentication mode.</div>
                        </div>

                        @if (_model.CopilotAuthenticationType == CopilotAuthenticationType.GitHubOAuth)
                        {
                            <div class="mb-4">
                                <h6 class="mb-2">How to create a GitHub app</h6>
                                <div class="ps-3">
                                    <ol>
                                        <li>
                                            In GitHub, go to <strong>Settings</strong> &rarr; <strong>Developer settings</strong> &rarr; <strong>GitHub Apps</strong> and click <strong>New GitHub App</strong>.
                                            You can also open <a href="https://github.com/settings/apps/new" target="_blank" rel="noopener noreferrer">this link</a>.
                                        </li>
                                        <li>Enter an <strong>App name</strong> (e.g., "Blazor Copilot Integration") and your site's <strong>Homepage URL</strong>.</li>
                                        <li>Under <strong>Callback URL</strong>, enter the value configured in your Copilot OAuth callback endpoint.</li>
                                        <li>Webhooks are <strong>not required</strong> for this integration. Under <strong>Webhook</strong>, uncheck <strong>Active</strong>.</li>
                                        <li>Under <strong>Permissions</strong>, grant <strong>Copilot Chat &rarr; Read-only</strong> access under "Account permissions" to allow model listing.</li>
                                        <li>Choose where the app can be installed and click <strong>Create GitHub App</strong>.</li>
                                        <li>On the app's settings page, copy the <strong>Client ID</strong> and paste it below.</li>
                                        <li>Click <strong>Generate a new client secret</strong>, copy the secret, and paste it below.</li>
                                    </ol>
                                    <p class="text-muted">
                                        Docs: <a href="https://docs.github.com/en/apps/creating-github-apps/about-creating-github-apps/about-creating-github-apps" target="_blank" rel="noopener noreferrer">About creating GitHub Apps</a>
                                    </p>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotClientId" class="form-label">Client ID</label>
                                <InputText id="copilotClientId" @bind-Value="_model.CopilotClientId" class="form-control" />
                                <div class="form-text">The client ID from your GitHub app.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotClientSecret" class="form-label">Client secret</label>
                                <InputText id="copilotClientSecret" @bind-Value="_model.CopilotClientSecret" type="password" class="form-control" placeholder="Enter a new secret to update" />
                                @if (_model.CopilotHasSecret)
                                {
                                    <div class="form-text text-success">A client secret has been securely stored. Enter a new value to replace it, or leave empty to keep the existing secret.</div>
                                }
                                else
                                {
                                    <div class="form-text">The client secret from your GitHub app.</div>
                                }
                            </div>
                        }

                        @if (_model.CopilotAuthenticationType == CopilotAuthenticationType.ApiKey)
                        {
                            <div class="mb-4">
                                <h6 class="mb-2">API key (BYOK) configuration</h6>
                                <p class="text-muted">
                                    Use your own API key from a model provider. No GitHub Copilot subscription is required.
                                    <a href="https://github.com/github/copilot-sdk/blob/main/docs/auth/byok.md" target="_blank" rel="noopener noreferrer">Learn more about BYOK</a>
                                </p>
                            </div>

                            <div class="mb-3">
                                <label for="copilotProvider" class="form-label">Provider type</label>
                                <select id="copilotProvider" class="form-select" value="@_model.CopilotProviderType" @onchange="OnCopilotProviderTypeChanged">
                                    <option value="openai">OpenAI / OpenAI-compatible</option>
                                    <option value="azure">Azure OpenAI</option>
                                    <option value="anthropic">Anthropic</option>
                                </select>
                                <div class="form-text">Select the AI provider type.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotBaseUrl" class="form-label">Base URL</label>
                                <InputText id="copilotBaseUrl" @bind-Value="_model.CopilotBaseUrl" class="form-control" placeholder="https://api.openai.com/v1" />
                                <div class="form-text">The API endpoint URL for your provider.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotApiKey" class="form-label">API key</label>
                                <InputText id="copilotApiKey" @bind-Value="_model.CopilotApiKey" type="password" class="form-control" placeholder="Enter API key" />
                                @if (_model.CopilotHasApiKey)
                                {
                                    <div class="form-text text-success">An API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key.</div>
                                }
                                else
                                {
                                    <div class="form-text">The API key from your provider. Optional for local providers like Ollama.</div>
                                }
                            </div>

                            <div class="mb-3">
                                <label for="copilotModel" class="form-label">Default model</label>
                                <InputText id="copilotModel" @bind-Value="_model.CopilotDefaultModel" class="form-control" placeholder="gpt-4o" />
                                <div class="form-text">The model name or deployment name to use (e.g., "gpt-4o", "claude-3.5-sonnet"). This is required for BYOK.</div>
                            </div>

                            <div class="mb-3">
                                <label for="copilotWireApi" class="form-label">Wire API format</label>
                                <InputSelect id="copilotWireApi" @bind-Value="_model.CopilotWireApi" class="form-select">
                                    <option value="completions">Chat completions</option>
                                    <option value="responses">Responses</option>
                                </InputSelect>
                                <div class="form-text">"Chat completions" works for most models. Use "Responses" for GPT-5 series models that support the newer responses format.</div>
                            </div>

                            @if (string.Equals(_model.CopilotProviderType, "azure", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="mb-3">
                                    <label for="copilotAzureVersion" class="form-label">Azure API version</label>
                                    <InputText id="copilotAzureVersion" @bind-Value="_model.CopilotAzureApiVersion" class="form-control" placeholder="2024-10-21" />
                                    <div class="form-text">Required for Azure provider. Default: <code>2024-10-21</code>.</div>
                                </div>
                            }
                        }
                    </div>
                </div>

                @* ── MCP Server ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Model Context Protocol (MCP) server</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure how external MCP clients access the application's MCP endpoint at <code>/mcp</code>.
                        </p>

                        <div class="mb-3">
                            <label for="mcpAuth" class="form-label">Authentication type</label>
                            <select id="mcpAuth" class="form-select" value="@_model.McpServerAuthenticationType" @onchange="OnMcpAuthTypeChanged">
                                @foreach (var authType in Enum.GetValues<McpServerAuthenticationType>())
                                {
                                    <option value="@authType">@authType</option>
                                }
                            </select>
                        </div>

                        @if (_model.McpServerAuthenticationType == McpServerAuthenticationType.ApiKey)
                        {
                            <div class="mb-3">
                                <label for="mcpApiKey" class="form-label">API key</label>
                                <InputText id="mcpApiKey" @bind-Value="_model.McpServerApiKey" class="form-control" />
                                @if (_errors.TryGetValue(nameof(_model.McpServerApiKey), out var mcpKeyErr))
                                {
                                    <span class="text-danger">@mcpKeyErr</span>
                                }
                                <div class="form-text">Clients may send this as <code>Bearer key</code>, <code>ApiKey key</code>, or the raw value in the <code>Authorization</code> header.</div>
                            </div>
                        }

                        <div class="form-check form-switch">
                            <InputCheckbox id="mcpRequireAccess" @bind-Value="_model.McpServerRequireAccessPermission" class="form-check-input" />
                            <label for="mcpRequireAccess" class="form-check-label">Require administrator access for OpenId mode</label>
                        </div>
                    </div>
                </div>

                @* ── Claude ── *@
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-chat-square-dots me-1"></i> Claude</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            Configure direct Claude access for the Claude orchestrator. No external executable or separate Anthropic installation is required.
                        </p>

                        <div class="mb-3">
                            <label for="claudeAuth" class="form-label">Authentication type</label>
                            <select id="claudeAuth" class="form-select" value="@_model.AnthropicAuthenticationType" @onchange="OnAnthropicAuthTypeChanged">
                                <option value="@ClaudeAuthenticationType.NotConfigured">Not configured</option>
                                <option value="@ClaudeAuthenticationType.ApiKey">API key</option>
                            </select>
                            <div class="form-text">Choose how the Claude orchestrator authenticates. "Not configured" keeps Claude disabled until you explicitly enable API key authentication.</div>
                        </div>

                        @if (_model.AnthropicAuthenticationType == ClaudeAuthenticationType.ApiKey)
                        {
                            <div class="mb-3">
                                <label for="claudeBaseUrl" class="form-label">Base URL</label>
                                <InputText id="claudeBaseUrl" @bind-Value="_model.AnthropicBaseUrl" class="form-control" placeholder="https://api.anthropic.com" />
                                <div class="form-text">Use the standard Anthropic API base URL unless you have a custom gateway.</div>
                            </div>

                            <div class="mb-3">
                                <label for="claudeApiKey" class="form-label">API key</label>
                                <InputText id="claudeApiKey" @bind-Value="_model.AnthropicApiKey" type="password" class="form-control" placeholder="Enter API key" />
                                @if (_errors.TryGetValue(nameof(_model.AnthropicApiKey), out var claudeKeyErr))
                                {
                                    <span class="text-danger">@claudeKeyErr</span>
                                }
                                @if (_model.AnthropicHasApiKey)
                                {
                                    <div class="form-text text-success">A Claude API key has been securely stored. Enter a new value to replace it, or leave empty to keep the existing key.</div>
                                }
                                else
                                {
                                    <div class="form-text">The Claude API key used for live model discovery and Claude-orchestrated chats.</div>
                                }
                            </div>

                            @if (_model.AnthropicAvailableModels.Any())
                            {
                                <div class="mb-3">
                                    <label for="claudeModel" class="form-label">Default model</label>
                                    <select id="claudeModel" class="form-select" @bind="_model.AnthropicDefaultModel">
                                        <option value="">Use per-item override</option>
                                        @foreach (var m in _model.AnthropicAvailableModels)
                                        {
                                            <option value="@m.Key">@m.Value</option>
                                        }
                                    </select>
                                    <div class="form-text">Available models are loaded from the Anthropic Models API using the configured API key.</div>
                                </div>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <label for="claudeModel" class="form-label">Default model</label>
                                    <InputText id="claudeModel" @bind-Value="_model.AnthropicDefaultModel" class="form-control" placeholder="claude-sonnet-4-6" />
                                    <div class="form-text">Optionally set the Claude model ID used when a profile or interaction does not override it.</div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Save Settings
                    </button>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    private const string CopilotProtectorPurpose = "CrestApps.Core.Blazor.Web.CopilotSettings";
    private const string AnthropicProtectorPurpose = "CrestApps.Core.Blazor.Web.ClaudeSettings";

    private SettingsViewModel _model;
    private string _successMessage;
    private Dictionary<string, string> _errors = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        var settings = SiteSettings.Get<GeneralAISettings>();
        var chatInteractionSettings = SiteSettings.Get<ChatInteractionSettings>();
        var defaultOrchestratorSettings = SiteSettings.Get<DefaultOrchestratorSettings>();
        var deploymentDefaults = SiteSettings.Get<DefaultAIDeploymentSettings>();
        var memorySettings = SiteSettings.Get<AIMemorySettings>();
        var documentSettings = SiteSettings.Get<InteractionDocumentSettings>();
        var dataSourceSettings = SiteSettings.Get<AIDataSourceSettings>();
        var mcpServerSettings = SiteSettings.Get<McpServerOptions>();
        var chatInteractionMemorySettings = SiteSettings.Get<MemoryMetadata>();
        var copilotSettings = SiteSettings.Get<CopilotSettings>();
        var anthropicSettings = SiteSettings.Get<ClaudeSettings>();
        var paginationSettings = SiteSettings.Get<PaginationSettings>();
        var adminWidgetSettings = SiteSettings.Get<AIChatAdminWidgetSettings>();

        _model = new SettingsViewModel
        {
            EnableAIUsageTracking = settings.EnableAIUsageTracking,
            EnablePreemptiveMemoryRetrieval = settings.EnablePreemptiveMemoryRetrieval,
            MaximumIterationsPerRequest = settings.MaximumIterationsPerRequest,
            EnableDistributedCaching = settings.EnableDistributedCaching,
            EnableOpenTelemetry = settings.EnableOpenTelemetry,
            ChatInteractionChatMode = chatInteractionSettings.ChatMode,
            ChatInteractionEnableTextToSpeechPlayback = chatInteractionSettings.EnableTextToSpeechPlayback,
            DefaultOrchestratorEnablePreemptiveRag = defaultOrchestratorSettings.EnablePreemptiveRag,
            MemoryIndexProfileName = memorySettings.IndexProfileName,
            MemoryTopN = memorySettings.TopN,
            EnableUserMemoryByDefault = chatInteractionMemorySettings.EnableUserMemory ?? true,

            DefaultChatDeploymentName = deploymentDefaults.DefaultChatDeploymentName,
            DefaultUtilityDeploymentName = deploymentDefaults.DefaultUtilityDeploymentName,
            DefaultEmbeddingDeploymentName = deploymentDefaults.DefaultEmbeddingDeploymentName,
            DefaultImageDeploymentName = deploymentDefaults.DefaultImageDeploymentName,
            DefaultSpeechToTextDeploymentName = deploymentDefaults.DefaultSpeechToTextDeploymentName,
            DefaultTextToSpeechDeploymentName = deploymentDefaults.DefaultTextToSpeechDeploymentName,
            DefaultTextToSpeechVoiceId = deploymentDefaults.DefaultTextToSpeechVoiceId,

            DocumentIndexProfileName = documentSettings.IndexProfileName,
            DocumentTopN = documentSettings.TopN,
            DocumentRetrievalMode = documentSettings.RetrievalMode,
            DataSourceDefaultStrictness = dataSourceSettings.DefaultStrictness,
            DataSourceDefaultTopNDocuments = dataSourceSettings.DefaultTopNDocuments,
            McpServerAuthenticationType = mcpServerSettings.AuthenticationType,
            McpServerApiKey = mcpServerSettings.ApiKey,
            McpServerRequireAccessPermission = mcpServerSettings.RequireAccessPermission,

            CopilotAuthenticationType = copilotSettings.AuthenticationType,
            CopilotClientId = copilotSettings.ClientId,
            CopilotHasSecret = !string.IsNullOrWhiteSpace(copilotSettings.ProtectedClientSecret),
            CopilotProviderType = copilotSettings.ProviderType,
            CopilotBaseUrl = copilotSettings.BaseUrl,
            CopilotHasApiKey = !string.IsNullOrWhiteSpace(copilotSettings.ProtectedApiKey),
            CopilotWireApi = copilotSettings.WireApi ?? "completions",
            CopilotDefaultModel = copilotSettings.DefaultModel,
            CopilotAzureApiVersion = copilotSettings.AzureApiVersion,

            AnthropicAuthenticationType = anthropicSettings.AuthenticationType,
            AnthropicBaseUrl = anthropicSettings.BaseUrl,
            AnthropicHasApiKey = !string.IsNullOrWhiteSpace(anthropicSettings.ProtectedApiKey),
            AnthropicDefaultModel = anthropicSettings.DefaultModel,

            AdminPageSize = paginationSettings.AdminPageSize,
            AdminWidgetProfileId = adminWidgetSettings.ProfileId,
            AdminWidgetPrimaryColor = string.IsNullOrWhiteSpace(adminWidgetSettings.PrimaryColor)
                ? AIChatAdminWidgetSettings.DefaultSecondaryColor
                : adminWidgetSettings.PrimaryColor,
        };

        await PopulateDropdownsAsync();
    }

    private async Task PopulateDropdownsAsync()
    {
        _model.ChatDeployments = await BuildDeploymentItemsAsync(AIDeploymentType.Chat);
        _model.UtilityDeployments = await BuildDeploymentItemsAsync(AIDeploymentType.Utility);
        _model.EmbeddingDeployments = await BuildDeploymentItemsAsync(AIDeploymentType.Embedding);
        _model.ImageDeployments = await BuildDeploymentItemsAsync(AIDeploymentType.Image);
        _model.SpeechToTextDeployments = await BuildDeploymentItemsAsync(AIDeploymentType.SpeechToText);
        _model.TextToSpeechDeployments = await BuildDeploymentItemsAsync(AIDeploymentType.TextToSpeech);

        _model.ChatInteractionModes =
        [
            new(nameof(ChatMode.TextInput), "Text input"),
            new(nameof(ChatMode.AudioInput), "Audio input"),
            new(nameof(ChatMode.Conversation), "Conversation"),
        ];

        _model.DocumentIndexProfiles = (await IndexProfileStore.GetByTypeAsync(IndexProfileTypes.AIDocuments))
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .Select(p => new KeyValuePair<string, string>(p.Name, p.DisplayText ?? p.Name))
            .ToList();

        _model.MemoryIndexProfiles = (await IndexProfileStore.GetByTypeAsync(IndexProfileTypes.AIMemory))
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .Select(p => new KeyValuePair<string, string>(p.Name, p.DisplayText ?? p.Name))
            .ToList();

        _model.AdminWidgetProfiles = (await ProfileManager.GetAsync(AIProfileType.Chat))
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .Select(p => new KeyValuePair<string, string>(p.ItemId, p.DisplayText ?? p.Name))
            .ToList();

        await PopulateClaudeModelsAsync();
    }

    private void OnCopilotAuthTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<CopilotAuthenticationType>(e.Value?.ToString(), out var value))
        {
            _model.CopilotAuthenticationType = value;
        }
    }

    private void OnCopilotProviderTypeChanged(ChangeEventArgs e)
    {
        _model.CopilotProviderType = e.Value?.ToString();
    }

    private void OnMcpAuthTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<McpServerAuthenticationType>(e.Value?.ToString(), out var value))
        {
            _model.McpServerAuthenticationType = value;
        }
    }

    private void OnAnthropicAuthTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ClaudeAuthenticationType>(e.Value?.ToString(), out var value))
        {
            _model.AnthropicAuthenticationType = value;
        }
    }

    private async Task PopulateClaudeModelsAsync()
    {
        var claudeSettings = SiteSettings.Get<ClaudeSettings>();

        if (claudeSettings == null || !claudeSettings.IsConfigured())
        {
            _model.AnthropicAvailableModels = ClaudeModelSelectListFactory
                .Build([], _model.AnthropicDefaultModel);

            return;
        }

        var models = await ClaudeClientService.ListModelsAsync();
        _model.AnthropicAvailableModels = ClaudeModelSelectListFactory
            .Build(models, _model.AnthropicDefaultModel, claudeSettings.DefaultModel);
    }

    private async Task<List<KeyValuePair<string, string>>> BuildDeploymentItemsAsync(AIDeploymentType type)
    {
        var deployments = await DeploymentManager.GetByTypeAsync(type);

        return deployments
            .OrderBy(d => d.ConnectionName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(d => d.Name, StringComparer.OrdinalIgnoreCase)
            .Select(d =>
            {
                var label = string.Equals(d.Name, d.ModelName, StringComparison.OrdinalIgnoreCase)
                    ? d.Name
                    : $"{d.Name} ({d.ModelName})";

                return new KeyValuePair<string, string>(d.Name, label);
            })
            .ToList();
    }

    private async Task HandleSaveAsync()
    {
        _errors.Clear();

        if (_model.MaximumIterationsPerRequest < 1)
        {
            _errors[nameof(_model.MaximumIterationsPerRequest)] = "Must be at least 1.";
        }

        if (_model.DocumentTopN < 1)
        {
            _errors[nameof(_model.DocumentTopN)] = "Must be at least 1.";
        }

        if (_model.MemoryTopN < 1 || _model.MemoryTopN > 20)
        {
            _errors[nameof(_model.MemoryTopN)] = "Must be between 1 and 20.";
        }

        if (_model.DataSourceDefaultStrictness < AIDataSourceSettings.MinStrictness ||
            _model.DataSourceDefaultStrictness > AIDataSourceSettings.MaxStrictness)
        {
            _errors[nameof(_model.DataSourceDefaultStrictness)] = $"Must be between {AIDataSourceSettings.MinStrictness} and {AIDataSourceSettings.MaxStrictness}.";
        }

        if (_model.DataSourceDefaultTopNDocuments < AIDataSourceSettings.MinTopNDocuments ||
            _model.DataSourceDefaultTopNDocuments > AIDataSourceSettings.MaxTopNDocuments)
        {
            _errors[nameof(_model.DataSourceDefaultTopNDocuments)] = $"Must be between {AIDataSourceSettings.MinTopNDocuments} and {AIDataSourceSettings.MaxTopNDocuments}.";
        }

        if (_model.McpServerAuthenticationType == McpServerAuthenticationType.ApiKey &&
            string.IsNullOrWhiteSpace(_model.McpServerApiKey))
        {
            _errors[nameof(_model.McpServerApiKey)] = "API key is required when the MCP server uses API key authentication.";
        }

        var existingAnthropic = SiteSettings.Get<ClaudeSettings>();

        if (_model.AnthropicAuthenticationType == ClaudeAuthenticationType.ApiKey &&
            string.IsNullOrWhiteSpace(_model.AnthropicApiKey) &&
            string.IsNullOrWhiteSpace(existingAnthropic.ProtectedApiKey))
        {
            _errors[nameof(_model.AnthropicApiKey)] = "API key is required when Claude uses API key authentication.";
        }

        if (_model.AdminPageSize < 1 || _model.AdminPageSize > 200)
        {
            _errors[nameof(_model.AdminPageSize)] = "Page size must be between 1 and 200.";
        }

        if (!string.IsNullOrWhiteSpace(_model.AdminWidgetPrimaryColor) &&
            !Regex.IsMatch(
                _model.AdminWidgetPrimaryColor,
                "^#(?:[0-9a-fA-F]{3}){1,2}$",
                RegexOptions.CultureInvariant,
                TimeSpan.FromMilliseconds(100)))
        {
            _errors[nameof(_model.AdminWidgetPrimaryColor)] = "Color must be a valid hex value such as #6c757d.";
        }

        if (!string.IsNullOrWhiteSpace(_model.AdminWidgetProfileId))
        {
            var profile = await ProfileManager.FindByIdAsync(_model.AdminWidgetProfileId);

            if (profile is null || profile.Type != AIProfileType.Chat)
            {
                _errors[nameof(_model.AdminWidgetProfileId)] = "Invalid admin widget profile.";
            }
        }

        if (!string.IsNullOrWhiteSpace(_model.MemoryIndexProfileName))
        {
            var indexProfile = await IndexProfileStore.FindByNameAsync(_model.MemoryIndexProfileName);

            if (indexProfile is null || !string.Equals(indexProfile.Type, IndexProfileTypes.AIMemory, StringComparison.OrdinalIgnoreCase))
            {
                _errors[nameof(_model.MemoryIndexProfileName)] = "Invalid memory index profile.";
            }
        }

        if (_errors.Count > 0)
        {
            await PopulateDropdownsAsync();

            return;
        }

        // Save general AI settings.
        SiteSettings.Set<GeneralAISettings>(s =>
        {
            s.EnablePreemptiveMemoryRetrieval = _model.EnablePreemptiveMemoryRetrieval;
            s.EnableAIUsageTracking = _model.EnableAIUsageTracking;
            s.MaximumIterationsPerRequest = _model.MaximumIterationsPerRequest;
            s.EnableDistributedCaching = _model.EnableDistributedCaching;
            s.EnableOpenTelemetry = _model.EnableOpenTelemetry;
        });

        SiteSettings.Set<ChatInteractionSettings>(s =>
        {
            s.ChatMode = _model.ChatInteractionChatMode;
            s.EnableTextToSpeechPlayback = _model.ChatInteractionEnableTextToSpeechPlayback;
        });

        SiteSettings.Set(new DefaultOrchestratorSettings
        {
            EnablePreemptiveRag = _model.DefaultOrchestratorEnablePreemptiveRag,
        });

        SiteSettings.Set(new DefaultAIDeploymentSettings
        {
            DefaultChatDeploymentName = _model.DefaultChatDeploymentName,
            DefaultUtilityDeploymentName = _model.DefaultUtilityDeploymentName,
            DefaultEmbeddingDeploymentName = _model.DefaultEmbeddingDeploymentName,
            DefaultImageDeploymentName = _model.DefaultImageDeploymentName,
            DefaultSpeechToTextDeploymentName = _model.DefaultSpeechToTextDeploymentName,
            DefaultTextToSpeechDeploymentName = _model.DefaultTextToSpeechDeploymentName,
            DefaultTextToSpeechVoiceId = _model.DefaultTextToSpeechVoiceId?.Trim(),
        });

        SiteSettings.Set(new AIMemorySettings
        {
            IndexProfileName = string.IsNullOrWhiteSpace(_model.MemoryIndexProfileName)
                ? null
                : _model.MemoryIndexProfileName.Trim(),
            TopN = _model.MemoryTopN,
        });

        SiteSettings.Set(new InteractionDocumentSettings
        {
            IndexProfileName = _model.DocumentIndexProfileName?.Trim(),
            TopN = _model.DocumentTopN,
            RetrievalMode = _model.DocumentRetrievalMode,
        });

        SiteSettings.Set(new AIDataSourceSettings
        {
            DefaultStrictness = _model.DataSourceDefaultStrictness,
            DefaultTopNDocuments = _model.DataSourceDefaultTopNDocuments,
        });

        SiteSettings.Set(new McpServerOptions
        {
            AuthenticationType = _model.McpServerAuthenticationType,
            ApiKey = _model.McpServerApiKey?.Trim(),
            RequireAccessPermission = _model.McpServerRequireAccessPermission,
        });

        SiteSettings.Set(new MemoryMetadata
        {
            EnableUserMemory = _model.EnableUserMemoryByDefault,
        });

        // Save Copilot settings, preserving existing protected secrets.
        var existingCopilot = SiteSettings.Get<CopilotSettings>();
        var protector = DataProtectionProvider.CreateProtector(CopilotProtectorPurpose);

        var copilotSettings = new CopilotSettings
        {
            AuthenticationType = _model.CopilotAuthenticationType,
            ClientId = _model.CopilotClientId?.Trim(),
            ProtectedClientSecret = existingCopilot.ProtectedClientSecret,
            ProviderType = _model.CopilotProviderType,
            BaseUrl = _model.CopilotBaseUrl?.Trim(),
            ProtectedApiKey = existingCopilot.ProtectedApiKey,
            WireApi = _model.CopilotWireApi,
            DefaultModel = _model.CopilotDefaultModel?.Trim(),
            AzureApiVersion = _model.CopilotAzureApiVersion?.Trim(),
        };

        if (!string.IsNullOrWhiteSpace(_model.CopilotClientSecret))
        {
            copilotSettings.ProtectedClientSecret = protector.Protect(_model.CopilotClientSecret.Trim());
        }

        if (!string.IsNullOrWhiteSpace(_model.CopilotApiKey))
        {
            copilotSettings.ProtectedApiKey = protector.Protect(_model.CopilotApiKey.Trim());
        }

        SiteSettings.Set(copilotSettings);

        var anthropicProtector = DataProtectionProvider.CreateProtector(AnthropicProtectorPurpose);
        var anthropicSettings = new ClaudeSettings
        {
            AuthenticationType = _model.AnthropicAuthenticationType,
            BaseUrl = string.IsNullOrWhiteSpace(_model.AnthropicBaseUrl)
                ? "https://api.anthropic.com"
                : _model.AnthropicBaseUrl.Trim(),
            ProtectedApiKey = existingAnthropic.ProtectedApiKey,
            DefaultModel = _model.AnthropicDefaultModel?.Trim(),
        };

        if (!string.IsNullOrWhiteSpace(_model.AnthropicApiKey))
        {
            anthropicSettings.ProtectedApiKey = anthropicProtector.Protect(_model.AnthropicApiKey.Trim());
        }

        SiteSettings.Set(anthropicSettings);

        SiteSettings.Set(new PaginationSettings
        {
            AdminPageSize = _model.AdminPageSize,
        });

        SiteSettings.Set(new AIChatAdminWidgetSettings
        {
            ProfileId = string.IsNullOrWhiteSpace(_model.AdminWidgetProfileId) ? null : _model.AdminWidgetProfileId.Trim(),
            PrimaryColor = string.IsNullOrWhiteSpace(_model.AdminWidgetPrimaryColor)
                ? AIChatAdminWidgetSettings.DefaultSecondaryColor
                : _model.AdminWidgetPrimaryColor.Trim(),
        });

        await SiteSettings.SaveChangesAsync();

        _successMessage = "Settings saved successfully.";
    }
}
