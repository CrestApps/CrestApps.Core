@page "/AI/Profiles"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Profiles
@inject IAIProfileManager ProfileManager
@inject NavigationManager NavigationManager

<PageTitle>AI Profiles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-gear"></i> AI Profiles</h2>
    <a href="/AI/Profiles/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Profile
    </a>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Profiles is null)
{
    <p><em>Loading...</em></p>
}
else if (!Profiles.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI profiles found. Create your first profile to get started.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Type</th>
                    <th style="width: 260px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var profile in Profiles)
                {
                    <tr>
                        <td><strong>@(profile.DisplayText ?? profile.Name)</strong></td>
                        <td>@profile.Name</td>
                        <td>
                            <span class="badge @GetTypeBadgeClass(profile.Type)">
                                @profile.Type
                            </span>
                        </td>
                        <td>
                            <a href="/AI/Profiles/Edit/@profile.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(profile.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this profile?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private IReadOnlyCollection<AIProfile>? Profiles;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    protected override async Task OnInitializedAsync()
    {
        Profiles = (await ProfileManager.GetAllAsync()).ToList();
    }

    private static string GetTypeBadgeClass(AIProfileType type) => type switch
    {
        AIProfileType.Chat => "bg-primary",
        AIProfileType.Agent => "bg-success",
        AIProfileType.Utility => "bg-warning text-dark",
        AIProfileType.TemplatePrompt => "bg-info text-dark",
        _ => "bg-secondary"
    };

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            var profile = await ProfileManager.FindByIdAsync(DeleteTargetId);
            if (profile != null)
            {
                await ProfileManager.DeleteAsync(profile);
            }
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        SuccessMessage = "Profile deleted successfully.";
        Profiles = (await ProfileManager.GetAllAsync()).ToList();
    }
}
