@page "/AI/Deployments"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Deployments
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Services
@inject IAIDeploymentStore DeploymentCatalog
@inject NavigationManager NavigationManager

<PageTitle>AI Deployments</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-box-seam"></i> AI Deployments</h2>
    <a href="/AI/Deployments/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Deployment
    </a>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Deployments is null)
{
    <p><em>Loading...</em></p>
}
else if (!Deployments.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No deployments found. Create a deployment to map models to connections.
    </div>
}
else
{
    var userDefined = Deployments.Where(d => !AIConfigurationRecordIds.IsConfigurationDeploymentId(d.ItemId)).ToList();
    var configured = Deployments.Where(d => AIConfigurationRecordIds.IsConfigurationDeploymentId(d.ItemId)).ToList();

    @if (userDefined.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">User-defined deployments</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Technical name</th>
                                <th>Model name</th>
                                <th>Type</th>
                                <th>Provider</th>
                                <th>Connection</th>
                                <th style="width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deployment in userDefined)
                            {
                                <tr>
                                    <td><strong>@deployment.Name</strong></td>
                                    <td>@(string.IsNullOrWhiteSpace(deployment.ModelName) ? "—" : deployment.ModelName)</td>
                                    <td>
                                        @foreach (var type in deployment.Type.GetSupportedTypes())
                                        {
                                            <span class="badge bg-secondary me-1">@type</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@(AIProviderNameNormalizer.Normalize(deployment.ClientName) ?? "—")</span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(deployment.ConnectionName) ? "Standalone" : deployment.ConnectionName)</td>
                                    <td>
                                        <a href="/AI/Deployments/Edit/@deployment.ItemId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(deployment.ItemId)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (configured.Count > 0)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">System configuration deployments</h5>
                <span class="badge bg-secondary">Read-only</span>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">These deployments come from system configuration and cannot be edited or deleted from the UI.</p>
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Technical name</th>
                                <th>Model name</th>
                                <th>Type</th>
                                <th>Provider</th>
                                <th>Connection</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deployment in configured)
                            {
                                <tr>
                                    <td><strong>@deployment.Name</strong></td>
                                    <td>@(string.IsNullOrWhiteSpace(deployment.ModelName) ? "—" : deployment.ModelName)</td>
                                    <td>
                                        @foreach (var type in deployment.Type.GetSupportedTypes())
                                        {
                                            <span class="badge bg-secondary me-1">@type</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@(AIProviderNameNormalizer.Normalize(deployment.ClientName) ?? "—")</span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(deployment.ConnectionName) ? "Standalone" : deployment.ConnectionName)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this deployment?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyCollection<AIDeployment>? Deployments;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessQueryParam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SuccessQueryParam))
        {
            SuccessMessage = SuccessQueryParam;
        }

        await LoadDeploymentsAsync();
    }

    private async Task LoadDeploymentsAsync()
    {
        var all = await DeploymentCatalog.GetAllAsync();
        Deployments = all
            .OrderBy(d => d.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            if (AIConfigurationRecordIds.IsConfigurationDeploymentId(DeleteTargetId))
            {
                ErrorMessage = "Deployments defined in appsettings are read-only and cannot be deleted from the UI.";
            }
            else
            {
                var deployment = await DeploymentCatalog.FindByIdAsync(DeleteTargetId);
                if (deployment != null)
                {
                    await DeploymentCatalog.DeleteAsync(deployment);
                    SuccessMessage = "Deployment deleted successfully.";
                }
            }
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        await LoadDeploymentsAsync();
    }
}
