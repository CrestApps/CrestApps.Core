@page "/ai/profiles/create"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI
@using CrestApps.Core.AI.A2A.Models
@using CrestApps.Core.AI.Claude.Models
@using CrestApps.Core.AI.Claude.Services
@using CrestApps.Core.AI.Copilot.Models
@using CrestApps.Core.AI.Copilot.Services
@using CrestApps.Core.AI.DataSources
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Orchestration
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.AI.Services
@using CrestApps.Core.AI.Speech
@using CrestApps.Core.AI.Tooling
@using CrestApps.Core.Blazor.Web.Areas.AI.Services
@using CrestApps.Core.Blazor.Web.Services
@using CrestApps.Core.Blazor.Web.Areas.AIChat.Services
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Services
@using CrestApps.Core.Templates.Services
@using Microsoft.Extensions.Options
@inject IAIProfileManager ProfileManager
@inject IAIProfileTemplateManager TemplateManager
@inject ICatalog<AIDeployment> DeploymentCatalog
@inject ICatalog<A2AConnection> A2ACatalog
@inject ICatalog<McpConnection> McpCatalog
@inject IAIDataSourceStore DataSourceStore
@inject ISearchIndexProfileStore IndexProfileStore
@inject ITemplateService TemplateService
@inject IOptions<OrchestratorOptions> OrchestratorOpts
@inject IOptionsSnapshot<ClaudeOptions> ClaudeOpts
@inject ClaudeClientService ClaudeClientService
@inject IOptions<CopilotOptions> CopilotOpts
@inject IOptions<AIToolDefinitionOptions> ToolOpts
@inject IOptions<InteractionDocumentOptions> DocOpts
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions
@inject ISpeechVoiceResolver SpeechVoiceResolver
@inject AIProfileDocumentService ProfileDocumentService
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SiteSettingsStore SiteSettingsStore

<PageTitle>Create AI Profile - Blazor AI Integration Sample</PageTitle>
<link rel="stylesheet" href="/_content/CrestApps.AI.Resources/styles/document-drop-zone.css" />

<h2><i class="bi bi-plus-lg"></i> Create AI Profile</h2>
<hr />

<EditForm FormName="ai-aiprofiles-create" Model="_model" OnValidSubmit="HandleSubmitAsync">
    @if (_model.AvailableProfileTemplates.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">Apply Template</h5>
            </div>
            <div class="card-body">
                <div class="d-flex gap-2 align-items-start">
                    <div class="flex-grow-1">
                        <InputSelect class="form-select" @bind-Value="_selectedApplyTemplateId">
                            <option value="">Select a template</option>
                            @foreach (var tpl in _model.AvailableProfileTemplates)
                            {
                                <option value="@tpl.Value">@tpl.Key</option>
                            }
                        </InputSelect>
                        <div class="form-text">Select a profile template to pre-fill the form fields.</div>
                    </div>
                    <button type="button" class="btn btn-secondary" disabled="@string.IsNullOrEmpty(_selectedApplyTemplateId)" @onclick="ApplyTemplateAsync">
                        <i class="bi bi-clipboard-check"></i> Apply
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            <!-- Tab Navigation -->
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "basic" ? "active" : "")" @onclick='() => _activeTab = "basic"'>Basic Info</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "params" ? "active" : "")" @onclick='() => _activeTab = "params"'>AI Parameters</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "capabilities" ? "active" : "")" @onclick='() => _activeTab = "capabilities"'>Capabilities</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "knowledge" ? "active" : "")" @onclick='() => _activeTab = "knowledge"'>Knowledge</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "processing" ? "active" : "")" @onclick='() => _activeTab = "processing"'>Data Processing &amp; Metrics</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "settings" ? "active" : "")" @onclick='() => _activeTab = "settings"'>Settings</button>
                </li>
            </ul>

            <div class="p-3 border border-top-0 rounded-bottom">

                <!-- Basic Info Tab -->
                <div style="display: @(_activeTab == "basic" ? "block" : "none")">
                    <div class="mb-3">
                        <label for="profileTitle" class="form-label">Title <span class="text-danger">*</span></label>
                        <input id="profileTitle" class="form-control" value="@_model.DisplayText" @oninput="e => _model.DisplayText = e.Value?.ToString()" placeholder="e.g., My Chat Assistant" />
                    </div>

                    <div class="mb-3">
                        <label for="profileName" class="form-label">Technical name <span class="text-danger">*</span></label>
                        <InputText id="profileName" class="form-control" @bind-Value="_model.Name" placeholder="e.g., my-chat-assistant" />
                        @if (!string.IsNullOrEmpty(_nameError))
                        {
                            <div class="text-danger">@_nameError</div>
                        }
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Profile type</label>
                                <select class="form-select" value="@_model.Type" @onchange="OnProfileTypeChanged">
                                    @foreach (var profileType in Enum.GetValues<AIProfileType>())
                                    {
                                        <option value="@profileType">@profileType</option>
                                    }
                                </select>
                                <div class="form-text">Choose the type of the profile.</div>
                            </div>
                        </div>
                        @if (_model.Type == AIProfileType.Chat)
                        {
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Title type</label>
                                    <InputSelect class="form-select" @bind-Value="_model.TitleType">
                                        <option value="">Default</option>
                                        @foreach (var tt in Enum.GetValues<AISessionTitleType>())
                                        {
                                            <option value="@tt">@tt</option>
                                        }
                                    </InputSelect>
                                    <div class="form-text">How the chat session title is determined.</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Chat mode</label>
                                    <InputSelect class="form-select" @bind-Value="_model.ChatMode">
                                        <option value="@ChatMode.TextInput">Text input</option>
                                        <option value="@ChatMode.AudioInput">Audio input</option>
                                        <option value="@ChatMode.Conversation">Conversation</option>
                                    </InputSelect>
                                    <div class="form-text">Choose text input, microphone dictation, or full conversation mode.</div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (_model.Type == AIProfileType.Chat)
                    {
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnableTextToSpeechPlayback" />
                                <label class="form-check-label">Enable text-to-speech playback</label>
                            </div>
                            <div class="form-text">Show a play button on assistant messages when a text-to-speech deployment is configured.</div>
                        </div>

                        @if (_model.ChatMode == ChatMode.Conversation)
                        {
                            <div class="mb-3">
                                <label class="form-label">Voice</label>
                                <InputSelect class="form-select" @bind-Value="_model.VoiceName">
                                    <option value="">Default voice</option>
                                    @foreach (var group in _availableVoices.GroupBy(GetVoiceGroupLabel).OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <optgroup label="@group.Key">
                                            @foreach (var voice in group.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase))
                                            {
                                                <option value="@voice.Id">@voice.Name</option>
                                            }
                                        </optgroup>
                                    }
                                </InputSelect>
                                <div class="form-text">Leave empty to use the site's default text-to-speech voice.</div>
                            </div>
                        }
                    }

                    @if (_model.Type == AIProfileType.Agent)
                    {
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="_model.Description" placeholder="Describe what this agent does so the orchestrator can decide when to invoke it." />
                            <div class="form-text">A description of what this agent does. Used by the orchestrator to determine when to route requests to this agent.</div>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Chat deployment</label>
                                <InputSelect class="form-select" @bind-Value="_model.ChatDeploymentName">
                                    <option value="">Use default chat deployment</option>
                                    @foreach (var d in _model.ChatDeployments)
                                    {
                                        <option value="@d.Value">@d.Key</option>
                                    }
                                </InputSelect>
                                <div class="form-text">The chat model deployment to use.</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Utility deployment</label>
                                <InputSelect class="form-select" @bind-Value="_model.UtilityDeploymentName">
                                    <option value="">Use default utility deployment</option>
                                    @foreach (var d in _model.UtilityDeployments)
                                    {
                                        <option value="@d.Value">@d.Key</option>
                                    }
                                </InputSelect>
                                <div class="form-text">Optional deployment for utility tasks.</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Orchestrator</label>
                                <select class="form-select" value="@_model.OrchestratorName" @onchange="OnOrchestratorChanged">
                                    <option value="">Use default orchestrator</option>
                                    @foreach (var o in _model.Orchestrators)
                                    {
                                        <option value="@o.Value">@o.Key</option>
                                    }
                                </select>
                                <div class="form-text">The orchestrator that manages AI interactions.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Copilot Config -->
                    @if (!string.IsNullOrEmpty(_model.OrchestratorName) &&
                         string.Equals(_model.OrchestratorName, CopilotOrchestrator.OrchestratorName, StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="card mb-3">
                            <div class="card-header">
                                <h6 class="card-title mb-0"><i class="bi bi-github me-1"></i> Copilot Configuration</h6>
                            </div>
                            <div class="card-body">
                                @if (!_model.CopilotIsConfigured)
                                {
                                    <div class="alert alert-warning mb-0">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                        <strong>Copilot is not configured.</strong> Go to <a href="/admin/settings"><strong>Settings</strong></a> and complete the Copilot section first.
                                    </div>
                                }
                                else if (_model.CopilotAuthenticationType == (int)CopilotAuthenticationType.ApiKey)
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Model override</label>
                                        <InputText class="form-control" @bind-Value="_model.CopilotModel" placeholder="Leave empty to use the default model from settings" />
                                        <div class="form-text">Optionally override the model name.</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Effort level</label>
                                        <InputSelect class="form-select" @bind-Value="_model.CopilotReasoningEffort">
                                            @foreach (var e in Enum.GetValues<CopilotReasoningEffort>())
                                            {
                                                <option value="@e">@(e == CopilotReasoningEffort.None ? "Default" : e.ToString())</option>
                                            }
                                        </InputSelect>
                                        <div class="form-text">Select the reasoning effort level.</div>
                                    </div>
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="_model.CopilotIsAllowAll" />
                                        <label class="form-check-label">Allow all tool executions</label>
                                    </div>
                                    <div class="form-text">When checked, the Copilot CLI runs with the --allow-all flag.</div>
                                }
                                else if (_model.CopilotAuthenticationType == (int)CopilotAuthenticationType.GitHubOAuth)
                                {
                                    @if (_model.CopilotIsAuthenticated)
                                    {
                                        <div class="alert alert-success py-2 mb-3">
                                            <i class="bi bi-check-circle-fill"></i> Connected as <strong>@_model.CopilotGitHubUsername</strong>
                                        </div>
                                        <div class="alert alert-warning py-2 mb-3">
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                            Using the Copilot orchestrator will allow any user chatting with this profile to utilize your GitHub credentials.
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Copilot model</label>
                                            <InputSelect class="form-select" @bind-Value="_model.CopilotModel">
                                                @foreach (var m in _model.CopilotAvailableModels)
                                                {
                                                    <option value="@m.Value">@m.Key</option>
                                                }
                                            </InputSelect>
                                            <div class="form-text">Select the Copilot model to use.</div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Effort level</label>
                                            <InputSelect class="form-select" @bind-Value="_model.CopilotReasoningEffort">
                                                @foreach (var e in Enum.GetValues<CopilotReasoningEffort>())
                                                {
                                                    <option value="@e">@(e == CopilotReasoningEffort.None ? "Default" : e.ToString())</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="form-check">
                                            <InputCheckbox class="form-check-input" @bind-Value="_model.CopilotIsAllowAll" />
                                            <label class="form-check-label">Allow all tool executions</label>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-3">
                                            <p class="text-muted"><i class="bi bi-github fs-1"></i></p>
                                            <p class="text-muted">Copilot requires GitHub authentication. Sign in with your GitHub account to continue.</p>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }

                    <!-- Claude Config -->
                    @if (!string.IsNullOrEmpty(_model.OrchestratorName) &&
                         string.Equals(_model.OrchestratorName, ClaudeOrchestrator.OrchestratorName, StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="card mb-3">
                            <div class="card-header">
                                <h6 class="card-title mb-0"><i class="bi bi-lightning me-1"></i> Claude Configuration</h6>
                            </div>
                            <div class="card-body">
                                @if (!_model.ClaudeIsConfigured)
                                {
                                    <div class="alert alert-warning mb-0">
                                        <strong>Claude is not configured.</strong> Go to <a href="/admin/settings"><strong>Settings</strong></a> and complete the Claude section first.
                                    </div>
                                }
                                else if (_model.AnthropicAvailableModels.Count > 0)
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Claude model</label>
                                        <InputSelect class="form-select" @bind-Value="_model.ClaudeModel">
                                            <option value="">Use default model</option>
                                            @foreach (var m in _model.AnthropicAvailableModels)
                                            {
                                                <option value="@m.Value">@m.Key</option>
                                            }
                                        </InputSelect>
                                        <div class="form-text">Select a Claude model override, or leave on the configured default.</div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="form-label">Effort level</label>
                                        <InputSelect class="form-select" @bind-Value="_model.ClaudeEffortLevel">
                                            @foreach (var e in Enum.GetValues<ClaudeEffortLevel>())
                                            {
                                                <option value="@e">@(e == ClaudeEffortLevel.None ? "Default" : e.ToString())</option>
                                            }
                                        </InputSelect>
                                        <div class="form-text">Higher effort produces more thorough responses but uses more tokens.</div>
                                    </div>
                                }
                                else
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Claude model</label>
                                        <InputText class="form-control" @bind-Value="_model.ClaudeModel" placeholder="Leave empty to use the default model from settings" />
                                        <div class="form-text">Optionally override the Claude model.</div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="form-label">Effort level</label>
                                        <InputSelect class="form-select" @bind-Value="_model.ClaudeEffortLevel">
                                            @foreach (var e in Enum.GetValues<ClaudeEffortLevel>())
                                            {
                                                <option value="@e">@(e == ClaudeEffortLevel.None ? "Default" : e.ToString())</option>
                                            }
                                        </InputSelect>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (_model.Type == AIProfileType.Chat || _model.Type == AIProfileType.TemplatePrompt)
                    {
                        <div class="mb-3">
                            <label class="form-label">Prompt subject</label>
                            <InputText class="form-control" @bind-Value="_model.PromptSubject" placeholder="Optional subject context for the prompt" />
                            <div class="form-text">Provides context to the AI about the primary subject of the conversation.</div>
                        </div>
                    }

                    @if (_model.Type == AIProfileType.Chat)
                    {
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.AddInitialPrompt" />
                                <label class="form-check-label">Add initial prompt</label>
                            </div>
                            <div class="form-text">When enabled, each new chat session starts with an assistant message from the initial prompt.</div>
                        </div>

                        @if (!_model.AddInitialPrompt)
                        {
                            <div class="mb-3">
                                <label class="form-label">Welcome message</label>
                                <InputTextArea class="form-control" rows="3" @bind-Value="_model.WelcomeMessage" placeholder="Message shown when a chat starts" />
                                <div class="form-text">The welcome message to show when a new session is created.</div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Initial prompt</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="_model.InitialPrompt" placeholder="The assistant message added as the first chat history entry" />
                                <div class="form-text">This assistant message is added as the first chat history entry.</div>
                            </div>
                        }
                    }

                    @if (_model.Type == AIProfileType.TemplatePrompt)
                    {
                        <div class="mb-3">
                            <label class="form-label">Prompt template</label>
                            <InputTextArea class="form-control" rows="5" @bind-Value="_model.PromptTemplate" placeholder="Template for generating prompts" />
                            <div class="form-text">
                                Liquid syntax is supported. Available variables: <code>@("{{ User.UserName }}")</code>, <code>@("{{ User.Email }}")</code>,
                                <code>@("{{ Session.Id }}")</code>, <code>@("{{ Profile.Name }}")</code>.
                            </div>
                        </div>
                    }
                </div>

                <!-- AI Parameters Tab -->
                <div style="display: @(_activeTab == "params" ? "block" : "none")">
                        @if (_model.AvailablePromptTemplates.Count > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label">Prompt templates</label>
                                <div class="dropdown mb-2 w-100">
                                    <button class="btn btn-outline-primary dropdown-toggle w-100 d-flex justify-content-center align-items-center gap-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <span aria-hidden="true">+</span> Add template
                                    </button>
                                    <div class="dropdown-menu p-2" style="max-height:24rem;min-width:22rem;overflow-y:auto;">
                                        <div class="mb-2" @onclick:stopPropagation="true">
                                            <input type="search"
                                                   class="form-control form-control-sm"
                                                   @bind="_promptTemplateSearchTerm"
                                                   @bind:event="oninput"
                                                   placeholder="Search prompt templates..." />
                                        </div>
                                        <div class="prompt-template-menu-items">
                                            @foreach (var group in FilteredPromptTemplateGroups)
                                            {
                                                <div class="dropdown-header px-2">@group.Key</div>
                                                @foreach (var option in group)
                                                {
                                                    <button type="button"
                                                            class="dropdown-item text-wrap"
                                                            @onclick="() => AddPromptTemplate(option.TemplateId)">
                                                        <span class="d-block fw-semibold">@option.Title</span>
                                                        @if (!string.IsNullOrWhiteSpace(option.Description))
                                                        {
                                                            <small class="text-muted">@option.Description</small>
                                                        }
                                                    </button>
                                                }
                                            }
                                        </div>
                                        @if (!HasFilteredPromptTemplates)
                                        {
                                            <div class="text-muted small px-2 py-1">No prompt templates match your search.</div>
                                        }
                                    </div>
                                </div>

                            @if (_model.PromptTemplates.Count > 0)
                            {
                                @for (var i = 0; i < _model.PromptTemplates.Count; i++)
                                {
                                    var index = i;
                                    var selection = _model.PromptTemplates[index];
                                    var option = _model.AvailablePromptTemplates.FirstOrDefault(t => string.Equals(t.TemplateId, selection.TemplateId, StringComparison.OrdinalIgnoreCase));
                                    var title = option?.Title ?? selection.TemplateId ?? "Prompt template";

                                    <div class="card mb-1">
                                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                                            <span class="fw-semibold">@title</span>
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.PromptTemplates.RemoveAt(index)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        <div class="card-body">
                                            @if (option?.Parameters?.Count > 0)
                                            {
                                                <div class="mb-2">
                                                    <small class="text-muted d-block mb-1">Expected parameters:</small>
                                                    <ul class="mb-0 small text-muted">
                                                        @foreach (var p in option.Parameters)
                                                        {
                                                            <li><strong>@p.Name</strong>@(string.IsNullOrWhiteSpace(p.Description) ? "" : $": {p.Description}")</li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                            <div class="mb-1">
                                                <label class="form-label">Template parameters</label>
                                                <InputTextArea class="form-control" rows="3" @bind-Value="selection.PromptParameters" placeholder='e.g., {"key1": "value1", "key2": "value2"}' />
                                                <span class="form-text">Optional JSON key-value pairs to pass as template arguments.</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small">No prompt templates selected.</div>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">System message</label>
                        <InputTextArea class="form-control" rows="5" @bind-Value="_model.SystemMessage" placeholder="You are a helpful AI assistant..." />
                        <div class="form-text">Instructions that guide the AI's behavior throughout the conversation.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Temperature</label>
                                <InputNumber class="form-control" @bind-Value="_model.Temperature" step="0.01" min="0" max="2" placeholder="0.0 - 2.0" />
                                <div class="form-text">Controls randomness. Lower = more focused, higher = more creative.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Top P</label>
                                <InputNumber class="form-control" @bind-Value="_model.TopP" step="0.01" min="0" max="1" placeholder="0.0 - 1.0" />
                                <div class="form-text">Nucleus sampling. Controls diversity of responses.</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Frequency penalty</label>
                                <InputNumber class="form-control" @bind-Value="_model.FrequencyPenalty" step="0.01" min="-2" max="2" placeholder="-2.0 - 2.0" />
                                <div class="form-text">Penalizes repeated tokens. Higher = less repetition.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Presence penalty</label>
                                <InputNumber class="form-control" @bind-Value="_model.PresencePenalty" step="0.01" min="-2" max="2" placeholder="-2.0 - 2.0" />
                                <div class="form-text">Penalizes tokens already present. Higher = more topic variety.</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Max output tokens</label>
                                <InputNumber class="form-control" @bind-Value="_model.MaxTokens" min="1" placeholder="Leave blank for model default" />
                                <div class="form-text">Maximum number of tokens in the response.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Past messages count</label>
                                <InputNumber class="form-control" @bind-Value="_model.PastMessagesCount" min="0" placeholder="Leave blank for all" />
                                <div class="form-text">Number of previous messages to include in context.</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.UseCaching" />
                            <label class="form-check-label">Enable response caching</label>
                        </div>
                        <div class="form-text">Cache responses to improve performance for repeated queries.</div>
                    </div>
                </div>

                <!-- Capabilities Tab -->
                <div style="display: @(_activeTab == "capabilities" ? "block" : "none")">
                    <!-- AI Agents -->
                    <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-robot"></i> AI Agents</h6>
                    @if (_model.AvailableAgents.Count == 0)
                    {
                        <div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> No agent profiles are available.</div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the agent profiles this profile can delegate tasks to.</p>
                        @foreach (var agent in _model.AvailableAgents)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" checked="@agent.IsSelected" @onchange="e => ToggleAgent(agent.Name, (bool)e.Value)" id="agent_@agent.Name" />
                                <label class="form-check-label" for="agent_@agent.Name">
                                    <strong>@agent.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(agent.Description))
                                    {
                                        <br /><small class="text-muted">@agent.Description</small>
                                    }
                                </label>
                            </div>
                        }
                    }

                    <!-- A2A Connections -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h6>
                    @if (_model.AvailableA2AConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> No A2A host connections are configured.</div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the remote A2A hosts this profile can use.</p>
                        @foreach (var connection in _model.AvailableA2AConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" checked="@connection.IsSelected" @onchange="e => ToggleA2A(connection.ItemId, (bool)e.Value)" id="a2a_@connection.ItemId" />
                                <label class="form-check-label" for="a2a_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong><br />
                                    <small class="text-muted">@connection.Endpoint</small>
                                </label>
                            </div>
                        }
                    }

                    <!-- MCP Hosts -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-plug"></i> MCP Hosts</h6>
                    @if (_model.AvailableMcpConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> No MCP hosts are configured.</div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the MCP server connections this profile can use.</p>
                        @foreach (var connection in _model.AvailableMcpConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" checked="@connection.IsSelected" @onchange="e => ToggleMcp(connection.ItemId, (bool)e.Value)" id="mcp_@connection.ItemId" />
                                <label class="form-check-label" for="mcp_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(connection.Source))
                                    {
                                        <br /><small class="text-muted">@connection.Source</small>
                                    }
                                </label>
                            </div>
                        }
                    }

                    <!-- AI Tools -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-tools"></i> AI Tools</h6>
                    @if (_model.AvailableTools.Count == 0)
                    {
                        <div class="alert alert-info mb-0"><i class="bi bi-info-circle"></i> No selectable AI tools are registered.</div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <p class="text-muted mb-0 small">Select the tools this profile can use.</p>
                            <div class="btn-group btn-group-sm ms-3">
                                <button type="button" class="btn btn-outline-primary" @onclick="SelectAllTools"><i class="bi bi-check-all"></i> Select all</button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="DeselectAllTools"><i class="bi bi-x-lg"></i> Deselect all</button>
                            </div>
                        </div>
                        @foreach (var group in _model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                        {
                            <h6 class="text-secondary mt-3 mb-2"><i class="bi bi-folder"></i> @group.Key</h6>
                            @foreach (var tool in group)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" checked="@tool.IsSelected" @onchange="e => ToggleTool(tool.Name, (bool)e.Value)" id="tool_@tool.Name" />
                                    <label class="form-check-label" for="tool_@tool.Name">
                                        <strong>@tool.Title</strong>
                                        @if (!string.IsNullOrEmpty(tool.Description))
                                        {
                                            <br /><small class="text-muted">@tool.Description</small>
                                        }
                                    </label>
                                </div>
                            }
                        }
                    }
                </div>

                <!-- Knowledge Tab -->
                <div style="display: @(_activeTab == "knowledge" ? "block" : "none")">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.EnableUserMemory" />
                            <label class="form-check-label">Enable user memory</label>
                        </div>
                        <div class="form-text">Store and recall user conversation history for personalized responses.</div>
                    </div>

                    <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-database"></i> Data Source</h6>
                    <div class="mb-3">
                        <label class="form-label">Data source</label>
                        <InputSelect class="form-select" @bind-Value="_model.DataSourceId">
                            <option value="">No data source</option>
                            @foreach (var ds in _model.DataSources)
                            {
                                <option value="@ds.Value">@ds.Key</option>
                            }
                        </InputSelect>
                        <div class="form-text">Select a data source to enable RAG for this profile.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Filter</label>
                        <InputText class="form-control" @bind-Value="_model.DataSourceFilter" placeholder="Optional provider-specific filter" />
                        <div class="form-text">Optional filter expression passed to the data source provider.</div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.DataSourceIsInScope" />
                            <label class="form-check-label">Restrict answers to retrieved data only</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Document Top N</label>
                                <InputNumber class="form-control" @bind-Value="_model.DocumentTopN" min="1" max="20" placeholder="Default: 3" />
                                <div class="form-text">Number of top matching chunks to include as AI context.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Document retrieval mode</label>
                                <InputSelect class="form-select" @bind-Value="_model.DocumentRetrievalMode">
                                    <option value="">Default setting</option>
                                    @foreach (var mode in Enum.GetValues<DocumentRetrievalMode>())
                                    {
                                        <option value="@mode">@mode</option>
                                    }
                                </InputSelect>
                                <div class="form-text">Chunk keeps chunk-level context. Hierarchical injects full document text.</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Strictness</label>
                                <InputNumber class="form-control" @bind-Value="_model.DataSourceStrictness" min="1" max="5" placeholder="Default provider setting" />
                                <div class="form-text">Controls how strictly the AI should follow retrieved data-source matches.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Retrieved documents</label>
                                <InputNumber class="form-control" @bind-Value="_model.DataSourceTopNDocuments" min="1" max="20" placeholder="Default provider setting" />
                                <div class="form-text">How many data-source documents to retrieve for RAG.</div>
                            </div>
                        </div>
                    </div>

                    @if (!_model.HasDocumentIndexConfiguration)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> Document knowledge-base search is not configured yet. Create an <strong>AI Documents</strong> index profile first.
                        </div>
                    }

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.AllowSessionDocuments" />
                            <label class="form-check-label">Allow session document uploads</label>
                        </div>
                        <div class="form-text">Allow users to upload documents during chat sessions.</div>
                    </div>

                    <div class="attached-documents-panel mt-3">
                        <h6 class="mb-1"><i class="bi bi-paperclip"></i> Attach Documents</h6>
                        <p class="text-muted small mb-3">Uploaded files will be indexed as hidden knowledge for this profile after you save it. Supported knowledge formats: @_supportedExtensionsDisplay</p>

                        @if (_model.AttachedDocuments.Count > 0)
                        {
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div class="small text-muted">These documents come from the selected template and will be copied to the new profile when you save it.</div>
                                <span class="badge text-bg-primary rounded-pill">@_model.AttachedDocuments.Count included</span>
                            </div>

                            <div class="attached-documents-list mb-3">
                                @foreach (var doc in _model.AttachedDocuments)
                                {
                                    <div class="attached-document-card">
                                        <span class="attached-document-icon"><i class="bi bi-file-earmark-text"></i></span>
                                        <div class="attached-document-meta flex-grow-1">
                                            <div class="attached-document-name">@doc.FileName</div>
                                            <span class="attached-document-size">@FormatFileSize(doc.FileSize)</span>
                                        </div>
                                        <span class="badge text-bg-secondary">Template</span>
                                    </div>
                                }
                            </div>
                        }

                        <div id="pending-docs-list" class="mb-2">
                            @for (var i = 0; i < _pendingFiles.Count; i++)
                            {
                                var index = i;
                                var file = _pendingFiles[index];
                                <div class="d-flex align-items-center mb-2 pending-doc-row">
                                    <i class="bi bi-file-earmark-plus me-2 text-success"></i>
                                    <span class="flex-grow-1">
                                        @file.Name <small class="text-muted">(@FormatFileSize(file.Size))</small> <span class="badge bg-info">New</span>
                                    </span>
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Remove" @onclick="() => RemovePendingFile(index)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="document-drop-zone" id="profile-doc-drop-zone">
                            <InputFile id="profile-doc-add-input"
                                       OnChange="OnDocumentsSelected"
                                       multiple
                                       accept="@_supportedExtensionsAccept"
                                       class="d-none" />
                            <div class="document-drop-zone__body">
                                <span class="document-drop-zone__icon"><i class="bi bi-cloud-arrow-up"></i></span>
                                <div>
                                    <div class="document-drop-zone__title">Drag and drop files here</div>
                                    <div class="text-muted small">or browse for documents to attach as hidden profile knowledge</div>
                                </div>
                                <div class="document-drop-zone__actions">
                                    <button type="button" class="btn btn-outline-primary" id="profile-doc-browse" data-drop-zone-browse>
                                        <i class="bi bi-folder2-open"></i> Browse files
                                    </button>
                                </div>
                                <div class="form-text mb-0">Supported knowledge formats: @_supportedExtensionsDisplay</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Data Processing & Metrics Tab -->
                <div style="display: @(_activeTab == "processing" ? "block" : "none")">
                    <p class="text-muted mb-3">Configure automatic data extraction from conversations.</p>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.EnableDataExtraction" />
                            <label class="form-check-label">Enable data extraction</label>
                        </div>
                        <div class="form-text">Run AI-powered extraction on conversation messages.</div>
                    </div>

                    @if (_model.EnableDataExtraction)
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Extraction check interval</label>
                                    <InputNumber class="form-control" @bind-Value="_model.ExtractionCheckInterval" min="1" max="20" />
                                    <div class="form-text">How often extraction runs (1 = every message).</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Session inactivity timeout (minutes)</label>
                                    <InputNumber class="form-control" @bind-Value="_model.SessionInactivityTimeoutInMinutes" min="1" />
                                    <div class="form-text">Sessions inactive longer than this will be automatically closed.</div>
                                </div>
                            </div>
                        </div>

                        <h6 class="mb-2 mt-2 border-bottom pb-2"><i class="bi bi-list-check"></i> Extraction Entries</h6>
                        @for (var i = 0; i < _model.DataExtractionEntries.Count; i++)
                        {
                            var index = i;
                            var entry = _model.DataExtractionEntries[index];

                            <div class="card mb-2">
                                <div class="card-header d-flex justify-content-between align-items-center py-2">
                                    <span class="fw-semibold">@(string.IsNullOrWhiteSpace(entry.Name) ? "New Entry" : entry.Name)</span>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.DataExtractionEntries.RemoveAt(index)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Name</label>
                                        <InputText class="form-control" @bind-Value="entry.Name" placeholder="e.g., customer_name" />
                                        <span class="form-text">A unique identifier. Only alphanumeric characters and underscores.</span>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Description</label>
                                        <InputTextArea class="form-control" rows="3" @bind-Value="entry.Description" placeholder="What to extract" />
                                    </div>
                                    <div class="form-check mb-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="entry.AllowMultipleValues" />
                                        <label class="form-check-label">Allow multiple values</label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="entry.IsUpdatable" />
                                        <label class="form-check-label">Updatable</label>
                                    </div>
                                </div>
                            </div>
                        }
                        <button type="button" class="btn btn-sm btn-success" @onclick="AddExtractionEntry">
                            <i class="bi bi-plus"></i> Add Entry
                        </button>
                    }

                    <hr class="my-4" />

                    <h6 class="mb-2"><i class="bi bi-graph-up"></i> Session Metrics</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.EnableSessionMetrics" />
                            <label class="form-check-label">Enable session metrics</label>
                        </div>
                        <div class="form-text">Capture usage, latency, and feedback metrics for analytics.</div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.EnableAIResolutionDetection" />
                            <label class="form-check-label">Enable AI resolution detection</label>
                        </div>
                        <div class="form-text">The AI will determine whether the user's issue was resolved during the session.</div>
                    </div>

                    <h6 class="mb-2"><i class="bi bi-clipboard-check"></i> Post-session Processing</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.EnablePostSessionProcessing" />
                            <label class="form-check-label">Enable post-session processing</label>
                        </div>
                        <div class="form-text">Run AI-powered analysis on the complete conversation after a session closes.</div>
                    </div>

                    @if (_model.EnablePostSessionProcessing)
                    {
                        @for (var i = 0; i < _model.PostSessionTasks.Count; i++)
                        {
                            var index = i;
                            var task = _model.PostSessionTasks[index];

                            <div class="card mb-2">
                                <div class="card-header d-flex justify-content-between align-items-center py-2">
                                    <span class="fw-semibold">@(string.IsNullOrWhiteSpace(task.Name) ? "New Task" : task.Name)</span>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.PostSessionTasks.RemoveAt(index)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Name</label>
                                        <InputText class="form-control" @bind-Value="task.Name" placeholder="e.g., sentiment_analysis" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Type</label>
                                        <InputSelect class="form-select" @bind-Value="task.Type">
                                            @foreach (var tt in Enum.GetValues<PostSessionTaskType>())
                                            {
                                                <option value="@tt">@tt</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Instructions</label>
                                        <InputTextArea class="form-control" rows="3" @bind-Value="task.Instructions" placeholder="Instructions for this task" />
                                    </div>
                                    <div class="form-check mb-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="task.AllowMultipleValues" />
                                        <label class="form-check-label">Allow multiple values</label>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Options (one per line)</label>
                                        <InputTextArea class="form-control" rows="3" @bind-Value="task.Options" placeholder="Option 1&#10;Option 2" />
                                    </div>
                                </div>
                            </div>
                        }
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddPostSessionTask">
                            <i class="bi bi-plus-circle"></i> Add Task
                        </button>
                    }

                    <hr class="my-4" />

                    <h6 class="mb-2"><i class="bi bi-bullseye"></i> Conversion Goals</h6>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.EnableConversionMetrics" />
                            <label class="form-check-label">Enable conversion metrics</label>
                        </div>
                        <div class="form-text">Evaluate each session against defined goals and assign scores.</div>
                    </div>

                    @if (_model.EnableConversionMetrics)
                    {
                        @for (var i = 0; i < _model.ConversionGoals.Count; i++)
                        {
                            var index = i;
                            var goal = _model.ConversionGoals[index];

                            <div class="card mb-2">
                                <div class="card-header d-flex justify-content-between align-items-center py-2">
                                    <span class="fw-semibold">@(string.IsNullOrWhiteSpace(goal.Name) ? "New goal" : goal.Name)</span>
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.ConversionGoals.RemoveAt(index)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label">Name</label>
                                        <InputText class="form-control" @bind-Value="goal.Name" placeholder="e.g., booking_completed" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Description</label>
                                        <InputTextArea class="form-control" rows="3" @bind-Value="goal.Description" placeholder="Describe what constitutes success" />
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Min score</label>
                                                <InputNumber class="form-control" @bind-Value="goal.MinScore" min="0" />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Max score</label>
                                                <InputNumber class="form-control" @bind-Value="goal.MaxScore" min="1" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        <button type="button" class="btn btn-sm btn-success" @onclick="AddConversionGoal">
                            <i class="bi bi-plus"></i> Add Goal
                        </button>
                    }
                </div>

                <!-- Settings Tab -->
                <div style="display: @(_activeTab == "settings" ? "block" : "none")">
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.IsListable" />
                            <label class="form-check-label">Listable</label>
                        </div>
                        <div class="form-text">Show this profile in the chat UI for users to select.</div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.IsRemovable" />
                            <label class="form-check-label">Removable</label>
                        </div>
                        <div class="form-text">Allow this profile to be deleted.</div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.LockSystemMessage" />
                            <label class="form-check-label">Lock system message</label>
                        </div>
                        <div class="form-text">Prevent modification of the system message after creation.</div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Create
                </button>
                <a href="/ai/profiles" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private AIProfileViewModel _model = new()
    {
        Type = AIProfileType.Chat,
        UseCaching = true,
        IsListable = true,
        IsRemovable = true,
    };

    private string _activeTab = "basic";
    private string _nameError;
    private string _errorMessage;
    private string _selectedApplyTemplateId;
    private string _promptTemplateSearchTerm;
    private IReadOnlyList<SpeechVoice> _availableVoices = [];
    private List<Microsoft.AspNetCore.Components.Forms.IBrowserFile> _pendingFiles = [];
    private string _supportedExtensionsAccept;
    private string _supportedExtensionsDisplay;

    protected override async Task OnInitializedAsync()
    {
        await PopulateDropdownsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAutoGenerateTechnicalName", "profileTitle", "profileName");
            await JS.InvokeVoidAsync("initDocumentDropZone", new
            {
                dropZone = "#profile-doc-drop-zone",
                fileInput = "#profile-doc-add-input",
                browseButton = "#profile-doc-browse",
            });
        }
    }

    private async Task ApplyTemplateAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedApplyTemplateId))
        {
            return;
        }

        var template = await TemplateManager.FindByIdAsync(_selectedApplyTemplateId);
        if (template == null)
        {
            return;
        }

        var profile = new AIProfile { Type = AIProfileType.Chat };
        ApplyTemplateToProfile(profile, template);

        _model = AIProfileViewModel.FromProfile(profile);
        _model.SelectedTemplateId = _selectedApplyTemplateId;
        await PopulateDropdownsAsync();
    }

    private async Task HandleSubmitAsync()
    {
        _nameError = null;
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _nameError = "Technical name is required.";

            return;
        }

        _model.SelectedA2AConnectionIds = await GetValidA2AConnectionIdsAsync(_model.SelectedA2AConnectionIds);
        _model.SelectedMcpConnectionIds = await GetValidMcpConnectionIdsAsync(_model.SelectedMcpConnectionIds);
        SyncCheckboxSelections();

        var profile = new AIProfile { Type = AIProfileType.Chat };
        _model.ApplyTo(profile);
        profile.ItemId = Guid.NewGuid().ToString("N");

        await ProfileManager.CreateAsync(profile);
        await StoreCommitter.CommitAsync();

        if (_pendingFiles.Count > 0)
        {
            using var formFiles = await BrowserFileFormFileCollection.CreateAsync(_pendingFiles);

            if (formFiles.Files.Count > 0)
            {
                await ProfileDocumentService.UploadDocumentsAsync(profile, formFiles.Files);
                await ProfileManager.UpdateAsync(profile);
                await StoreCommitter.CommitAsync();
            }
        }

        Navigation.NavigateTo("/ai/profiles");
    }

    private void SyncCheckboxSelections()
    {
        _model.SelectedToolNames = _model.AvailableTools.Where(t => t.IsSelected).Select(t => t.Name).ToArray();
        _model.SelectedAgentNames = _model.AvailableAgents.Where(a => a.IsSelected).Select(a => a.Name).ToArray();
        _model.SelectedA2AConnectionIds = _model.AvailableA2AConnections.Where(c => c.IsSelected).Select(c => c.ItemId).ToArray();
        _model.SelectedMcpConnectionIds = _model.AvailableMcpConnections.Where(c => c.IsSelected).Select(c => c.ItemId).ToArray();
    }

