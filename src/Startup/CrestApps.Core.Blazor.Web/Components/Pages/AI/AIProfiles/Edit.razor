@page "/ai/profiles/edit/{Id}"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI
@using CrestApps.Core.AI.A2A.Models
@using CrestApps.Core.AI.Claude.Models
@using CrestApps.Core.AI.Claude.Services
@using CrestApps.Core.AI.Copilot.Models
@using CrestApps.Core.AI.Copilot.Services
@using CrestApps.Core.AI.DataSources
@using CrestApps.Core.AI.Documents
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Orchestration
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.AI.Services
@using CrestApps.Core.AI.Speech
@using CrestApps.Core.AI.Tooling
@using CrestApps.Core.Blazor.Web.Areas.AI.Services
@using CrestApps.Core.Blazor.Web.Areas.AIChat.Services
@using CrestApps.Core.Blazor.Web.Services
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Services
@using CrestApps.Core.Templates.Services
@using Microsoft.Extensions.Options
@inject IAIProfileManager ProfileManager
@inject IAIProfileTemplateManager TemplateManager
@inject ICatalog<AIDeployment> DeploymentCatalog
@inject ICatalog<A2AConnection> A2ACatalog
@inject ICatalog<McpConnection> McpCatalog
@inject IAIDataSourceStore DataSourceStore
@inject IAIDocumentStore DocumentStore
@inject ISearchIndexProfileStore IndexProfileStore
@inject ITemplateService TemplateService
@inject IOptions<OrchestratorOptions> OrchestratorOpts
@inject IOptionsSnapshot<ClaudeOptions> ClaudeOpts
@inject ClaudeClientService ClaudeClientService
@inject IOptionsMonitor<CopilotOptions> CopilotOpts
@inject IOptions<AIToolDefinitionOptions> ToolOpts
@inject IOptionsMonitor<InteractionDocumentOptions> DocOpts
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions
@inject ISpeechVoiceResolver SpeechVoiceResolver
@inject AIProfileDocumentService ProfileDocumentService
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SiteSettingsStore SiteSettingsStore

<PageTitle>Edit AI Profile - Blazor AI Integration Sample</PageTitle>
<link rel="stylesheet" href="/_content/CrestApps.AI.Resources/styles/document-drop-zone.css" />

@if (_notFound)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> Profile not found.
    </div>
    <a href="/ai/profiles" class="btn btn-secondary">Back to Profiles</a>
}
else if (_model != null)
{
    <h2><i class="bi bi-pencil"></i> Edit AI Profile</h2>
    <hr />

    <EditForm FormName="ai-aiprofiles-edit" Model="_model" OnValidSubmit="HandleSubmitAsync">
        <input type="hidden" name="_model.ItemId" value="@_model.ItemId" />
        <div class="row">
            <div class="col-md-8">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger">@_errorMessage</div>
                }

                <!-- Tab Navigation -->
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <button type="button" class="nav-link @(_activeTab == "basic" ? "active" : "")" @onclick='() => _activeTab = "basic"'>Basic Info</button>
                    </li>
                    <li class="nav-item">
                        <button type="button" class="nav-link @(_activeTab == "params" ? "active" : "")" @onclick='() => _activeTab = "params"'>AI Parameters</button>
                    </li>
                    <li class="nav-item">
                        <button type="button" class="nav-link @(_activeTab == "capabilities" ? "active" : "")" @onclick='() => _activeTab = "capabilities"'>Capabilities</button>
                    </li>
                    <li class="nav-item">
                        <button type="button" class="nav-link @(_activeTab == "knowledge" ? "active" : "")" @onclick='() => _activeTab = "knowledge"'>Knowledge</button>
                    </li>
                    <li class="nav-item">
                        <button type="button" class="nav-link @(_activeTab == "processing" ? "active" : "")" @onclick='() => _activeTab = "processing"'>Data Processing &amp; Metrics</button>
                    </li>
                    <li class="nav-item">
                        <button type="button" class="nav-link @(_activeTab == "settings" ? "active" : "")" @onclick='() => _activeTab = "settings"'>Settings</button>
                    </li>
                </ul>

                <div class="p-3 border border-top-0 rounded-bottom">

                    <!-- Basic Info Tab -->
                    <div style="display: @(_activeTab == "basic" ? "block" : "none")">
                        <div class="mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_model.DisplayText" placeholder="e.g., My Chat Assistant" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Technical name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" value="@_model.Name" disabled />
                            @if (!string.IsNullOrEmpty(_nameError))
                            {
                                <div class="text-danger">@_nameError</div>
                            }
                            <div class="form-text">The technical name cannot be changed after creation.</div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Profile type</label>
                                    <select class="form-select" value="@_model.Type" @onchange="OnProfileTypeChanged">
                                        @foreach (var profileType in Enum.GetValues<AIProfileType>())
                                        {
                                            <option value="@profileType">@profileType</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            @if (_model.Type == AIProfileType.Chat)
                            {
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label class="form-label">Title type</label>
                                        <InputSelect class="form-select" @bind-Value="_model.TitleType">
                                            <option value="">Default</option>
                                            @foreach (var tt in Enum.GetValues<AISessionTitleType>())
                                            {
                                                <option value="@tt">@tt</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label class="form-label">Chat mode</label>
                                        <InputSelect class="form-select" @bind-Value="_model.ChatMode">
                                            <option value="@ChatMode.TextInput">Text input</option>
                                            <option value="@ChatMode.AudioInput">Audio input</option>
                                            <option value="@ChatMode.Conversation">Conversation</option>
                                        </InputSelect>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (_model.Type == AIProfileType.Chat)
                        {
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <InputCheckbox class="form-check-input" @bind-Value="_model.EnableTextToSpeechPlayback" />
                                    <label class="form-check-label">Enable text-to-speech playback</label>
                                </div>
                                <div class="form-text">Show a play button on assistant messages when a text-to-speech deployment is configured.</div>
                            </div>

                            @if (_model.ChatMode == ChatMode.Conversation)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Voice</label>
                                    <InputSelect class="form-select" @bind-Value="_model.VoiceName">
                                        <option value="">Default voice</option>
                                        @foreach (var group in _availableVoices.GroupBy(GetVoiceGroupLabel).OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase))
                                        {
                                            <optgroup label="@group.Key">
                                                @foreach (var voice in group.OrderBy(v => v.Name, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <option value="@voice.Id">@voice.Name</option>
                                                }
                                            </optgroup>
                                        }
                                    </InputSelect>
                                    <div class="form-text">Leave empty to use the site's default text-to-speech voice.</div>
                                </div>
                            }
                        }

                        @if (_model.Type == AIProfileType.Agent)
                        {
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" rows="3" @bind-Value="_model.Description" placeholder="Describe what this agent does" />
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Chat deployment</label>
                                    <InputSelect class="form-select" @bind-Value="_model.ChatDeploymentName">
                                        <option value="">Use default chat deployment</option>
                                        @foreach (var d in _model.ChatDeployments)
                                        {
                                            <option value="@d.Value">@d.Key</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Utility deployment</label>
                                    <InputSelect class="form-select" @bind-Value="_model.UtilityDeploymentName">
                                        <option value="">Use default utility deployment</option>
                                        @foreach (var d in _model.UtilityDeployments)
                                        {
                                            <option value="@d.Value">@d.Key</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Orchestrator</label>
                                    <select class="form-select" value="@_model.OrchestratorName" @onchange="OnOrchestratorChanged">
                                        <option value="">Use default orchestrator</option>
                                        @foreach (var o in _model.Orchestrators)
                                        {
                                            <option value="@o.Value">@o.Key</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Copilot Config -->
                        @if (!string.IsNullOrEmpty(_model.OrchestratorName) &&
                             string.Equals(_model.OrchestratorName, CopilotOrchestrator.OrchestratorName, StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="card mb-3">
                                <div class="card-header"><h6 class="card-title mb-0"><i class="bi bi-github me-1"></i> Copilot Configuration</h6></div>
                                <div class="card-body">
                                    @if (!_model.CopilotIsConfigured)
                                    {
                                        <div class="alert alert-warning mb-0"><strong>Copilot is not configured.</strong> Go to <a href="/admin/settings"><strong>Settings</strong></a> first.</div>
                                    }
                                    else if (_model.CopilotAuthenticationType == (int)CopilotAuthenticationType.ApiKey)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label">Model override</label>
                                            <InputText class="form-control" @bind-Value="_model.CopilotModel" placeholder="Leave empty to use default" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Effort level</label>
                                            <InputSelect class="form-select" @bind-Value="_model.CopilotReasoningEffort">
                                                @foreach (var e in Enum.GetValues<CopilotReasoningEffort>())
                                                {
                                                    <option value="@e">@(e == CopilotReasoningEffort.None ? "Default" : e.ToString())</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="form-check">
                                            <InputCheckbox class="form-check-input" @bind-Value="_model.CopilotIsAllowAll" />
                                            <label class="form-check-label">Allow all tool executions</label>
                                        </div>
                                    }
                                    else if (_model.CopilotIsAuthenticated)
                                    {
                                        <div class="alert alert-success py-2 mb-3"><i class="bi bi-check-circle-fill"></i> Connected as <strong>@_model.CopilotGitHubUsername</strong></div>
                                        <div class="mb-3">
                                            <label class="form-label">Copilot model</label>
                                            <InputSelect class="form-select" @bind-Value="_model.CopilotModel">
                                                @foreach (var m in _model.CopilotAvailableModels)
                                                {
                                                    <option value="@m.Value">@m.Key</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Effort level</label>
                                            <InputSelect class="form-select" @bind-Value="_model.CopilotReasoningEffort">
                                                @foreach (var e in Enum.GetValues<CopilotReasoningEffort>())
                                                {
                                                    <option value="@e">@(e == CopilotReasoningEffort.None ? "Default" : e.ToString())</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="form-check">
                                            <InputCheckbox class="form-check-input" @bind-Value="_model.CopilotIsAllowAll" />
                                            <label class="form-check-label">Allow all tool executions</label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Claude Config -->
                        @if (!string.IsNullOrEmpty(_model.OrchestratorName) &&
                             string.Equals(_model.OrchestratorName, ClaudeOrchestrator.OrchestratorName, StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="card mb-3">
                                <div class="card-header"><h6 class="card-title mb-0"><i class="bi bi-lightning me-1"></i> Claude Configuration</h6></div>
                                <div class="card-body">
                                    @if (!_model.ClaudeIsConfigured)
                                    {
                                        <div class="alert alert-warning mb-0"><strong>Claude is not configured.</strong> Go to <a href="/admin/settings"><strong>Settings</strong></a> first.</div>
                                    }
                                    else if (_model.AnthropicAvailableModels.Count > 0)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label">Claude model</label>
                                            <InputSelect class="form-select" @bind-Value="_model.ClaudeModel">
                                                <option value="">Use default model</option>
                                                @foreach (var m in _model.AnthropicAvailableModels)
                                                {
                                                    <option value="@m.Value">@m.Key</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="mb-0">
                                            <label class="form-label">Effort level</label>
                                            <InputSelect class="form-select" @bind-Value="_model.ClaudeEffortLevel">
                                                @foreach (var e in Enum.GetValues<ClaudeEffortLevel>())
                                                {
                                                    <option value="@e">@(e == ClaudeEffortLevel.None ? "Default" : e.ToString())</option>
                                                }
                                            </InputSelect>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mb-3">
                                            <label class="form-label">Claude model</label>
                                            <InputText class="form-control" @bind-Value="_model.ClaudeModel" placeholder="Leave empty to use default" />
                                        </div>
                                        <div class="mb-0">
                                            <label class="form-label">Effort level</label>
                                            <InputSelect class="form-select" @bind-Value="_model.ClaudeEffortLevel">
                                                @foreach (var e in Enum.GetValues<ClaudeEffortLevel>())
                                                {
                                                    <option value="@e">@(e == ClaudeEffortLevel.None ? "Default" : e.ToString())</option>
                                                }
                                            </InputSelect>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (_model.Type == AIProfileType.Chat || _model.Type == AIProfileType.TemplatePrompt)
                        {
                            <div class="mb-3">
                                <label class="form-label">Prompt subject</label>
                                <InputText class="form-control" @bind-Value="_model.PromptSubject" placeholder="Optional subject context" />
                            </div>
                        }

                        @if (_model.Type == AIProfileType.Chat)
                        {
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <InputCheckbox class="form-check-input" @bind-Value="_model.AddInitialPrompt" />
                                    <label class="form-check-label">Add initial prompt</label>
                                </div>
                            </div>

                            @if (!_model.AddInitialPrompt)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Welcome message</label>
                                    <InputTextArea class="form-control" rows="3" @bind-Value="_model.WelcomeMessage" placeholder="Message shown when a chat starts" />
                                </div>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <label class="form-label">Initial prompt</label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="_model.InitialPrompt" placeholder="First assistant message" />
                                </div>
                            }
                        }

                        @if (_model.Type == AIProfileType.TemplatePrompt)
                        {
                            <div class="mb-3">
                                <label class="form-label">Prompt template</label>
                                <InputTextArea class="form-control" rows="5" @bind-Value="_model.PromptTemplate" placeholder="Template for generating prompts" />
                            </div>
                        }
                    </div>

                    <!-- AI Parameters Tab -->
                    <div style="display: @(_activeTab == "params" ? "block" : "none")">
                        @if (_model.AvailablePromptTemplates.Count > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label">Prompt templates</label>
                                <div class="dropdown mb-2 w-100">
                                    <button class="btn btn-outline-primary dropdown-toggle w-100 d-flex justify-content-center align-items-center gap-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <span aria-hidden="true">+</span> Add template
                                    </button>
                                    <div class="dropdown-menu p-2" style="max-height:24rem;min-width:22rem;overflow-y:auto;">
                                        <div class="mb-2" @onclick:stopPropagation="true">
                                            <input type="search"
                                                   class="form-control form-control-sm"
                                                   @bind="_promptTemplateSearchTerm"
                                                   @bind:event="oninput"
                                                   placeholder="Search prompt templates..." />
                                        </div>
                                        <div class="prompt-template-menu-items">
                                            @foreach (var group in FilteredPromptTemplateGroups)
                                            {
                                                <div class="dropdown-header px-2">@group.Key</div>
                                                @foreach (var option in group)
                                                {
                                                    <button type="button"
                                                            class="dropdown-item text-wrap"
                                                            @onclick="() => AddPromptTemplate(option.TemplateId)">
                                                        <span class="d-block fw-semibold">@option.Title</span>
                                                        @if (!string.IsNullOrWhiteSpace(option.Description))
                                                        {
                                                            <small class="text-muted">@option.Description</small>
                                                        }
                                                    </button>
                                                }
                                            }
                                        </div>
                                        @if (!HasFilteredPromptTemplates)
                                        {
                                            <div class="text-muted small px-2 py-1">No prompt templates match your search.</div>
                                        }
                                    </div>
                                </div>

                                @for (var i = 0; i < _model.PromptTemplates.Count; i++)
                                {
                                    var index = i;
                                    var selection = _model.PromptTemplates[index];
                                    var option = _model.AvailablePromptTemplates.FirstOrDefault(t => string.Equals(t.TemplateId, selection.TemplateId, StringComparison.OrdinalIgnoreCase));
                                    var title = option?.Title ?? selection.TemplateId ?? "Prompt template";

                                    <div class="card mb-1">
                                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                                            <span class="fw-semibold">@title</span>
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.PromptTemplates.RemoveAt(index)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        <div class="card-body">
                                            @if (option?.Parameters?.Count > 0)
                                            {
                                                <ul class="mb-2 small text-muted">
                                                    @foreach (var p in option.Parameters)
                                                    {
                                                        <li><strong>@p.Name</strong>@(string.IsNullOrWhiteSpace(p.Description) ? "" : $": {p.Description}")</li>
                                                    }
                                                </ul>
                                            }

                                            <label class="form-label">Template parameters</label>
                                            <InputTextArea class="form-control" rows="3" @bind-Value="selection.PromptParameters" placeholder='{"key1": "value1"}' />
                                        </div>
                                    </div>
                                }

                                @if (_model.PromptTemplates.Count == 0)
                                {
                                    <div class="text-muted small">No prompt templates selected.</div>
                                }
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">System message</label>
                            <InputTextArea class="form-control" rows="5" @bind-Value="_model.SystemMessage" placeholder="You are a helpful AI assistant..." />
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Temperature</label>
                                    <InputNumber class="form-control" @bind-Value="_model.Temperature" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Top P</label>
                                    <InputNumber class="form-control" @bind-Value="_model.TopP" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Frequency penalty</label>
                                    <InputNumber class="form-control" @bind-Value="_model.FrequencyPenalty" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Presence penalty</label>
                                    <InputNumber class="form-control" @bind-Value="_model.PresencePenalty" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Max output tokens</label>
                                    <InputNumber class="form-control" @bind-Value="_model.MaxTokens" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Past messages count</label>
                                    <InputNumber class="form-control" @bind-Value="_model.PastMessagesCount" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.UseCaching" />
                                <label class="form-check-label">Enable response caching</label>
                            </div>
                        </div>
                    </div>

                    <!-- Capabilities Tab -->
                    <div style="display: @(_activeTab == "capabilities" ? "block" : "none")">
                        <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-robot"></i> AI Agents</h6>
                        @if (_model.AvailableAgents.Count == 0)
                        {
                            <div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> No agent profiles available.</div>
                        }
                        else
                        {
                            @foreach (var agent in _model.AvailableAgents)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" checked="@agent.IsSelected" @onchange="e => ToggleAgent(agent.Name, (bool)e.Value)" id="agent_@agent.Name" />
                                    <label class="form-check-label" for="agent_@agent.Name">
                                        <strong>@agent.DisplayText</strong>
                                        @if (!string.IsNullOrEmpty(agent.Description))
                                        {
                                            <br /><small class="text-muted">@agent.Description</small>
                                        }
                                    </label>
                                </div>
                            }
                        }

                        <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h6>
                        @if (_model.AvailableA2AConnections.Count == 0)
                        {
                            <div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> No A2A hosts configured.</div>
                        }
                        else
                        {
                            @foreach (var c in _model.AvailableA2AConnections)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" checked="@c.IsSelected" @onchange="e => ToggleA2A(c.ItemId, (bool)e.Value)" id="a2a_@c.ItemId" />
                                    <label class="form-check-label" for="a2a_@c.ItemId"><strong>@c.DisplayText</strong><br /><small class="text-muted">@c.Endpoint</small></label>
                                </div>
                            }
                        }

                        <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-plug"></i> MCP Hosts</h6>
                        @if (_model.AvailableMcpConnections.Count == 0)
                        {
                            <div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> No MCP hosts configured.</div>
                        }
                        else
                        {
                            @foreach (var c in _model.AvailableMcpConnections)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" checked="@c.IsSelected" @onchange="e => ToggleMcp(c.ItemId, (bool)e.Value)" id="mcp_@c.ItemId" />
                                    <label class="form-check-label" for="mcp_@c.ItemId">
                                        <strong>@c.DisplayText</strong>
                                        @if (!string.IsNullOrEmpty(c.Source))
                                        {
                                            <br /><small class="text-muted">@c.Source</small>
                                        }
                                    </label>
                                </div>
                            }
                        }

                        <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-tools"></i> AI Tools</h6>
                        @if (_model.AvailableTools.Count == 0)
                        {
                            <div class="alert alert-info mb-0"><i class="bi bi-info-circle"></i> No selectable AI tools registered.</div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <p class="text-muted mb-0 small">Select the tools this profile can use.</p>
                                <div class="btn-group btn-group-sm ms-3">
                                    <button type="button" class="btn btn-outline-primary" @onclick="SelectAllTools"><i class="bi bi-check-all"></i> Select all</button>
                                    <button type="button" class="btn btn-outline-secondary" @onclick="DeselectAllTools"><i class="bi bi-x-lg"></i> Deselect all</button>
                                </div>
                            </div>
                            @foreach (var group in _model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                            {
                                <h6 class="text-secondary mt-3 mb-2"><i class="bi bi-folder"></i> @group.Key</h6>
                                @foreach (var tool in group)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" checked="@tool.IsSelected" @onchange="e => ToggleTool(tool.Name, (bool)e.Value)" id="tool_@tool.Name" />
                                        <label class="form-check-label" for="tool_@tool.Name">
                                            <strong>@tool.Title</strong>
                                            @if (!string.IsNullOrEmpty(tool.Description))
                                            {
                                                <br /><small class="text-muted">@tool.Description</small>
                                            }
                                        </label>
                                    </div>
                                }
                            }
                        }
                    </div>

                    <!-- Knowledge Tab -->
                    <div style="display: @(_activeTab == "knowledge" ? "block" : "none")">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnableUserMemory" />
                                <label class="form-check-label">Enable user memory</label>
                            </div>
                        </div>

                        <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-database"></i> Data Source</h6>
                        <div class="mb-3">
                            <label class="form-label">Data source</label>
                            <InputSelect class="form-select" @bind-Value="_model.DataSourceId">
                                <option value="">No data source</option>
                                @foreach (var ds in _model.DataSources)
                                {
                                    <option value="@ds.Value">@ds.Key</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Filter</label>
                            <InputText class="form-control" @bind-Value="_model.DataSourceFilter" placeholder="Optional provider-specific filter" />
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.DataSourceIsInScope" />
                                <label class="form-check-label">Restrict answers to retrieved data only</label>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Document Top N</label>
                                    <InputNumber class="form-control" @bind-Value="_model.DocumentTopN" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Document retrieval mode</label>
                                    <InputSelect class="form-select" @bind-Value="_model.DocumentRetrievalMode">
                                        <option value="">Default setting</option>
                                        @foreach (var mode in Enum.GetValues<DocumentRetrievalMode>())
                                        {
                                            <option value="@mode">@mode</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Strictness</label>
                                    <InputNumber class="form-control" @bind-Value="_model.DataSourceStrictness" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Retrieved documents</label>
                                    <InputNumber class="form-control" @bind-Value="_model.DataSourceTopNDocuments" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.AllowSessionDocuments" />
                                <label class="form-check-label">Allow session document uploads</label>
                            </div>
                        </div>

                        <div class="attached-documents-panel mt-3">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h6 class="mb-1"><i class="bi bi-file-earmark-text"></i> Attached Documents</h6>
                                    <p class="text-muted small mb-0">These files are indexed as background knowledge for this profile and remain hidden from end users. Supported knowledge formats: @_supportedExtensionsDisplay</p>
                                </div>
                                <span class="badge text-bg-primary rounded-pill">@_model.AttachedDocuments.Count existing</span>
                            </div>

                            <div class="attached-documents-list mb-3">
                                @foreach (var doc in _model.AttachedDocuments)
                                {
                                    <div class="attached-document-card">
                                        <span class="attached-document-icon"><i class="bi bi-file-earmark-text"></i></span>
                                        <div class="attached-document-meta flex-grow-1">
                                            <div class="attached-document-name">@doc.FileName</div>
                                            <span class="attached-document-size">@FormatFileSize(doc.FileSize)</span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Remove" @onclick="() => RemoveDocument(doc.DocumentId)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>

                            <div id="pending-docs-list" class="mb-2">
                                @for (var i = 0; i < _pendingFiles.Count; i++)
                                {
                                    var index = i;
                                    var file = _pendingFiles[index];
                                    <div class="d-flex align-items-center mb-2 pending-doc-row">
                                        <i class="bi bi-file-earmark-plus me-2 text-success"></i>
                                        <span class="flex-grow-1">
                                            @file.Name <small class="text-muted">(@FormatFileSize(file.Size))</small> <span class="badge bg-info">New</span>
                                        </span>
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Remove" @onclick="() => RemovePendingFile(index)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>

                            <div class="document-drop-zone" id="profile-doc-drop-zone">
                                <InputFile id="profile-doc-add-input"
                                           OnChange="OnDocumentsSelected"
                                           multiple
                                           accept="@_supportedExtensionsAccept"
                                           class="d-none" />
                                <div class="document-drop-zone__body">
                                    <span class="document-drop-zone__icon"><i class="bi bi-cloud-arrow-up"></i></span>
                                    <div>
                                        <div class="document-drop-zone__title">Drag and drop files here</div>
                                        <div class="text-muted small">or browse for documents to attach as hidden profile knowledge</div>
                                    </div>
                                    <div class="document-drop-zone__actions">
                                        <button type="button" class="btn btn-outline-primary" id="profile-doc-browse" data-drop-zone-browse>
                                            <i class="bi bi-folder2-open"></i> Browse files
                                        </button>
                                    </div>
                                    <div class="form-text mb-0">Supported knowledge formats: @_supportedExtensionsDisplay</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Data Processing & Metrics Tab -->
                    <div style="display: @(_activeTab == "processing" ? "block" : "none")">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnableDataExtraction" />
                                <label class="form-check-label">Enable data extraction</label>
                            </div>
                        </div>

                        @if (_model.EnableDataExtraction)
                        {
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Extraction check interval</label>
                                        <InputNumber class="form-control" @bind-Value="_model.ExtractionCheckInterval" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Session inactivity timeout (minutes)</label>
                                        <InputNumber class="form-control" @bind-Value="_model.SessionInactivityTimeoutInMinutes" />
                                    </div>
                                </div>
                            </div>

                            <h6 class="mb-2 mt-2 border-bottom pb-2"><i class="bi bi-list-check"></i> Extraction Entries</h6>
                            @for (var i = 0; i < _model.DataExtractionEntries.Count; i++)
                            {
                                var index = i;
                                var entry = _model.DataExtractionEntries[index];

                                <div class="card mb-2">
                                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                                        <span class="fw-semibold">@(string.IsNullOrWhiteSpace(entry.Name) ? "New Entry" : entry.Name)</span>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.DataExtractionEntries.RemoveAt(index)"><i class="bi bi-trash"></i></button>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label class="form-label">Name</label>
                                            <InputText class="form-control" @bind-Value="entry.Name" placeholder="e.g., customer_name" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Description</label>
                                            <InputTextArea class="form-control" rows="3" @bind-Value="entry.Description" />
                                        </div>
                                        <div class="form-check mb-2">
                                            <InputCheckbox class="form-check-input" @bind-Value="entry.AllowMultipleValues" />
                                            <label class="form-check-label">Allow multiple values</label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <InputCheckbox class="form-check-input" @bind-Value="entry.IsUpdatable" />
                                            <label class="form-check-label">Updatable</label>
                                        </div>
                                    </div>
                                </div>
                            }
                            <button type="button" class="btn btn-sm btn-success" @onclick="AddExtractionEntry"><i class="bi bi-plus"></i> Add Entry</button>
                        }

                        <hr class="my-4" />
                        <h6 class="mb-2"><i class="bi bi-graph-up"></i> Session Metrics</h6>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnableSessionMetrics" />
                                <label class="form-check-label">Enable session metrics</label>
                            </div>
                        </div>
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnableAIResolutionDetection" />
                                <label class="form-check-label">Enable AI resolution detection</label>
                            </div>
                        </div>

                        <h6 class="mb-2"><i class="bi bi-clipboard-check"></i> Post-session Processing</h6>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnablePostSessionProcessing" />
                                <label class="form-check-label">Enable post-session processing</label>
                            </div>
                        </div>

                        @if (_model.EnablePostSessionProcessing)
                        {
                            @for (var i = 0; i < _model.PostSessionTasks.Count; i++)
                            {
                                var index = i;
                                var task = _model.PostSessionTasks[index];

                                <div class="card mb-2">
                                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                                        <span class="fw-semibold">@(string.IsNullOrWhiteSpace(task.Name) ? "New Task" : task.Name)</span>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.PostSessionTasks.RemoveAt(index)"><i class="bi bi-trash"></i></button>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3"><label class="form-label">Name</label><InputText class="form-control" @bind-Value="task.Name" /></div>
                                        <div class="mb-3">
                                            <label class="form-label">Type</label>
                                            <InputSelect class="form-select" @bind-Value="task.Type">
                                                @foreach (var tt in Enum.GetValues<PostSessionTaskType>()) { <option value="@tt">@tt</option> }
                                            </InputSelect>
                                        </div>
                                        <div class="mb-3"><label class="form-label">Instructions</label><InputTextArea class="form-control" rows="3" @bind-Value="task.Instructions" /></div>
                                        <div class="form-check mb-2"><InputCheckbox class="form-check-input" @bind-Value="task.AllowMultipleValues" /><label class="form-check-label">Allow multiple values</label></div>
                                        <div class="mb-3"><label class="form-label">Options (one per line)</label><InputTextArea class="form-control" rows="3" @bind-Value="task.Options" /></div>
                                    </div>
                                </div>
                            }
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddPostSessionTask"><i class="bi bi-plus-circle"></i> Add Task</button>
                        }

                        <hr class="my-4" />
                        <h6 class="mb-2"><i class="bi bi-bullseye"></i> Conversion Goals</h6>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.EnableConversionMetrics" />
                                <label class="form-check-label">Enable conversion metrics</label>
                            </div>
                        </div>

                        @if (_model.EnableConversionMetrics)
                        {
                            @for (var i = 0; i < _model.ConversionGoals.Count; i++)
                            {
                                var index = i;
                                var goal = _model.ConversionGoals[index];

                                <div class="card mb-2">
                                    <div class="card-header d-flex justify-content-between align-items-center py-2">
                                        <span class="fw-semibold">@(string.IsNullOrWhiteSpace(goal.Name) ? "New goal" : goal.Name)</span>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.ConversionGoals.RemoveAt(index)"><i class="bi bi-trash"></i></button>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3"><label class="form-label">Name</label><InputText class="form-control" @bind-Value="goal.Name" /></div>
                                        <div class="mb-3"><label class="form-label">Description</label><InputTextArea class="form-control" rows="3" @bind-Value="goal.Description" /></div>
                                        <div class="row">
                                            <div class="col-md-6"><div class="mb-3"><label class="form-label">Min score</label><InputNumber class="form-control" @bind-Value="goal.MinScore" /></div></div>
                                            <div class="col-md-6"><div class="mb-3"><label class="form-label">Max score</label><InputNumber class="form-control" @bind-Value="goal.MaxScore" /></div></div>
                                        </div>
                                    </div>
                                </div>
                            }
                            <button type="button" class="btn btn-sm btn-success" @onclick="AddConversionGoal"><i class="bi bi-plus"></i> Add Goal</button>
                        }
                    </div>

                    <!-- Settings Tab -->
                    <div style="display: @(_activeTab == "settings" ? "block" : "none")">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsListable" />
                                <label class="form-check-label">Listable</label>
                            </div>
                            <div class="form-text">Show this profile in the chat UI.</div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsRemovable" />
                                <label class="form-check-label">Removable</label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.LockSystemMessage" />
                                <label class="form-check-label">Lock system message</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                    <a href="/ai/profiles" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public string Id { get; set; }

    private AIProfileViewModel _model;
    private bool _notFound;
    private string _activeTab = "basic";
    private string _nameError;
    private string _errorMessage;
    private string _promptTemplateSearchTerm;
    private IReadOnlyList<SpeechVoice> _availableVoices = [];
    private List<string> _removedDocumentIds = [];
    private List<Microsoft.AspNetCore.Components.Forms.IBrowserFile> _pendingFiles = [];
    private string _supportedExtensionsAccept;
    private string _supportedExtensionsDisplay;

    protected override async Task OnInitializedAsync()
    {
        var profile = await ProfileManager.FindByIdAsync(Id);
        if (profile == null)
        {
            _notFound = true;

            return;
        }

        _model = AIProfileViewModel.FromProfile(profile);
        await PopulateAttachedDocumentsAsync();
        await PopulateDropdownsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initDocumentDropZone", new
            {
                dropZone = "#profile-doc-drop-zone",
                fileInput = "#profile-doc-add-input",
                browseButton = "#profile-doc-browse",
            });
        }
    }

    private async Task HandleSubmitAsync()
    {
        _nameError = null;
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _nameError = "Name is required.";

            return;
        }

        var existing = await ProfileManager.FindByIdAsync(_model.ItemId);
        if (existing == null)
        {
            _notFound = true;

            return;
        }

        SyncCheckboxSelections();
        _model.SelectedA2AConnectionIds = await GetValidA2AConnectionIdsAsync(_model.SelectedA2AConnectionIds);
        _model.SelectedMcpConnectionIds = await GetValidMcpConnectionIdsAsync(_model.SelectedMcpConnectionIds);
        _model.ApplyTo(existing);

        if (_removedDocumentIds.Count > 0)
        {
            await ProfileDocumentService.RemoveDocumentsAsync(existing, _removedDocumentIds);
        }

        if (_pendingFiles.Count > 0)
        {
            using var formFiles = await BrowserFileFormFileCollection.CreateAsync(_pendingFiles);

            if (formFiles.Files.Count > 0)
            {
                await ProfileDocumentService.UploadDocumentsAsync(existing, formFiles.Files);
            }
        }

        await ProfileManager.UpdateAsync(existing);
        await StoreCommitter.CommitAsync();

        Navigation.NavigateTo("/ai/profiles");
    }

    private void SyncCheckboxSelections()
    {
        _model.SelectedToolNames = _model.AvailableTools.Where(t => t.IsSelected).Select(t => t.Name).ToArray();
        _model.SelectedAgentNames = _model.AvailableAgents.Where(a => a.IsSelected).Select(a => a.Name).ToArray();
        _model.SelectedA2AConnectionIds = _model.AvailableA2AConnections.Where(c => c.IsSelected).Select(c => c.ItemId).ToArray();
        _model.SelectedMcpConnectionIds = _model.AvailableMcpConnections.Where(c => c.IsSelected).Select(c => c.ItemId).ToArray();
    }

    private void ToggleTool(string name, bool v) { var t = _model.AvailableTools.FirstOrDefault(x => x.Name == name); if (t != null) t.IsSelected = v; }
    private void ToggleAgent(string name, bool v) { var a = _model.AvailableAgents.FirstOrDefault(x => x.Name == name); if (a != null) a.IsSelected = v; }
    private void ToggleA2A(string id, bool v) { var c = _model.AvailableA2AConnections.FirstOrDefault(x => x.ItemId == id); if (c != null) c.IsSelected = v; }
    private void ToggleMcp(string id, bool v) { var c = _model.AvailableMcpConnections.FirstOrDefault(x => x.ItemId == id); if (c != null) c.IsSelected = v; }
    private void SelectAllTools() { foreach (var t in _model.AvailableTools) t.IsSelected = true; }
    private void DeselectAllTools() { foreach (var t in _model.AvailableTools) t.IsSelected = false; }
    private void AddExtractionEntry() => _model.DataExtractionEntries.Add(new DataExtractionEntryItem());
    private void AddConversionGoal() => _model.ConversionGoals.Add(new ConversionGoalItem());
    private void AddPostSessionTask() => _model.PostSessionTasks.Add(new PostSessionTaskItem());

    private IEnumerable<IGrouping<string, PromptTemplateOptionItem>> FilteredPromptTemplateGroups =>
        _model.AvailablePromptTemplates
            .Where(template => string.IsNullOrWhiteSpace(_promptTemplateSearchTerm) ||
                template.Title.Contains(_promptTemplateSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(template.Description) && template.Description.Contains(_promptTemplateSearchTerm, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(template.Category) && template.Category.Contains(_promptTemplateSearchTerm, StringComparison.OrdinalIgnoreCase)))
            .GroupBy(template => template.Category)
            .OrderBy(group => group.Key);

    private bool HasFilteredPromptTemplates => FilteredPromptTemplateGroups.Any();

    private void AddPromptTemplate(string templateId)
    {
        if (string.IsNullOrWhiteSpace(templateId))
        {
            return;
        }

        if (_model.PromptTemplates.Any(template => string.Equals(template.TemplateId, templateId, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _model.PromptTemplates.Add(new PromptTemplateSelectionItem { TemplateId = templateId });
    }

    private void RemoveDocument(string docId)
    {
        _removedDocumentIds.Add(docId);
        _model.AttachedDocuments.RemoveAll(d => d.DocumentId == docId);
    }

    private void OnDocumentsSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(20))
        {
            if (_pendingFiles.Any(existing => HasSameFileIdentity(existing, file)))
            {
                continue;
            }

            if (_pendingFiles.Count >= 20)
            {
                break;
            }

            _pendingFiles.Add(file);
        }
    }

    private void RemovePendingFile(int index)
    {
        if (index < 0 || index >= _pendingFiles.Count)
        {
            return;
        }

        _pendingFiles.RemoveAt(index);
    }

    private async Task PopulateAttachedDocumentsAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.ItemId))
        {
            return;
        }

        var storedDocuments = await DocumentStore.GetDocumentsAsync(_model.ItemId, AIReferenceTypes.Document.Profile);
        var documentsById = (_model.AttachedDocuments ?? [])
            .Where(d => !string.IsNullOrWhiteSpace(d.DocumentId))
            .ToDictionary(d => d.DocumentId, StringComparer.OrdinalIgnoreCase);

        foreach (var document in storedDocuments)
        {
            if (string.IsNullOrWhiteSpace(document.ItemId))
            {
                continue;
            }

            documentsById[document.ItemId] = new DocumentItem
            {
                DocumentId = document.ItemId,
                FileName = document.FileName,
                ContentType = document.ContentType,
                FileSize = document.FileSize,
            };
        }

        _model.AttachedDocuments = documentsById.Values
            .OrderBy(d => d.FileName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task PopulateDropdownsAsync()
    {
        var allDeployments = await DeploymentCatalog.GetAllAsync();
        await PopulateVoiceOptionsAsync(allDeployments);
        _model.ChatDeployments = allDeployments.Where(d => d.Type.Supports(AIDeploymentType.Chat)).Select(d => new KeyValuePair<string, string>(BuildDeploymentLabel(d), d.Name)).ToList();
        _model.UtilityDeployments = allDeployments.Where(d => d.Type.Supports(AIDeploymentType.Utility) || d.Type.Supports(AIDeploymentType.Chat)).Select(d => new KeyValuePair<string, string>(BuildDeploymentLabel(d), d.Name)).ToList();

        var orchestrators = OrchestratorOpts.Value.GetOrchestratorDescriptors();
        _model.Orchestrators = orchestrators.Select(o => new KeyValuePair<string, string>(o.Value.Title ?? o.Key, o.Key)).ToList();

        var hasAnthropicOptions = ClaudeOpts.TryGetValidValue(out ClaudeOptions anthropicOptions);
        _model.ClaudeIsConfigured = hasAnthropicOptions && anthropicOptions.IsConfigured();
        if (_model.ClaudeIsConfigured)
        {
            var models = await ClaudeClientService.ListModelsAsync();
            _model.AnthropicAvailableModels = ClaudeModelSelectListFactory.Build(models, _model.ClaudeModel, anthropicOptions.DefaultModel);
        }
        else
        {
            _model.AnthropicAvailableModels = ClaudeModelSelectListFactory.Build([], _model.ClaudeModel, anthropicOptions?.DefaultModel);
        }

        var hasCopilotOptions = CopilotOpts.TryGetValidValue(out CopilotOptions copilotOptions);
        _model.CopilotIsConfigured = hasCopilotOptions && copilotOptions.AuthenticationType switch
        {
            CopilotAuthenticationType.GitHubOAuth => !string.IsNullOrWhiteSpace(copilotOptions.ClientId) && !string.IsNullOrWhiteSpace(copilotOptions.ClientSecret),
            CopilotAuthenticationType.ApiKey => !string.IsNullOrWhiteSpace(copilotOptions.ProviderType) && !string.IsNullOrWhiteSpace(copilotOptions.BaseUrl) && !string.IsNullOrWhiteSpace(copilotOptions.DefaultModel),
            _ => false,
        };
        _model.CopilotAuthenticationType = hasCopilotOptions ? (int)copilotOptions.AuthenticationType : 0;

        var toolOptions = ToolOpts.Value;
        var selectedNames = new HashSet<string>(_model.SelectedToolNames ?? [], StringComparer.OrdinalIgnoreCase);
        _model.AvailableTools = toolOptions.Tools.Where(kvp => !kvp.Value.IsSystemTool)
            .Select(kvp => new ToolSelectionItem { Name = kvp.Key, Title = kvp.Value.Title ?? kvp.Key, Description = kvp.Value.Description, Category = kvp.Value.Category ?? "Miscellaneous", IsSelected = selectedNames.Contains(kvp.Key) })
            .OrderBy(t => t.Category).ThenBy(t => t.Title).ToList();

        var connections = await A2ACatalog.GetAllAsync();
        var selectedConnectionIds = new HashSet<string>(_model.SelectedA2AConnectionIds ?? [], StringComparer.Ordinal);
        _model.AvailableA2AConnections = connections.OrderBy(c => c.DisplayText, StringComparer.OrdinalIgnoreCase)
            .Select(c => new A2AConnectionSelectionItem { ItemId = c.ItemId, DisplayText = c.DisplayText, Endpoint = c.Endpoint, IsSelected = selectedConnectionIds.Contains(c.ItemId) }).ToList();

        var mcpConnections = await McpCatalog.GetAllAsync();
        var selectedMcpIds = new HashSet<string>(_model.SelectedMcpConnectionIds ?? [], StringComparer.Ordinal);
        _model.AvailableMcpConnections = mcpConnections.OrderBy(c => c.DisplayText, StringComparer.OrdinalIgnoreCase)
            .Select(c => new McpConnectionSelectionItem { ItemId = c.ItemId, DisplayText = c.DisplayText, Source = c.Source, IsSelected = selectedMcpIds.Contains(c.ItemId) }).ToList();

        var allAgents = await ProfileManager.GetAsync(AIProfileType.Agent) ?? [];
        var selectedAgentNames = new HashSet<string>(_model.SelectedAgentNames ?? [], StringComparer.OrdinalIgnoreCase);
        _model.AvailableAgents = allAgents.Where(a => !string.IsNullOrEmpty(a.Description)).OrderBy(a => a.DisplayText ?? a.Name, StringComparer.OrdinalIgnoreCase)
            .Select(a => new AgentSelectionItem { Name = a.Name, DisplayText = a.DisplayText ?? a.Name, Description = a.Description, IsSelected = selectedAgentNames.Contains(a.Name) }).ToList();

        var allDataSources = await DataSourceStore.GetAllAsync();
        _model.DataSources = allDataSources.OrderBy(ds => ds.DisplayText, StringComparer.OrdinalIgnoreCase).Select(ds => new KeyValuePair<string, string>(ds.DisplayText, ds.ItemId)).ToList();

        var documentSettings = DocOpts.CurrentValue;
        _model.DocumentIndexProfileName = documentSettings.IndexProfileName;
        if (!string.IsNullOrWhiteSpace(documentSettings.IndexProfileName))
        {
            var indexProfile = await IndexProfileStore.FindByNameAsync(documentSettings.IndexProfileName);
            _model.HasDocumentIndexConfiguration = indexProfile != null && string.Equals(indexProfile.Type, IndexProfileTypes.AIDocuments, StringComparison.OrdinalIgnoreCase);
        }

        _supportedExtensionsAccept = ChatDocumentOptions.Value.GetEmbeddableFileExtensionsAcceptValue();
        _supportedExtensionsDisplay = ChatDocumentOptions.Value.GetEmbeddableFileExtensionsDisplayValue();
        _model.AvailableSystemPromptTemplates = (await TemplateService.GetByKindAsync(AITemplateSources.SystemPrompt))
            .Where(template => template.Metadata.IsListable)
            .OrderBy(template => template.Metadata.Title ?? template.Id, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var promptTemplates = await TemplateService.GetByKindAsync(AITemplateSources.SystemPrompt);
        _model.AvailablePromptTemplates = promptTemplates.Where(t => t.Metadata.IsListable)
            .OrderBy(t => t.Metadata.Category ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            .ThenBy(t => t.Metadata.Title ?? t.Id, StringComparer.OrdinalIgnoreCase)
            .Select(t => new PromptTemplateOptionItem { TemplateId = t.Id, Title = t.Metadata.Title ?? t.Id, Description = t.Metadata.Description, Category = t.Metadata.Category ?? "General", Parameters = (t.Metadata.Parameters ?? []).Select(p => new PromptTemplateParameterItem { Name = p.Name, Description = p.Description }).ToList() }).ToList();
    }

    private async Task<string[]> GetValidA2AConnectionIdsAsync(IEnumerable<string> selectedIds)
    {
        var allIds = (await A2ACatalog.GetAllAsync()).Select(c => c.ItemId).ToHashSet(StringComparer.Ordinal);

        return (selectedIds ?? []).Where(id => !string.IsNullOrWhiteSpace(id) && allIds.Contains(id)).Distinct(StringComparer.Ordinal).ToArray();
    }

    private async Task<string[]> GetValidMcpConnectionIdsAsync(IEnumerable<string> selectedIds)
    {
        var allIds = (await McpCatalog.GetAllAsync()).Select(c => c.ItemId).ToHashSet(StringComparer.Ordinal);

        return (selectedIds ?? []).Where(id => !string.IsNullOrWhiteSpace(id) && allIds.Contains(id)).Distinct(StringComparer.Ordinal).ToArray();
    }

    private async Task PopulateVoiceOptionsAsync(IEnumerable<AIDeployment> deployments)
    {
        _availableVoices = [];

        var deploymentDefaults = SiteSettingsStore.Get<DefaultAIDeploymentSettings>();
        if (string.IsNullOrWhiteSpace(deploymentDefaults.DefaultTextToSpeechDeploymentName))
        {
            return;
        }

        var deployment = deployments.FirstOrDefault(d => string.Equals(d.Name, deploymentDefaults.DefaultTextToSpeechDeploymentName, StringComparison.OrdinalIgnoreCase));
        if (deployment == null)
        {
            return;
        }

        _availableVoices = (await SpeechVoiceResolver.GetSpeechVoicesAsync(deployment))
            .Where(voice => !string.IsNullOrWhiteSpace(voice.Id))
            .OrderBy(voice => GetVoiceGroupLabel(voice), StringComparer.OrdinalIgnoreCase)
            .ThenBy(voice => voice.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string GetVoiceGroupLabel(SpeechVoice voice)
    {
        var displayName = SpeechVoiceLocalizationHelper.GetCultureDisplayName(voice.Language);

        return string.IsNullOrWhiteSpace(displayName) ? "Other" : displayName;
    }

    private static string BuildDeploymentLabel(AIDeployment d) =>
        string.Equals(d.Name, d.ModelName, StringComparison.OrdinalIgnoreCase) ? d.Name : $"{d.Name} ({d.ModelName})";

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1048576) return $"{bytes / 1024.0:F1} KB";

        return $"{bytes / 1048576.0:F1} MB";
    }

    private static bool HasSameFileIdentity(Microsoft.AspNetCore.Components.Forms.IBrowserFile left, Microsoft.AspNetCore.Components.Forms.IBrowserFile right) =>
        string.Equals(left.Name, right.Name, StringComparison.OrdinalIgnoreCase) && left.Size == right.Size;

    private void OnProfileTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<AIProfileType>(e.Value?.ToString(), out var value))
        {
            _model.Type = value;
        }
    }

    private void OnOrchestratorChanged(ChangeEventArgs e)
    {
        _model.OrchestratorName = e.Value?.ToString();
    }
}

