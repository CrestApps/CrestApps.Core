@page "/ai/profiles"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.AI.Chat
@using CrestApps.Core.Services
@inject IAIProfileManager ProfileManager
@inject IAIChatSessionManager SessionManager
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>AI Profiles - Blazor AI Integration Sample</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-gear"></i> AI Profiles</h2>
    <a href="/ai/profiles/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Profile
    </a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
    </div>
}

@if (_profiles == null)
{
    <p><em>Loading...</em></p>
}
else if (_profiles.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI profiles found. Create your first profile to get started.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th style="width: 110px;">Type</th>
                    <th style="width: 430px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var profile in _profiles)
                {
                    <tr>
                        <td><strong>@(profile.DisplayText ?? profile.Name)</strong></td>
                        <td>@profile.Name</td>
                        <td>
                            <span class="badge @(profile.Type == AIProfileType.Chat ? "bg-primary" : "bg-secondary")">
                                @profile.Type
                            </span>
                        </td>
                        <td>
                            <div class="d-flex flex-nowrap gap-2">
                            @if (profile.Type == AIProfileType.Chat)
                            {
                                <button type="button" class="btn btn-sm btn-outline-success" title="Start a new chat session" @onclick="() => StartNewChatAsync(profile)">
                                    <i class="bi bi-chat-dots"></i> New Chat
                                </button>
                                <a href="/ai-chat/sessions/@profile.ItemId" class="btn btn-sm btn-outline-info" title="View chat history">
                                    <i class="bi bi-clock-history"></i> Chat History
                                </a>
                            }
                            else if (profile.Type == AIProfileType.Utility || profile.Type == AIProfileType.Agent)
                            {
                                <a href="/ai-chat/test/@profile.ItemId" class="btn btn-sm btn-outline-success" title="Test this profile">
                                    <i class="bi bi-play-circle"></i> Test
                                </a>
                            }

                            <a href="/ai/profiles/edit/@profile.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(profile.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AIProfile> _profiles;
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfilesAsync();
    }

    private async Task LoadProfilesAsync()
    {
        var profiles = await ProfileManager.GetAllAsync();

        _profiles = profiles
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this profile?");
        if (!confirmed)
        {
            return;
        }

        var profile = await ProfileManager.FindByIdAsync(id);
        if (profile == null)
        {
            _errorMessage = "Profile not found.";

            return;
        }

        await ProfileManager.DeleteAsync(profile);
        await StoreCommitter.CommitAsync();
        await LoadProfilesAsync();
    }

    private async Task StartNewChatAsync(AIProfile profile)
    {
        var session = await SessionManager.NewAsync(profile, new NewAIChatSessionContext());
        session.Title = profile.DisplayText ?? profile.Name;
        await SessionManager.SaveAsync(session);
        await StoreCommitter.CommitAsync();

        Navigation.NavigateTo($"/ai-chat/chat/{session.SessionId}");
    }
}
