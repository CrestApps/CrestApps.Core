@page "/AI/Connections"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Services
@using CrestApps.Core.Services
@inject INamedSourceCatalog<AIProviderConnection> ConnectionCatalog
@inject NavigationManager NavigationManager

<PageTitle>AI Connections</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-plug"></i> AI Connections</h2>
    <a href="/AI/Connections/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Connection
    </a>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Connections is null)
{
    <p><em>Loading...</em></p>
}
else if (!Connections.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI connections found. Create a connection to link AI providers.
    </div>
}
else
{
    var userDefined = Connections.Where(c => !AIConfigurationRecordIds.IsConfigurationConnectionId(c.ItemId)).ToList();
    var configured = Connections.Where(c => AIConfigurationRecordIds.IsConfigurationConnectionId(c.ItemId)).ToList();

    @if (userDefined.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">User-defined connections</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Technical Name</th>
                                <th>Provider</th>
                                <th style="width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in userDefined)
                            {
                                <tr>
                                    <td><strong>@(connection.DisplayText ?? connection.Name)</strong></td>
                                    <td><code>@connection.Name</code></td>
                                    <td>
                                        <span class="badge bg-info">@(connection.Source ?? "—")</span>
                                    </td>
                                    <td>
                                        <a href="/AI/Connections/Edit/@connection.ItemId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(connection.ItemId)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (configured.Count > 0)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">System configuration connections</h5>
                <span class="badge bg-secondary">Read-only</span>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">These connections come from system configuration and cannot be edited or deleted from the UI.</p>
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Technical Name</th>
                                <th>Provider</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in configured)
                            {
                                <tr>
                                    <td><strong>@(connection.DisplayText ?? connection.Name)</strong></td>
                                    <td><code>@connection.Name</code></td>
                                    <td>
                                        <span class="badge bg-info">@(connection.Source ?? "—")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this connection?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyCollection<AIProviderConnection>? Connections;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessQueryParam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SuccessQueryParam))
        {
            SuccessMessage = SuccessQueryParam;
        }

        await LoadConnectionsAsync();
    }

    private async Task LoadConnectionsAsync()
    {
        var all = await ConnectionCatalog.GetAllAsync();
        Connections = all
            .OrderBy(c => c.DisplayText ?? c.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            if (AIConfigurationRecordIds.IsConfigurationConnectionId(DeleteTargetId))
            {
                ErrorMessage = "Connections defined in appsettings are read-only and cannot be deleted from the UI.";
            }
            else
            {
                var connection = await ConnectionCatalog.FindByIdAsync(DeleteTargetId);
                if (connection != null)
                {
                    await ConnectionCatalog.DeleteAsync(connection);
                    SuccessMessage = "Connection deleted successfully.";
                }
            }
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        await LoadConnectionsAsync();
    }
}
