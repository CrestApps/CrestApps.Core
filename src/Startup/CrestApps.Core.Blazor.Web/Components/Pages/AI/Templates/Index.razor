@page "/AI/Templates"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.Services
@inject ICatalog<AIProfileTemplate> Catalog
@inject NavigationManager NavigationManager

<PageTitle>Templates</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-text"></i> Templates</h2>
    <a href="/AI/Templates/Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Template
    </a>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Templates is null)
{
    <p><em>Loading...</em></p>
}
else if (!Templates.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No templates configured yet.
        <a href="/AI/Templates/Create">Create your first template</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Source</th>
                    <th>Category</th>
                    <th>Listable</th>
                    <th style="min-width: 190px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var template in Templates)
                {
                    <tr>
                        <td>
                            <a href="/AI/Templates/Edit/@template.ItemId" class="text-decoration-none fw-semibold">
                                @(template.DisplayText ?? template.Name)
                            </a>
                        </td>
                        <td><code>@template.Name</code></td>
                        <td>
                            <span class="badge @(template.Source == "SystemPrompt" ? "bg-info" : "bg-success")">
                                @template.Source
                            </span>
                        </td>
                        <td>@(template.Category ?? "—")</td>
                        <td>
                            @if (template.IsListable)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <div class="d-inline-flex flex-nowrap gap-2">
                                <a href="/AI/Templates/Edit/@template.ItemId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => ConfirmDelete(template.ItemId)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this template?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private IReadOnlyCollection<AIProfileTemplate>? Templates;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    protected override async Task OnInitializedAsync()
    {
        Templates = await Catalog.GetAllAsync();
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            var template = await Catalog.FindByIdAsync(DeleteTargetId);
            if (template is not null)
            {
                await Catalog.DeleteAsync(template);
            }
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        SuccessMessage = "Template deleted successfully.";
        Templates = await Catalog.GetAllAsync();
    }
}
