@page "/ai/connections"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Services
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Services
@inject INamedSourceCatalog<AIProviderConnection> Catalog
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>AI Connections - Blazor AI Integration Sample</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-plug"></i> AI Connections</h2>
    <a href="/ai/connections/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Create New Connection
    </a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
    </div>
}

@if (_connections == null)
{
    <p><em>Loading...</em></p>
}
else if (_connections.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No AI connections found. Create a connection to link AI providers.
    </div>
}
else
{
    if (_userDefinedConnections.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">User-defined connections</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Technical Name</th>
                                <th>Provider</th>
                                <th style="width: 180px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in _userDefinedConnections)
                            {
                                <tr>
                                    <td><strong>@(connection.DisplayText ?? connection.Name)</strong></td>
                                    <td><code>@connection.Name</code></td>
                                    <td>
                                        <span class="badge bg-info">@(connection.Source ?? "—")</span>
                                    </td>
                                    <td>
                                        <a href="/ai/connections/edit/@connection.ItemId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(connection.ItemId)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    if (_configuredConnections.Count > 0)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">System configuration connections</h5>
                <span class="badge bg-secondary">Read-only</span>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">These connections come from system configuration and cannot be edited or deleted from the UI.</p>
                <div class="table-responsive mb-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Technical Name</th>
                                <th>Provider</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var connection in _configuredConnections)
                            {
                                <tr>
                                    <td><strong>@(connection.DisplayText ?? connection.Name)</strong></td>
                                    <td><code>@connection.Name</code></td>
                                    <td>
                                        <span class="badge bg-info">@(connection.Source ?? "—")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<AIConnectionViewModel> _connections;
    private List<AIConnectionViewModel> _userDefinedConnections = [];
    private List<AIConnectionViewModel> _configuredConnections = [];
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadConnectionsAsync();
    }

    private async Task LoadConnectionsAsync()
    {
        var connections = await Catalog.GetAllAsync();

        _connections = connections
            .Select(connection =>
            {
                var model = AIConnectionViewModel.FromConnection(connection);
                model.IsReadOnly = AIConfigurationRecordIds.IsConfigurationConnectionId(connection.ItemId);

                return model;
            })
            .OrderBy(static model => model.DisplayText ?? model.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _userDefinedConnections = _connections.Where(static c => !c.IsReadOnly).ToList();
        _configuredConnections = _connections.Where(static c => c.IsReadOnly).ToList();
    }

    private async Task DeleteAsync(string id)
    {
        if (AIConfigurationRecordIds.IsConfigurationConnectionId(id))
        {
            _errorMessage = "Connections defined in appsettings are read-only and cannot be deleted from the UI.";

            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this connection?");

        if (!confirmed)
        {
            return;
        }

        var connection = await Catalog.FindByIdAsync(id);
        if (connection == null)
        {
            _errorMessage = "Connection not found.";

            return;
        }

        if (AIConfigurationRecordIds.IsConfigurationConnectionId(connection.ItemId))
        {
            _errorMessage = "Connections defined in appsettings are read-only and cannot be deleted from the UI.";

            return;
        }

        await Catalog.DeleteAsync(connection);
        await StoreCommitter.CommitAsync();
        await LoadConnectionsAsync();
    }
}
