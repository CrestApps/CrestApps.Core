@page "/ai/templates"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Models
@using CrestApps.Core.Services
@inject ICatalog<AIProfileTemplate> Catalog
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Templates - CrestApps AI</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-file-earmark-text"></i> Templates</h2>
    <a href="/ai/templates/create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Template
    </a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
    </div>
}

@if (_templates == null)
{
    <p><em>Loading...</em></p>
}
else if (_templates.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No templates configured yet.
        <a href="/ai/templates/create">Create your first template</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Source</th>
                    <th>Category</th>
                    <th>Listable</th>
                    <th style="min-width: 190px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var template in _templates)
                {
                    <tr>
                        <td>
                            <a href="/ai/templates/edit/@template.ItemId" class="text-decoration-none fw-semibold">
                                @(template.DisplayText ?? template.Name)
                            </a>
                        </td>
                        <td><code>@template.Name</code></td>
                        <td>
                            <span class="badge @(template.Source == "SystemPrompt" ? "bg-info" : "bg-success")">
                                @template.Source
                            </span>
                        </td>
                        <td>@(template.Category ?? "—")</td>
                        <td>
                            @if (template.IsListable)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <div class="d-inline-flex flex-nowrap gap-2">
                                <a href="/ai/templates/edit/@template.ItemId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(template.ItemId)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AIProfileTemplate> _templates;
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadTemplatesAsync();
    }

    private async Task LoadTemplatesAsync()
    {
        var templates = await Catalog.GetAllAsync();

        _templates = templates
            .OrderBy(t => t.DisplayText ?? t.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this template?");

        if (!confirmed)
        {
            return;
        }

        var template = await Catalog.FindByIdAsync(id);
        if (template == null)
        {
            _errorMessage = "Template not found.";

            return;
        }

        await Catalog.DeleteAsync(template);
        await StoreCommitter.CommitAsync();
        await LoadTemplatesAsync();
    }
}
