@page "/ChatInteractions/Edit/{Id}"
@attribute [Authorize(Policy = "Admin")]
@inject NavigationManager NavigationManager

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Editing happens inline on the Chat page via the settings sidebar.
        // Redirect to the Chat page if an ID is provided, otherwise to Index.
        if (!string.IsNullOrEmpty(Id))
        {
            NavigationManager.NavigateTo($"/ChatInteractions/Chat/{Id}", replace: true);
        }
        else
        {
            NavigationManager.NavigateTo("/ChatInteractions", replace: true);
        }
    }
}
