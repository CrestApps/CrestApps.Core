@page "/ChatInteractions"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Chat
@using CrestApps.Core.Services
@inject ICatalogManager<ChatInteraction> InteractionManager
@inject IChatInteractionPromptStore PromptStore
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Chat Interactions</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-chat-left-dots"></i> Chat Interactions</h2>
    <button type="button" class="btn btn-success" @onclick="CreateNewChat" disabled="@_isCreating">
        <i class="bi bi-plus-lg"></i> New Chat
    </button>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Interactions is null)
{
    <p><em>Loading...</em></p>
}
else if (!Interactions.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No chat interactions yet. Create one to start chatting with AI using custom parameters.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Created</th>
                    <th style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var interaction in Interactions)
                {
                    <tr>
                        <td>
                            <a href="/ChatInteractions/Chat/@interaction.ItemId" class="text-decoration-none">
                                <strong>@(interaction.Title ?? "Untitled Chat")</strong>
                            </a>
                        </td>
                        <td>
                            <small class="text-muted">@interaction.CreatedUtc.ToString("g")</small>
                        </td>
                        <td>
                            <a href="/ChatInteractions/Chat/@interaction.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-chat-left-text"></i> Chat
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(interaction.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this chat interaction and all its history?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private IReadOnlyList<ChatInteraction>? Interactions;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;
    private bool _isCreating;

    protected override async Task OnInitializedAsync()
    {
        await LoadInteractionsAsync();
    }

    private async Task CreateNewChat()
    {
        if (_isCreating) return;
        _isCreating = true;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "anonymous";

            var interaction = await InteractionManager.NewAsync();
            interaction.Title = "Untitled Chat";
            interaction.OwnerId = userName;
            interaction.Author = userName;
            interaction.CreatedUtc = DateTime.UtcNow;
            await InteractionManager.CreateAsync(interaction);
            NavigationManager.NavigateTo($"/ChatInteractions/Chat/{interaction.ItemId}");
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task LoadInteractionsAsync()
    {
        var all = await InteractionManager.GetAllAsync();
        Interactions = all.OrderByDescending(i => i.CreatedUtc).ToList();
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            var interaction = await InteractionManager.FindByIdAsync(DeleteTargetId);
            if (interaction is not null)
            {
                await PromptStore.DeleteAllPromptsAsync(DeleteTargetId);
                await InteractionManager.DeleteAsync(interaction);
            }
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        SuccessMessage = "Chat interaction deleted successfully.";
        await LoadInteractionsAsync();
    }
}
