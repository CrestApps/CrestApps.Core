@page "/chat-interactions/create"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI
@using CrestApps.Core.AI.A2A.Models
@using CrestApps.Core.AI.Chat
@using CrestApps.Core.AI.Claude.Models
@using CrestApps.Core.AI.Claude.Services
@using CrestApps.Core.AI.Copilot.Models
@using CrestApps.Core.AI.Copilot.Services
@using CrestApps.Core.AI.Deployments
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Orchestration
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.AI.Tooling
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Infrastructure.Indexing
@using CrestApps.Core.Services
@using CrestApps.Core.Templates.Services
@using Microsoft.Extensions.Options
@inject ICatalogManager<ChatInteraction> InteractionManager
@inject ICatalog<AIDeployment> DeploymentCatalog
@inject ICatalog<A2AConnection> A2AConnectionCatalog
@inject ICatalog<McpConnection> McpConnectionCatalog
@inject ICatalog<AIDataSource> DataSourceCatalog
@inject IAIProfileManager ProfileManager
@inject IAIProfileTemplateManager TemplateManager
@inject ITemplateService TemplateService
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject SiteSettingsStore SiteSettingsStore
@inject IOptions<OrchestratorOptions> OrchestratorOptionsAccessor
@inject IOptions<AIToolDefinitionOptions> ToolOptionsAccessor
@inject IOptionsSnapshot<ClaudeOptions> ClaudeOptionsAccessor
@inject ClaudeClientService ClaudeClientService
@inject IOptions<CopilotOptions> CopilotOptionsAccessor
@inject ISearchIndexProfileStore IndexProfileStore

<PageTitle>New Chat Interaction - Blazor AI Integration Sample</PageTitle>

<h2><i class="bi bi-plus-lg"></i> New Chat Interaction</h2>
<hr />
<p class="text-muted">Configure AI parameters and start chatting. Unlike AI Profile chat, you can fully customize the behavior here.</p>

<EditForm FormName="chatinteractions-create" Model="_model" OnValidSubmit="HandleSubmitAsync">
    <div class="row">
        <div class="col-md-8">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "settings" ? "active" : "")" @onclick='() => _activeTab = "settings"'>Settings</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "kb" ? "active" : "")" @onclick='() => _activeTab = "kb"'>Knowledge</button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(_activeTab == "capabilities" ? "active" : "")" @onclick='() => _activeTab = "capabilities"'>Capabilities</button>
                </li>
            </ul>

            <div class="p-3 border border-top-0 rounded-bottom">
                @if (_activeTab == "settings")
                {
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <InputText id="title" class="form-control" @bind-Value="_model.Title" placeholder="e.g., Code Helper, Creative Writer" />
                        <div class="form-text">An optional title for this chat interaction.</div>
                    </div>

                    <div class="mb-3">
                        <label for="deployment" class="form-label">Deployment</label>
                        <InputSelect id="deployment" class="form-select" @bind-Value="_model.ChatDeploymentName">
                            <option value="">Select deployment</option>
                            @foreach (var d in _model.Deployments)
                            {
                                <option value="@d.Value">@d.Text</option>
                            }
                        </InputSelect>
                        <div class="form-text">The AI model deployment to use for this chat.</div>
                    </div>

                    <div class="mb-3">
                        <label for="orchestrator" class="form-label">Orchestrator</label>
                        <InputSelect id="orchestrator" class="form-select" @bind-Value="_model.OrchestratorName">
                            <option value="">Use default orchestrator</option>
                            @foreach (var o in _model.Orchestrators)
                            {
                                <option value="@o.Value">@o.Text</option>
                            }
                        </InputSelect>
                        <div class="form-text">The orchestrator that manages AI interactions.</div>
                    </div>

                    @if (_model.AvailablePromptTemplates.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                Prompt templates
                                <span class="text-muted" data-bs-toggle="tooltip" title="Add one or more reusable prompt templates that will be rendered in order before the custom system instructions.">
                                    <i class="bi bi-question-circle" aria-hidden="true"></i>
                                </span>
                            </label>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (_model.AvailablePromptTemplates.Count > 0)
                                {
                                    <div class="dropdown w-100">
                                        <button class="btn btn-outline-primary dropdown-toggle w-100 d-flex justify-content-center align-items-center gap-1" type="button" id="addPromptTemplateBtn" data-bs-toggle="dropdown" aria-expanded="false">
                                            <span aria-hidden="true">+</span> Add template
                                        </button>
                                        <div class="dropdown-menu p-2" style="max-height:24rem;min-width:22rem;overflow-y:auto;">
                                            <div class="mb-2" @onclick:stopPropagation="true">
                                                <input type="search"
                                                       class="form-control form-control-sm"
                                                       @bind="_promptTemplateSearchTerm"
                                                       @bind:event="oninput"
                                                       placeholder="Search prompt templates..." />
                                            </div>
                                            <div class="prompt-template-menu-items">
                                                @foreach (var group in FilteredPromptTemplateGroups)
                                                {
                                                    <div class="dropdown-header px-2">@group.Key</div>
                                                    @foreach (var option in group)
                                                    {
                                                        <button type="button"
                                                                class="dropdown-item text-wrap"
                                                                @onclick="() => AddPromptTemplate(option.TemplateId)">
                                                            <span class="d-block fw-semibold">@option.Title</span>
                                                            @if (!string.IsNullOrWhiteSpace(option.Description))
                                                            {
                                                                <small class="text-muted">@option.Description</small>
                                                            }
                                                        </button>
                                                    }
                                                }
                                            </div>
                                            @if (!HasFilteredPromptTemplates)
                                            {
                                                <div class="text-muted small px-2 py-1">No prompt templates match your search.</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="form-text mb-3">Use prompt templates to prepend reusable rendered content before the custom system instructions.</div>
                            @if (_model.PromptTemplates.Count > 0)
                            {
                                @for (var i = 0; i < _model.PromptTemplates.Count; i++)
                                {
                                    var index = i;
                                    var selection = _model.PromptTemplates[index];
                                    var option = _model.AvailablePromptTemplates.FirstOrDefault(t => string.Equals(t.TemplateId, selection.TemplateId, StringComparison.OrdinalIgnoreCase));
                                    var title = option?.Title ?? selection.TemplateId ?? "Prompt template";
                                    var category = option?.Category ?? "Unavailable";
                                    var description = option?.Description;
                                    var parameters = option?.Parameters ?? [];
                                    var collapseId = $"promptCollapse_{index}";

                                    <div class="card mb-1" data-template-id="@selection.TemplateId">
                                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                                            <button type="button" class="btn btn-sm btn-link text-start text-decoration-none flex-grow-1 px-0" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false">
                                                <i class="bi bi-chevron-right me-1"></i>
                                                <span class="fw-semibold">@title</span>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => _model.PromptTemplates.RemoveAt(index)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        <div id="@collapseId" class="collapse">
                                            <div class="card-body">
                                                <div class="d-flex flex-wrap gap-2 mb-2">
                                                    <span class="badge text-bg-secondary">@category</span>
                                                    @if (option == null)
                                                    {
                                                        <span class="badge text-bg-warning">Unavailable</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(description))
                                                {
                                                    <div class="text-muted small mb-3">@description</div>
                                                }
                                                @if (parameters.Count > 0)
                                                {
                                                    <div class="mb-3">
                                                        <small class="text-muted d-block mb-1">Expected parameters:</small>
                                                        <ul class="mb-0 small text-muted">
                                                            @foreach (var p in parameters)
                                                            {
                                                                <li><strong>@p.Name</strong>@(string.IsNullOrWhiteSpace(p.Description) ? "" : $": {p.Description}")</li>
                                                            }
                                                        </ul>
                                                    </div>
                                                }
                                                <div class="mb-1">
                                                    <label class="form-label">Template parameters</label>
                                                    <InputTextArea class="form-control" rows="3" @bind-Value="selection.PromptParameters"
                                                                   placeholder='e.g., {"key1": "value1", "key2": "value2"}' />
                                                    <span class="form-text">Optional JSON key-value pairs to pass as template arguments.</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small">No prompt templates selected.</div>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        <label for="systemMessage" class="form-label">System message</label>
                        <InputTextArea id="systemMessage" class="form-control" rows="4" @bind-Value="_model.SystemMessage" placeholder="You are a helpful assistant..." />
                        <div class="form-text">Instructions for the AI on how to behave.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="maxTokens" class="form-label">Max tokens</label>
                            <InputNumber id="maxTokens" class="form-control" @bind-Value="_model.MaxTokens" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="temperature" class="form-label">Temperature</label>
                            <InputNumber id="temperature" class="form-control" @bind-Value="_model.Temperature" min="0" max="2" step="0.1" placeholder="0.7" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="topP" class="form-label">Top P</label>
                            <InputNumber id="topP" class="form-control" @bind-Value="_model.TopP" min="0" max="1" step="0.1" placeholder="1.0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="frequencyPenalty" class="form-label">Frequency penalty</label>
                            <InputNumber id="frequencyPenalty" class="form-control" @bind-Value="_model.FrequencyPenalty" min="-2" max="2" step="0.1" placeholder="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="presencePenalty" class="form-label">Presence penalty</label>
                            <InputNumber id="presencePenalty" class="form-control" @bind-Value="_model.PresencePenalty" min="-2" max="2" step="0.1" placeholder="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="pastMessages" class="form-label">Past messages</label>
                            <InputNumber id="pastMessages" class="form-control" @bind-Value="_model.PastMessagesCount" min="0" placeholder="10" />
                        </div>
                    </div>
                }
                else if (_activeTab == "capabilities")
                {
                    <!-- AI Agents -->
                    <h6 class="mb-2 border-bottom pb-2"><i class="bi bi-robot"></i> AI Agents</h6>
                    @if (_model.AvailableAgents.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No AI agent profiles are available. Create agent-type AI profiles first.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the AI agents this interaction can delegate tasks to.</p>
                        @foreach (var agent in _model.AvailableAgents)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="agent_@agent.Name" checked="@agent.IsSelected"
                                       @onchange="(e) => agent.IsSelected = (bool)e.Value" />
                                <label class="form-check-label" for="agent_@agent.Name">
                                    <strong>@agent.DisplayText</strong>
                                </label>
                            </div>
                        }
                    }

                    <!-- AI Tools -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-tools"></i> AI Tools</h6>
                    @if (_model.AvailableTools.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No selectable AI tools are registered.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <p class="text-muted mb-0 small">Select the tools this interaction can use during conversations.</p>
                            <div class="btn-group btn-group-sm ms-3" role="group">
                                <button type="button" class="btn btn-outline-primary" @onclick="SelectAllTools"><i class="bi bi-check-all"></i> Select all</button>
                                <button type="button" class="btn btn-outline-secondary" @onclick="DeselectAllTools"><i class="bi bi-x-lg"></i> Deselect all</button>
                            </div>
                        </div>
                        @foreach (var group in _model.AvailableTools.GroupBy(t => t.Category).OrderBy(g => g.Key))
                        {
                            <h6 class="text-secondary mt-3 mb-2"><i class="bi bi-folder"></i> @group.Key</h6>
                            @foreach (var tool in group)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="tool_@tool.Name" checked="@tool.IsSelected"
                                           @onchange="(e) => tool.IsSelected = (bool)e.Value" />
                                    <label class="form-check-label" for="tool_@tool.Name">
                                        <strong>@tool.Title</strong>
                                        @if (!string.IsNullOrEmpty(tool.Description))
                                        {
                                            <br /><small class="text-muted">@tool.Description</small>
                                        }
                                    </label>
                                </div>
                            }
                        }
                    }

                    <!-- A2A Connections -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h6>
                    @if (_model.AvailableA2AConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle"></i> No A2A host connections are configured.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the remote A2A hosts this interaction can use for agent orchestration.</p>
                        @foreach (var connection in _model.AvailableA2AConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="a2a_@connection.ItemId" checked="@connection.IsSelected"
                                       @onchange="(e) => connection.IsSelected = (bool)e.Value" />
                                <label class="form-check-label" for="a2a_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong><br />
                                    <small class="text-muted">@connection.Endpoint</small>
                                </label>
                            </div>
                        }
                    }

                    <!-- MCP Hosts -->
                    <h6 class="mb-2 mt-4 border-bottom pb-2"><i class="bi bi-plug"></i> MCP Hosts</h6>
                    @if (_model.AvailableMcpConnections.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> No MCP host connections are configured.
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3 small">Select the MCP hosts this interaction can use for external tools and resources.</p>
                        @foreach (var connection in _model.AvailableMcpConnections)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="mcp_@connection.ItemId" checked="@connection.IsSelected"
                                       @onchange="(e) => connection.IsSelected = (bool)e.Value" />
                                <label class="form-check-label" for="mcp_@connection.ItemId">
                                    <strong>@connection.DisplayText</strong>
                                    @if (!string.IsNullOrEmpty(connection.Source))
                                    {
                                        <br /><small class="text-muted">@connection.Source</small>
                                    }
                                </label>
                            </div>
                        }
                    }
                }
                else if (_activeTab == "kb")
                {
                    <div class="mb-3">
                        <label for="dataSource" class="form-label">Data source</label>
                        <InputSelect id="dataSource" class="form-select" @bind-Value="_model.DataSourceId">
                            <option value="">None</option>
                            @foreach (var ds in _model.DataSources)
                            {
                                <option value="@ds.Value">@ds.Text</option>
                            }
                        </InputSelect>
                        <div class="form-text">Select a RAG data source to provide background knowledge for this interaction.</div>
                    </div>

                    <div class="mb-3">
                        <label for="dataSourceFilter" class="form-label">Filter</label>
                        <InputText id="dataSourceFilter" class="form-control" @bind-Value="_model.DataSourceFilter" placeholder="Optional provider-specific filter" />
                        <div class="form-text">Optional filter expression passed to the configured data source provider.</div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <InputCheckbox id="dataSourceInScope" class="form-check-input" @bind-Value="_model.DataSourceIsInScope" />
                            <label for="dataSourceInScope" class="form-check-label">Restrict answers to retrieved data only</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="documentRetrievalMode" class="form-label">Document retrieval mode</label>
                        <InputSelect id="documentRetrievalMode" class="form-select" @bind-Value="_model.DocumentRetrievalMode">
                            <option value="">Use site default</option>
                            @foreach (var mode in Enum.GetValues<DocumentRetrievalMode>())
                            {
                                <option value="@mode">@mode</option>
                            }
                        </InputSelect>
                        <div class="form-text">Overrides the site default when this interaction searches uploaded document knowledge.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="strictness" class="form-label">Strictness</label>
                            <InputNumber id="strictness" class="form-control" @bind-Value="_model.DataSourceStrictness" />
                            <div class="form-text">Controls how strictly the AI should follow retrieved data-source matches.</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="topNDocs" class="form-label">Retrieved documents</label>
                            <InputNumber id="topNDocs" class="form-control" @bind-Value="_model.DataSourceTopNDocuments" />
                            <div class="form-text">Number of documents retrieved for context.</div>
                        </div>
                    </div>

                    @if (_model.HasDocumentIndexConfiguration)
                    {
                        <h6 class="mt-3 mb-2"><i class="bi bi-paperclip"></i> Attach Documents</h6>
                        <div class="mb-3">
                            <label class="form-label">Upload documents</label>
                            <InputFile class="form-control" OnChange="OnDocumentsSelected" multiple />
                            <div class="form-text">Upload documents to be indexed for this interaction.</div>
                        </div>
                    }
                }
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-chat-left-text"></i> Create &amp; Start Chat
                </button>
                <a href="/chat-interactions" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private ChatInteractionViewModel _model = new();
    private string _activeTab = "settings";
    private string _promptTemplateSearchTerm;
    private List<IBrowserFile> _selectedDocuments = [];

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await PopulateDropdownsAsync();
    }

    private async Task PopulateDropdownsAsync()
    {
        var deployments = await DeploymentCatalog.GetAllAsync();
        _model.Deployments = deployments
            .Where(d => d.Type.Supports(AIDeploymentType.Chat))
            .Select(d => new SelectOption(
                string.Equals(d.Name, d.ModelName, StringComparison.OrdinalIgnoreCase) ? d.Name : $"{d.Name} ({d.ModelName})",
                d.Name))
            .ToList();

        var orchestratorOptions = OrchestratorOptionsAccessor.Value;
        var orchestrators = orchestratorOptions.GetOrchestratorDescriptors();
        _model.Orchestrators = orchestrators.Select(o => new SelectOption(o.Value.Title ?? o.Key, o.Key)).ToList();

        // A2A Connections
        var connections = await A2AConnectionCatalog.GetAllAsync();
        _model.AvailableA2AConnections = connections
            .OrderBy(c => c.DisplayText, StringComparer.OrdinalIgnoreCase)
            .Select(c => new A2AConnectionSelectionItem { ItemId = c.ItemId, DisplayText = c.DisplayText, Endpoint = c.Endpoint })
            .ToList();

        // MCP Connections
        var mcpConnections = await McpConnectionCatalog.GetAllAsync();
        _model.AvailableMcpConnections = mcpConnections
            .OrderBy(c => c.DisplayText, StringComparer.OrdinalIgnoreCase)
            .Select(c => new McpConnectionSelectionItem { ItemId = c.ItemId, DisplayText = c.DisplayText, Source = c.Source })
            .ToList();

        // AI Tools
        var toolOptions = ToolOptionsAccessor.Value;
        _model.AvailableTools = toolOptions.Tools
            .Where(kvp => !kvp.Value.IsSystemTool)
            .Select(kvp => new ToolSelectionItem
            {
                Name = kvp.Key,
                Title = kvp.Value.Title ?? kvp.Key,
                Description = kvp.Value.Description,
                Category = kvp.Value.Category ?? "Miscellaneous",
            })
            .OrderBy(t => t.Category).ThenBy(t => t.Title)
            .ToList();

        // AI Agents
        var agentProfiles = await ProfileManager.GetAsync(AIProfileType.Agent);
        _model.AvailableAgents = agentProfiles
            .OrderBy(p => p.DisplayText ?? p.Name, StringComparer.OrdinalIgnoreCase)
            .Select(p => new AgentSelectionItem { Name = p.Name, DisplayText = p.DisplayText ?? p.Name })
            .ToList();

        // Prompt Templates
        var promptTemplates = await TemplateService.GetByKindAsync(AITemplateSources.SystemPrompt);
        _model.AvailablePromptTemplates = promptTemplates
            .Where(t => t.Metadata.IsListable)
            .OrderBy(t => t.Metadata.Category ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            .ThenBy(t => t.Metadata.Title ?? t.Id, StringComparer.OrdinalIgnoreCase)
            .Select(t => new PromptTemplateOptionItem
            {
                TemplateId = t.Id,
                Title = t.Metadata.Title ?? t.Id,
                Description = t.Metadata.Description,
                Category = t.Metadata.Category ?? "General",
                Parameters = (t.Metadata.Parameters ?? []).Select(p => new PromptTemplateParameterItem
                {
                    Name = p.Name,
                    Description = p.Description,
                }).ToList(),
            })
            .ToList();
        // Data Sources
        var dataSources = await DataSourceCatalog.GetAllAsync();
        _model.DataSources = dataSources
            .OrderBy(ds => ds.DisplayText, StringComparer.OrdinalIgnoreCase)
            .Select(ds => new SelectOption(ds.DisplayText, ds.ItemId))
            .ToList();

        var documentSettings = SiteSettingsStore.Get<InteractionDocumentSettings>();
        _model.DocumentIndexProfileName = documentSettings.IndexProfileName;

        if (!string.IsNullOrWhiteSpace(documentSettings.IndexProfileName))
        {
            var documentIndexProfile = await IndexProfileStore.FindByNameAsync(documentSettings.IndexProfileName);
            _model.HasDocumentIndexConfiguration = documentIndexProfile != null;
        }
    }

    private IEnumerable<IGrouping<string, PromptTemplateOptionItem>> FilteredPromptTemplateGroups =>
        _model.AvailablePromptTemplates
            .Where(template => string.IsNullOrWhiteSpace(_promptTemplateSearchTerm) ||
                template.Title.Contains(_promptTemplateSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(template.Description) && template.Description.Contains(_promptTemplateSearchTerm, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(template.Category) && template.Category.Contains(_promptTemplateSearchTerm, StringComparison.OrdinalIgnoreCase)))
            .GroupBy(template => template.Category)
            .OrderBy(group => group.Key);

    private bool HasFilteredPromptTemplates => FilteredPromptTemplateGroups.Any();

    private void AddPromptTemplate(string templateId)
    {
        if (string.IsNullOrWhiteSpace(templateId))
        {
            return;
        }

        if (_model.PromptTemplates.Any(t => string.Equals(t.TemplateId, templateId, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        _model.PromptTemplates.Add(new PromptTemplateSelectionItem { TemplateId = templateId });
    }

    private void SelectAllTools()
    {
        foreach (var tool in _model.AvailableTools)
        {
            tool.IsSelected = true;
        }
    }

    private void DeselectAllTools()
    {
        foreach (var tool in _model.AvailableTools)
        {
            tool.IsSelected = false;
        }
    }

    private void OnDocumentsSelected(InputFileChangeEventArgs e)
    {
        _selectedDocuments = e.GetMultipleFiles().ToList();
    }

    private async Task HandleSubmitAsync()
    {
        var authState = await AuthenticationState;
        var userName = authState.User.Identity?.Name ?? "anonymous";

        var interaction = await InteractionManager.NewAsync();
        interaction.Title = _model.Title;
        interaction.OwnerId = userName;
        interaction.Author = userName;
        interaction.ChatDeploymentName = _model.ChatDeploymentName;
        interaction.OrchestratorName = _model.OrchestratorName;
        interaction.SystemMessage = _model.SystemMessage;
        interaction.Temperature = _model.Temperature;
        interaction.TopP = _model.TopP;
        interaction.FrequencyPenalty = _model.FrequencyPenalty;
        interaction.PresencePenalty = _model.PresencePenalty;
        interaction.MaxTokens = _model.MaxTokens;
        interaction.PastMessagesCount = _model.PastMessagesCount;
        interaction.A2AConnectionIds = _model.AvailableA2AConnections.Where(c => c.IsSelected).Select(c => c.ItemId).ToList();
        interaction.McpConnectionIds = _model.AvailableMcpConnections.Where(c => c.IsSelected).Select(c => c.ItemId).ToList();
        interaction.ToolNames = _model.AvailableTools.Where(t => t.IsSelected).Select(t => t.Name).ToList();
        interaction.AgentNames = _model.AvailableAgents.Where(a => a.IsSelected).Select(a => a.Name).ToList();
        interaction.CreatedUtc = DateTime.UtcNow;

        if (!string.IsNullOrWhiteSpace(_model.DataSourceId))
        {
            var dataSource = await DataSourceCatalog.FindByIdAsync(_model.DataSourceId);
            if (dataSource != null)
            {
                interaction.Alter<DataSourceMetadata>(metadata => metadata.DataSourceId = dataSource.ItemId);
                interaction.Alter<AIDataSourceRagMetadata>(metadata =>
                {
                    metadata.Strictness = _model.DataSourceStrictness;
                    metadata.TopNDocuments = _model.DataSourceTopNDocuments;
                    metadata.IsInScope = _model.DataSourceIsInScope;
                    metadata.Filter = string.IsNullOrWhiteSpace(_model.DataSourceFilter) ? null : _model.DataSourceFilter;
                });
            }
        }

        interaction.Alter<DocumentsMetadata>(metadata =>
        {
            metadata.RetrievalMode = _model.DocumentRetrievalMode;
        });

        if (_model.PromptTemplates.Count > 0)
        {
            interaction.Alter<PromptTemplateMetadata>(metadata =>
            {
                metadata.SetSelections(_model.PromptTemplates
                    .Where(t => !string.IsNullOrWhiteSpace(t.TemplateId))
                    .Select(t => new PromptTemplateSelectionEntry
                    {
                        TemplateId = t.TemplateId,
                        Parameters = ParsePromptParameters(t.PromptParameters),
                    })
                    .ToList());
            });
        }

        await InteractionManager.CreateAsync(interaction);
        await StoreCommitter.CommitAsync();

        Navigation.NavigateTo($"/chat-interactions/chat/{interaction.ItemId}");
    }

    private static Dictionary<string, object> ParsePromptParameters(string promptParameters)
    {
        if (string.IsNullOrWhiteSpace(promptParameters))
        {
            return null;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(promptParameters);

            if (document.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object)
            {
                return null;
            }

            var parameters = new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);

            foreach (var property in document.RootElement.EnumerateObject())
            {
                if (property.Value.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    parameters[property.Name] = property.Value.GetString();
                }
            }

            return parameters.Count > 0 ? parameters : null;
        }
        catch
        {
            return null;
        }
    }
}
