@page "/ChatInteractions/Create"
@attribute [Authorize(Policy = "Admin")]
@inject NavigationManager NavigationManager

@code {
    protected override void OnInitialized()
    {
        // Redirect to the index page which handles creation directly.
        // This preserves backward compatibility if anyone bookmarked this URL.
        NavigationManager.NavigateTo("/ChatInteractions", replace: true);
    }
}
