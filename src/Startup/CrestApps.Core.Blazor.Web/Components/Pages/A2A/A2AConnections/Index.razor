@page "/a2a/connections"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.A2A.Models
@using CrestApps.Core.Services
@inject ICatalog<A2AConnection> Catalog
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Agent to Agent Hosts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-diagram-3"></i> Agent to Agent Hosts</h2>
    <a href="/a2a/connections/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Add Connection
    </a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_connections == null)
{
    <p><em>Loading...</em></p>
}
else if (_connections.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No A2A hosts are configured yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Endpoint</th>
                    <th>Authentication</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var connection in _connections)
                {
                    connection.TryGet<A2AConnectionMetadata>(out var metadata);
                    <tr>
                        <td><strong>@connection.DisplayText</strong></td>
                        <td><code>@connection.Endpoint</code></td>
                        <td><span class="badge bg-info text-dark">@(metadata?.AuthenticationType)</span></td>
                        <td>
                            <a href="/a2a/connections/edit/@connection.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(connection.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<A2AConnection> _connections;
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await Catalog.GetAllAsync();

        _connections = all
            .OrderBy(c => c.DisplayText, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this A2A connection?");

        if (!confirmed)
        {
            return;
        }

        var connection = await Catalog.FindByIdAsync(id);

        if (connection == null)
        {
            _errorMessage = "Connection not found.";

            return;
        }

        await Catalog.DeleteAsync(connection);
        await StoreCommitter.CommitAsync();
        await LoadAsync();
    }
}
