@page "/a2a/connections/create"
@attribute [Authorize(Policy = "Admin")]
@using System.Text.Json
@using CrestApps.Core.AI.A2A
@using CrestApps.Core.AI.A2A.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Services
@inject ICatalog<A2AConnection> Catalog
@inject IDataProtectionProvider DataProtectionProvider
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation

<PageTitle>Add Agent to Agent Host</PageTitle>

<h2><i class="bi bi-plus-lg"></i> Add Agent to Agent Host</h2>
<hr />

<EditForm FormName="a2a-a2aconnections-create" Model="_model" OnValidSubmit="HandleSubmitAsync">
    <DataAnnotationsValidator />

    <div class="row">
        <div class="col-md-8">
            @if (_errors.Count > 0)
            {
                <div class="alert alert-danger">
                    @foreach (var error in _errors)
                    {
                        <div>@error</div>
                    }
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Title <span class="text-danger">*</span></label>
                <InputText @bind-Value="_model.DisplayText" class="form-control" placeholder="e.g., Production Agent Hub" />
                <ValidationMessage For="() => _model.DisplayText" />
            </div>

            <div class="mb-3">
                <label class="form-label">Endpoint <span class="text-danger">*</span></label>
                <InputText @bind-Value="_model.Endpoint" class="form-control" placeholder="https://agents.example.com" />
                <div class="form-text">The base host URL. The agent card is resolved from <code>/.well-known/agent-card.json</code>.</div>
                <ValidationMessage For="() => _model.Endpoint" />
            </div>

            <div class="mb-3">
                <label class="form-label">Authentication</label>
                <select class="form-select" value="@_model.AuthenticationType" @onchange="OnAuthTypeChanged">
                    @foreach (var authType in Enum.GetValues<ClientAuthenticationType>())
                    {
                        <option value="@authType">@authType</option>
                    }
                </select>
            </div>

            @if (_model.AuthenticationType == ClientAuthenticationType.ApiKey)
            {
                <div class="mb-3">
                    <label class="form-label">API key header name</label>
                    <InputText @bind-Value="_model.ApiKeyHeaderName" class="form-control" placeholder="Authorization" />
                </div>

                <div class="mb-3">
                    <label class="form-label">API key prefix</label>
                    <InputText @bind-Value="_model.ApiKeyPrefix" class="form-control" placeholder="Bearer" />
                </div>

                <div class="mb-3">
                    <label class="form-label">API key</label>
                    <input type="password" class="form-control" @bind="_model.ApiKey" autocomplete="new-password" />
                </div>
            }

            @if (_model.AuthenticationType == ClientAuthenticationType.Basic)
            {
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText @bind-Value="_model.BasicUsername" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" class="form-control" @bind="_model.BasicPassword" autocomplete="new-password" />
                </div>
            }

            @if (_model.AuthenticationType is ClientAuthenticationType.OAuth2ClientCredentials
                or ClientAuthenticationType.OAuth2PrivateKeyJwt
                or ClientAuthenticationType.OAuth2Mtls)
            {
                <div class="mb-3">
                    <label class="form-label">Token endpoint</label>
                    <InputText @bind-Value="_model.OAuth2TokenEndpoint" class="form-control" placeholder="https://identity.example.com/connect/token" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Client ID</label>
                    <InputText @bind-Value="_model.OAuth2ClientId" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Scopes</label>
                    <InputText @bind-Value="_model.OAuth2Scopes" class="form-control" placeholder="agents.read agents.invoke" />
                </div>
            }

            @if (_model.AuthenticationType == ClientAuthenticationType.OAuth2ClientCredentials)
            {
                <div class="mb-3">
                    <label class="form-label">Client secret</label>
                    <input type="password" class="form-control" @bind="_model.OAuth2ClientSecret" autocomplete="new-password" />
                </div>
            }

            @if (_model.AuthenticationType == ClientAuthenticationType.OAuth2PrivateKeyJwt)
            {
                <div class="mb-3">
                    <label class="form-label">Key ID</label>
                    <InputText @bind-Value="_model.OAuth2KeyId" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Private key (PEM)</label>
                    <InputTextArea @bind-Value="_model.OAuth2PrivateKey" class="form-control" rows="6" />
                </div>
            }

            @if (_model.AuthenticationType == ClientAuthenticationType.OAuth2Mtls)
            {
                <div class="mb-3">
                    <label class="form-label">Client certificate (Base64 PFX/PKCS#12)</label>
                    <InputTextArea @bind-Value="_model.OAuth2ClientCertificate" class="form-control" rows="6" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Certificate password</label>
                    <input type="password" class="form-control" @bind="_model.OAuth2ClientCertificatePassword" autocomplete="new-password" />
                </div>
            }

            @if (_model.AuthenticationType == ClientAuthenticationType.CustomHeaders)
            {
                <div class="mb-3">
                    <label class="form-label">Additional headers (JSON)</label>
                    <InputTextArea @bind-Value="_model.AdditionalHeaders" class="form-control" rows="6" placeholder="@("{\"X-Api-Key\": \"value\"}")" />
                </div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Create
                </button>
                <a href="/a2a/connections" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</EditForm>

@code {
    private A2AConnectionViewModel _model = new();
    private List<string> _errors = [];

    private void OnAuthTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ClientAuthenticationType>(e.Value?.ToString(), out var value))
        {
            _model.AuthenticationType = value;
        }
    }

    private async Task HandleSubmitAsync()
    {
        _errors.Clear();
        ValidateModel(_model, isEditing: false);

        if (_errors.Count > 0)
        {
            return;
        }

        var connection = new A2AConnection
        {
            ItemId = UniqueId.GenerateId(),
            CreatedUtc = DateTime.UtcNow,
        };

        ApplyToConnection(_model, connection);
        await Catalog.CreateAsync(connection);
        await StoreCommitter.CommitAsync();
        Navigation.NavigateTo("/a2a/connections");
    }

    private void ValidateModel(A2AConnectionViewModel model, bool isEditing)
    {
        if (string.IsNullOrWhiteSpace(model.DisplayText))
        {
            _errors.Add("Display text is required.");
        }

        if (string.IsNullOrWhiteSpace(model.Endpoint))
        {
            _errors.Add("Endpoint is required.");
        }
        else if (!Uri.TryCreate(model.Endpoint, UriKind.Absolute, out var uri) || (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        {
            _errors.Add("Endpoint must be a valid HTTP or HTTPS URL.");
        }

        switch (model.AuthenticationType)
        {
            case ClientAuthenticationType.ApiKey:
                if ((!isEditing || !model.HasApiKey) && string.IsNullOrWhiteSpace(model.ApiKey))
                {
                    _errors.Add("API key is required.");
                }

                break;

            case ClientAuthenticationType.Basic:
                if (string.IsNullOrWhiteSpace(model.BasicUsername))
                {
                    _errors.Add("Username is required.");
                }

                if ((!isEditing || !model.HasBasicPassword) && string.IsNullOrWhiteSpace(model.BasicPassword))
                {
                    _errors.Add("Password is required.");
                }

                break;

            case ClientAuthenticationType.OAuth2ClientCredentials:
                ValidateOAuth2Common(model);

                if ((!isEditing || !model.HasOAuth2ClientSecret) && string.IsNullOrWhiteSpace(model.OAuth2ClientSecret))
                {
                    _errors.Add("Client secret is required.");
                }

                break;

            case ClientAuthenticationType.OAuth2PrivateKeyJwt:
                ValidateOAuth2Common(model);

                if ((!isEditing || !model.HasOAuth2PrivateKey) && string.IsNullOrWhiteSpace(model.OAuth2PrivateKey))
                {
                    _errors.Add("Private key is required.");
                }

                break;

            case ClientAuthenticationType.OAuth2Mtls:
                ValidateOAuth2Common(model);

                if ((!isEditing || !model.HasOAuth2ClientCertificate) && string.IsNullOrWhiteSpace(model.OAuth2ClientCertificate))
                {
                    _errors.Add("Client certificate is required.");
                }

                break;

            case ClientAuthenticationType.CustomHeaders:
                if (!string.IsNullOrWhiteSpace(model.AdditionalHeaders))
                {
                    try
                    {
                        _ = JsonSerializer.Deserialize<Dictionary<string, string>>(model.AdditionalHeaders);
                    }
                    catch (JsonException)
                    {
                        _errors.Add("Additional headers must be valid JSON.");
                    }
                }

                break;
        }
    }

    private void ValidateOAuth2Common(A2AConnectionViewModel model)
    {
        if (string.IsNullOrWhiteSpace(model.OAuth2TokenEndpoint))
        {
            _errors.Add("Token endpoint is required.");
        }
        else if (!Uri.TryCreate(model.OAuth2TokenEndpoint, UriKind.Absolute, out _))
        {
            _errors.Add("Token endpoint must be a valid URL.");
        }

        if (string.IsNullOrWhiteSpace(model.OAuth2ClientId))
        {
            _errors.Add("Client ID is required.");
        }
    }

    private void ApplyToConnection(A2AConnectionViewModel model, A2AConnection connection)
    {
        connection.DisplayText = model.DisplayText?.Trim();
        connection.Endpoint = model.Endpoint?.Trim();
        var metadata = connection.GetOrCreate<A2AConnectionMetadata>();
        var protector = DataProtectionProvider.CreateProtector(A2AConstants.DataProtectionPurpose);
        metadata.AuthenticationType = model.AuthenticationType;
        metadata.ApiKeyHeaderName = null;
        metadata.ApiKeyPrefix = null;
        metadata.ApiKey = null;
        metadata.BasicUsername = null;
        metadata.BasicPassword = null;
        metadata.OAuth2TokenEndpoint = null;
        metadata.OAuth2ClientId = null;
        metadata.OAuth2ClientSecret = null;
        metadata.OAuth2Scopes = null;
        metadata.OAuth2PrivateKey = null;
        metadata.OAuth2KeyId = null;
        metadata.OAuth2ClientCertificate = null;
        metadata.OAuth2ClientCertificatePassword = null;
        metadata.AdditionalHeaders = null;

        switch (model.AuthenticationType)
        {
            case ClientAuthenticationType.ApiKey:
                metadata.ApiKeyHeaderName = model.ApiKeyHeaderName;
                metadata.ApiKeyPrefix = model.ApiKeyPrefix;
                metadata.ApiKey = !string.IsNullOrWhiteSpace(model.ApiKey) ? protector.Protect(model.ApiKey) : null;

                break;

            case ClientAuthenticationType.Basic:
                metadata.BasicUsername = model.BasicUsername;
                metadata.BasicPassword = !string.IsNullOrWhiteSpace(model.BasicPassword) ? protector.Protect(model.BasicPassword) : null;

                break;

            case ClientAuthenticationType.OAuth2ClientCredentials:
                metadata.OAuth2TokenEndpoint = model.OAuth2TokenEndpoint;
                metadata.OAuth2ClientId = model.OAuth2ClientId;
                metadata.OAuth2Scopes = model.OAuth2Scopes;
                metadata.OAuth2ClientSecret = !string.IsNullOrWhiteSpace(model.OAuth2ClientSecret) ? protector.Protect(model.OAuth2ClientSecret) : null;

                break;

            case ClientAuthenticationType.OAuth2PrivateKeyJwt:
                metadata.OAuth2TokenEndpoint = model.OAuth2TokenEndpoint;
                metadata.OAuth2ClientId = model.OAuth2ClientId;
                metadata.OAuth2Scopes = model.OAuth2Scopes;
                metadata.OAuth2KeyId = model.OAuth2KeyId;
                metadata.OAuth2PrivateKey = !string.IsNullOrWhiteSpace(model.OAuth2PrivateKey) ? protector.Protect(model.OAuth2PrivateKey) : null;

                break;

            case ClientAuthenticationType.OAuth2Mtls:
                metadata.OAuth2TokenEndpoint = model.OAuth2TokenEndpoint;
                metadata.OAuth2ClientId = model.OAuth2ClientId;
                metadata.OAuth2Scopes = model.OAuth2Scopes;
                metadata.OAuth2ClientCertificate = !string.IsNullOrWhiteSpace(model.OAuth2ClientCertificate) ? protector.Protect(model.OAuth2ClientCertificate) : null;
                metadata.OAuth2ClientCertificatePassword = !string.IsNullOrWhiteSpace(model.OAuth2ClientCertificatePassword) ? protector.Protect(model.OAuth2ClientCertificatePassword) : null;

                break;

            case ClientAuthenticationType.CustomHeaders:
                metadata.AdditionalHeaders = string.IsNullOrWhiteSpace(model.AdditionalHeaders) ? null : JsonSerializer.Deserialize<Dictionary<string, string>>(model.AdditionalHeaders);

                break;
        }

        connection.Put(metadata);
    }
}
