@page "/mcp/prompts"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.Services
@inject INamedCatalog<McpPrompt> Catalog
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>MCP Prompts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-chat-square-text"></i> MCP Prompts</h2>
    <a href="/mcp/prompts/create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Add Prompt
    </a>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_prompts == null)
{
    <p><em>Loading...</em></p>
}
else if (_prompts.Count == 0)
{
    <div class="alert alert-info">No MCP prompts are configured yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Description</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prompt in _prompts)
                {
                    <tr>
                        <td><strong>@(prompt.Prompt?.Title ?? prompt.Name)</strong></td>
                        <td><code>@prompt.Name</code></td>
                        <td>@prompt.Prompt?.Description</td>
                        <td>
                            <a href="/mcp/prompts/edit/@prompt.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(prompt.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<McpPrompt> _prompts;
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await Catalog.GetAllAsync();

        _prompts = all
            .OrderBy(p => p.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task DeleteAsync(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this MCP prompt?");

        if (!confirmed)
        {
            return;
        }

        var prompt = await Catalog.FindByIdAsync(id);

        if (prompt == null)
        {
            _errorMessage = "Prompt not found.";

            return;
        }

        await Catalog.DeleteAsync(prompt);
        await StoreCommitter.CommitAsync();
        await LoadAsync();
    }
}
