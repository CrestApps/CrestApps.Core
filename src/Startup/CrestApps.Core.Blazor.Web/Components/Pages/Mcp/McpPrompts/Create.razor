@page "/mcp/prompts/create"
@attribute [Authorize(Policy = "Admin")]
@using System.Text.Json
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.Blazor.Web.ViewModels
@using CrestApps.Core.Services
@using ModelContextProtocol.Protocol
@inject INamedCatalog<McpPrompt> Catalog
@inject IStoreCommitter StoreCommitter
@inject NavigationManager Navigation
@inject TimeProvider TimeProvider

<PageTitle>Create MCP Prompt</PageTitle>

<h2><i class="bi bi-plus-circle"></i> Create MCP Prompt</h2>
<hr />

<EditForm FormName="mcp-mcpprompts-create" Model="_model" OnValidSubmit="HandleSubmitAsync">
    <DataAnnotationsValidator />

    <div class="col-md-8">
        @if (_errors.Count > 0)
        {
            <div class="alert alert-danger">
                @foreach (var error in _errors)
                {
                    <div>@error</div>
                }
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Title</label>
            <InputText @bind-Value="_model.Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Technical name <span class="text-danger">*</span></label>
            <InputText @bind-Value="_model.Name" class="form-control" />
            <ValidationMessage For="() => _model.Name" />
            <div class="form-text">A unique machine-readable name. You may override it before saving.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea @bind-Value="_model.Description" class="form-control" rows="4" />
        </div>

        <div class="mb-3">
            <label class="form-label">Arguments (JSON array)</label>
            <InputTextArea @bind-Value="_model.Arguments" class="form-control" rows="8" />
            <div class="form-text">Example: <code>[{{ "name": "topic", "description": "Topic to expand", "required": true }}]</code></div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
            <a href="/mcp/prompts" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</EditForm>

@code {
    private static readonly JsonSerializerOptions _indentedJsonOptions = new() { WriteIndented = true };
    private McpPromptViewModel _model = new();
    private List<string> _errors = [];

    private async Task HandleSubmitAsync()
    {
        _errors.Clear();
        var arguments = ParseArguments(_model);

        if (_errors.Count > 0)
        {
            return;
        }

        var prompt = new McpPrompt
        {
            ItemId = UniqueId.GenerateId(),
            CreatedUtc = TimeProvider.GetUtcNow().UtcDateTime,
        };

        Apply(_model, prompt, arguments);
        await Catalog.CreateAsync(prompt);
        await StoreCommitter.CommitAsync();
        Navigation.NavigateTo("/mcp/prompts");
    }

    private List<PromptArgument> ParseArguments(McpPromptViewModel model)
    {
        if (string.IsNullOrWhiteSpace(model.Name))
        {
            _errors.Add("Name is required.");
        }

        if (string.IsNullOrWhiteSpace(model.Arguments))
        {
            return [];
        }

        try
        {
            var arguments = JsonSerializer.Deserialize<List<PromptArgument>>(model.Arguments) ?? [];

            for (var i = 0; i < arguments.Count; i++)
            {
                if (string.IsNullOrWhiteSpace(arguments[i].Name))
                {
                    _errors.Add($"Argument {i + 1} requires a name.");
                }
            }

            return arguments.Where(a => !string.IsNullOrWhiteSpace(a.Name)).ToList();
        }
        catch (JsonException)
        {
            _errors.Add("Arguments must be valid JSON.");

            return [];
        }
    }

    private static void Apply(McpPromptViewModel model, McpPrompt prompt, List<PromptArgument> arguments)
    {
        var name = model.Name.Trim();
        prompt.Name = name;
        prompt.Prompt = new Prompt
        {
            Name = name,
            Title = model.Title?.Trim(),
            Description = model.Description?.Trim(),
            Arguments = arguments,
        };
    }
}
