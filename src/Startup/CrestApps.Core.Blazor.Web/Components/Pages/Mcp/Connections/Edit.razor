@page "/Mcp/Connections/Edit/{Id}"
@attribute [Authorize(Policy = "Admin")]
@using System.Text.Json
@using CrestApps.Core.AI.Mcp
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.Services
@using Microsoft.AspNetCore.DataProtection
@inject ICatalog<McpConnection> Catalog
@inject IDataProtectionProvider DataProtectionProvider
@inject NavigationManager NavigationManager

<PageTitle>Edit MCP Host</PageTitle>

@if (NotFound)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Connection not found.
    </div>
    <a href="/Mcp/Connections" class="btn btn-outline-secondary">Back to Connections</a>
}
else if (Model is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <h2><i class="bi bi-pencil"></i> Edit MCP Host</h2>
    <hr />

    <EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="EditMcpConnection">
        <div class="col-md-8">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <InputText @bind-Value="Model.DisplayText" class="form-control" />
                @if (Errors.ContainsKey(nameof(Model.DisplayText)))
                {
                    <div class="text-danger">@Errors[nameof(Model.DisplayText)]</div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Connection type</label>
                <InputSelect @bind-Value="Model.Source" class="form-select">
                    <option value="@McpConstants.TransportTypes.Sse">Server-Sent Events (SSE)</option>
                    <option value="@McpConstants.TransportTypes.StdIo">Standard Input/Output</option>
                </InputSelect>
            </div>

            @if (Model.Source == McpConstants.TransportTypes.Sse)
            {
                <div class="mb-3">
                    <label class="form-label">Endpoint</label>
                    <InputText @bind-Value="Model.Endpoint" class="form-control" placeholder="https://mcp.example.com/mcp/sse" />
                    @if (Errors.ContainsKey(nameof(Model.Endpoint)))
                    {
                        <div class="text-danger">@Errors[nameof(Model.Endpoint)]</div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Authentication</label>
                    <InputSelect @bind-Value="Model.AuthenticationType" class="form-select">
                        @foreach (var authType in Enum.GetValues<McpClientAuthenticationType>())
                        {
                            <option value="@authType">@authType</option>
                        }
                    </InputSelect>
                </div>

                @if (Model.AuthenticationType == McpClientAuthenticationType.ApiKey)
                {
                    <div class="mb-3">
                        <label class="form-label">API key header name</label>
                        <InputText @bind-Value="Model.ApiKeyHeaderName" class="form-control" placeholder="Authorization" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">API key prefix</label>
                        <InputText @bind-Value="Model.ApiKeyPrefix" class="form-control" placeholder="Bearer" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">API key</label>
                        <InputText @bind-Value="Model.ApiKey" class="form-control" type="password" />
                        @if (HasApiKey) { <div class="form-text">Leave blank to keep the existing API key.</div> }
                        @if (Errors.ContainsKey(nameof(Model.ApiKey)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.ApiKey)]</div>
                        }
                    </div>
                }

                @if (Model.AuthenticationType == McpClientAuthenticationType.Basic)
                {
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText @bind-Value="Model.BasicUsername" class="form-control" />
                        @if (Errors.ContainsKey(nameof(Model.BasicUsername)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.BasicUsername)]</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText @bind-Value="Model.BasicPassword" class="form-control" type="password" />
                        @if (HasBasicPassword) { <div class="form-text">Leave blank to keep the existing password.</div> }
                        @if (Errors.ContainsKey(nameof(Model.BasicPassword)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.BasicPassword)]</div>
                        }
                    </div>
                }

                @if (Model.AuthenticationType is McpClientAuthenticationType.OAuth2ClientCredentials
                    or McpClientAuthenticationType.OAuth2PrivateKeyJwt
                    or McpClientAuthenticationType.OAuth2Mtls)
                {
                    <div class="mb-3">
                        <label class="form-label">Token endpoint</label>
                        <InputText @bind-Value="Model.OAuth2TokenEndpoint" class="form-control" />
                        @if (Errors.ContainsKey(nameof(Model.OAuth2TokenEndpoint)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.OAuth2TokenEndpoint)]</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Client ID</label>
                        <InputText @bind-Value="Model.OAuth2ClientId" class="form-control" />
                        @if (Errors.ContainsKey(nameof(Model.OAuth2ClientId)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.OAuth2ClientId)]</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Scopes</label>
                        <InputText @bind-Value="Model.OAuth2Scopes" class="form-control" />
                    </div>
                }

                @if (Model.AuthenticationType == McpClientAuthenticationType.OAuth2ClientCredentials)
                {
                    <div class="mb-3">
                        <label class="form-label">Client secret</label>
                        <InputText @bind-Value="Model.OAuth2ClientSecret" class="form-control" type="password" />
                        @if (HasOAuth2ClientSecret) { <div class="form-text">Leave blank to keep the existing client secret.</div> }
                        @if (Errors.ContainsKey(nameof(Model.OAuth2ClientSecret)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.OAuth2ClientSecret)]</div>
                        }
                    </div>
                }

                @if (Model.AuthenticationType == McpClientAuthenticationType.OAuth2PrivateKeyJwt)
                {
                    <div class="mb-3">
                        <label class="form-label">Key ID</label>
                        <InputText @bind-Value="Model.OAuth2KeyId" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Private key (PEM)</label>
                        <InputTextArea @bind-Value="Model.OAuth2PrivateKey" class="form-control" rows="6" />
                        @if (HasOAuth2PrivateKey) { <div class="form-text">Leave blank to keep the existing private key.</div> }
                        @if (Errors.ContainsKey(nameof(Model.OAuth2PrivateKey)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.OAuth2PrivateKey)]</div>
                        }
                    </div>
                }

                @if (Model.AuthenticationType == McpClientAuthenticationType.OAuth2Mtls)
                {
                    <div class="mb-3">
                        <label class="form-label">Client certificate (Base64 PFX/PKCS#12)</label>
                        <InputTextArea @bind-Value="Model.OAuth2ClientCertificate" class="form-control" rows="5" />
                        @if (HasOAuth2ClientCertificate) { <div class="form-text">Leave blank to keep the existing certificate.</div> }
                        @if (Errors.ContainsKey(nameof(Model.OAuth2ClientCertificate)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.OAuth2ClientCertificate)]</div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Certificate password</label>
                        <InputText @bind-Value="Model.OAuth2ClientCertificatePassword" class="form-control" type="password" />
                        @if (HasOAuth2ClientCertificatePassword) { <div class="form-text">Leave blank to keep the existing certificate password.</div> }
                    </div>
                }

                @if (Model.AuthenticationType == McpClientAuthenticationType.CustomHeaders)
                {
                    <div class="mb-3">
                        <label class="form-label">Additional headers (JSON)</label>
                        <InputTextArea @bind-Value="Model.AdditionalHeaders" class="form-control" rows="5" />
                        @if (Errors.ContainsKey(nameof(Model.AdditionalHeaders)))
                        {
                            <div class="text-danger">@Errors[nameof(Model.AdditionalHeaders)]</div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label">Command</label>
                    <InputText @bind-Value="Model.Command" class="form-control" placeholder="docker" />
                    @if (Errors.ContainsKey(nameof(Model.Command)))
                    {
                        <div class="text-danger">@Errors[nameof(Model.Command)]</div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Arguments (JSON array)</label>
                    <InputTextArea @bind-Value="Model.Arguments" class="form-control" rows="5" />
                    @if (Errors.ContainsKey(nameof(Model.Arguments)))
                    {
                        <div class="text-danger">@Errors[nameof(Model.Arguments)]</div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Working directory</label>
                    <InputText @bind-Value="Model.WorkingDirectory" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Environment variables (JSON object)</label>
                    <InputTextArea @bind-Value="Model.EnvironmentVariables" class="form-control" rows="5" />
                    @if (Errors.ContainsKey(nameof(Model.EnvironmentVariables)))
                    {
                        <div class="text-danger">@Errors[nameof(Model.EnvironmentVariables)]</div>
                    }
                </div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                <a href="/Mcp/Connections" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </EditForm>
}

@code {
    private static readonly JsonSerializerOptions IndentedJson = new() { WriteIndented = true };

    [Parameter]
    public string Id { get; set; } = default!;

    private FormModel? Model;
    private bool NotFound;
    private Dictionary<string, string> Errors { get; set; } = new();
    private bool HasApiKey, HasBasicPassword, HasOAuth2ClientSecret, HasOAuth2PrivateKey, HasOAuth2ClientCertificate, HasOAuth2ClientCertificatePassword;

    protected override async Task OnInitializedAsync()
    {
        var connection = await Catalog.FindByIdAsync(Id);
        if (connection is null) { NotFound = true; return; }

        Model = new FormModel
        {
            DisplayText = connection.DisplayText,
            Source = connection.Source,
        };

        if (connection.Source == McpConstants.TransportTypes.Sse && connection.TryGet<SseMcpConnectionMetadata>(out var sse))
        {
            Model.Endpoint = sse.Endpoint?.ToString();
            Model.AuthenticationType = sse.AuthenticationType;
            Model.ApiKeyHeaderName = sse.ApiKeyHeaderName;
            Model.ApiKeyPrefix = sse.ApiKeyPrefix;
            Model.BasicUsername = sse.BasicUsername;
            Model.OAuth2TokenEndpoint = sse.OAuth2TokenEndpoint;
            Model.OAuth2ClientId = sse.OAuth2ClientId;
            Model.OAuth2Scopes = sse.OAuth2Scopes;
            Model.OAuth2KeyId = sse.OAuth2KeyId;
            Model.AdditionalHeaders = sse.AdditionalHeaders is not null ? JsonSerializer.Serialize(sse.AdditionalHeaders, IndentedJson) : "{}";
            HasApiKey = !string.IsNullOrEmpty(sse.ApiKey);
            HasBasicPassword = !string.IsNullOrEmpty(sse.BasicPassword);
            HasOAuth2ClientSecret = !string.IsNullOrEmpty(sse.OAuth2ClientSecret);
            HasOAuth2PrivateKey = !string.IsNullOrEmpty(sse.OAuth2PrivateKey);
            HasOAuth2ClientCertificate = !string.IsNullOrEmpty(sse.OAuth2ClientCertificate);
            HasOAuth2ClientCertificatePassword = !string.IsNullOrEmpty(sse.OAuth2ClientCertificatePassword);
        }
        else if (connection.TryGet<StdioMcpConnectionMetadata>(out var stdio))
        {
            Model.Command = stdio.Command;
            Model.Arguments = stdio.Arguments is { Length: > 0 } ? JsonSerializer.Serialize(stdio.Arguments, IndentedJson) : "[]";
            Model.WorkingDirectory = stdio.WorkingDirectory;
            Model.EnvironmentVariables = stdio.EnvironmentVariables is { Count: > 0 } ? JsonSerializer.Serialize(stdio.EnvironmentVariables, IndentedJson) : "{}";
        }
    }

    private async Task HandleSubmit()
    {
        Errors.Clear();
        var connection = await Catalog.FindByIdAsync(Id);
        if (connection is null) { NotFound = true; return; }

        if (string.IsNullOrWhiteSpace(Model!.DisplayText))
            Errors[nameof(Model.DisplayText)] = "Display text is required.";

        if (Model.Source == McpConstants.TransportTypes.Sse)
        {
            if (string.IsNullOrWhiteSpace(Model.Endpoint))
                Errors[nameof(Model.Endpoint)] = "Endpoint is required.";
            else if (!Uri.TryCreate(Model.Endpoint, UriKind.Absolute, out _))
                Errors[nameof(Model.Endpoint)] = "Endpoint must be a valid absolute URL.";
            ValidateSseAuth();
        }
        else
        {
            if (string.IsNullOrWhiteSpace(Model.Command))
                Errors[nameof(Model.Command)] = "Command is required.";
            ValidateJson(Model.Arguments, nameof(Model.Arguments), "Arguments must be a valid JSON string array.", true);
            ValidateJson(Model.EnvironmentVariables, nameof(Model.EnvironmentVariables), "Environment variables must be valid JSON.", false);
        }

        if (Errors.Any()) return;

        connection.DisplayText = Model.DisplayText!.Trim();
        connection.Source = Model.Source;

        if (Model.Source == McpConstants.TransportTypes.Sse)
            ApplySse(connection);
        else
            ApplyStdIo(connection);

        await Catalog.UpdateAsync(connection);
        NavigationManager.NavigateTo("/Mcp/Connections?success=MCP connection updated successfully.");
    }

    private void ValidateSseAuth()
    {
        switch (Model!.AuthenticationType)
        {
            case McpClientAuthenticationType.ApiKey:
                if (!HasApiKey && string.IsNullOrWhiteSpace(Model.ApiKey))
                    Errors[nameof(Model.ApiKey)] = "API key is required.";
                break;
            case McpClientAuthenticationType.Basic:
                if (string.IsNullOrWhiteSpace(Model.BasicUsername))
                    Errors[nameof(Model.BasicUsername)] = "Username is required.";
                if (!HasBasicPassword && string.IsNullOrWhiteSpace(Model.BasicPassword))
                    Errors[nameof(Model.BasicPassword)] = "Password is required.";
                break;
            case McpClientAuthenticationType.OAuth2ClientCredentials:
                ValidateOAuth2Common();
                if (!HasOAuth2ClientSecret && string.IsNullOrWhiteSpace(Model.OAuth2ClientSecret))
                    Errors[nameof(Model.OAuth2ClientSecret)] = "Client secret is required.";
                break;
            case McpClientAuthenticationType.OAuth2PrivateKeyJwt:
                ValidateOAuth2Common();
                if (!HasOAuth2PrivateKey && string.IsNullOrWhiteSpace(Model.OAuth2PrivateKey))
                    Errors[nameof(Model.OAuth2PrivateKey)] = "Private key is required.";
                break;
            case McpClientAuthenticationType.OAuth2Mtls:
                ValidateOAuth2Common();
                if (!HasOAuth2ClientCertificate && string.IsNullOrWhiteSpace(Model.OAuth2ClientCertificate))
                    Errors[nameof(Model.OAuth2ClientCertificate)] = "Client certificate is required.";
                break;
            case McpClientAuthenticationType.CustomHeaders:
                ValidateJson(Model.AdditionalHeaders, nameof(Model.AdditionalHeaders), "Additional headers must be valid JSON.", false);
                break;
        }
    }

    private void ValidateOAuth2Common()
    {
        if (string.IsNullOrWhiteSpace(Model!.OAuth2TokenEndpoint))
            Errors[nameof(Model.OAuth2TokenEndpoint)] = "Token endpoint is required.";
        else if (!Uri.TryCreate(Model.OAuth2TokenEndpoint, UriKind.Absolute, out _))
            Errors[nameof(Model.OAuth2TokenEndpoint)] = "Token endpoint must be a valid absolute URL.";
        if (string.IsNullOrWhiteSpace(Model.OAuth2ClientId))
            Errors[nameof(Model.OAuth2ClientId)] = "Client ID is required.";
    }

    private void ValidateJson(string? value, string fieldName, string message, bool isArray)
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        try
        {
            if (isArray) JsonSerializer.Deserialize<string[]>(value);
            else JsonSerializer.Deserialize<Dictionary<string, string>>(value);
        }
        catch (JsonException) { Errors[fieldName] = message; }
    }

    private void ApplySse(McpConnection connection)
    {
        var metadata = connection.GetOrCreate<SseMcpConnectionMetadata>();
        var protector = DataProtectionProvider.CreateProtector(McpConstants.DataProtectionPurpose);
        var existingApiKey = metadata.ApiKey;
        var existingBasicPassword = metadata.BasicPassword;
        var existingOAuth2ClientSecret = metadata.OAuth2ClientSecret;
        var existingOAuth2PrivateKey = metadata.OAuth2PrivateKey;
        var existingCert = metadata.OAuth2ClientCertificate;
        var existingCertPw = metadata.OAuth2ClientCertificatePassword;

        metadata.Endpoint = Uri.TryCreate(Model!.Endpoint, UriKind.Absolute, out var ep) ? ep : null;
        metadata.AuthenticationType = Model.AuthenticationType;
        metadata.ApiKeyHeaderName = null; metadata.ApiKeyPrefix = null; metadata.ApiKey = null;
        metadata.BasicUsername = null; metadata.BasicPassword = null;
        metadata.OAuth2TokenEndpoint = null; metadata.OAuth2ClientId = null; metadata.OAuth2ClientSecret = null;
        metadata.OAuth2Scopes = null; metadata.OAuth2PrivateKey = null; metadata.OAuth2KeyId = null;
        metadata.OAuth2ClientCertificate = null; metadata.OAuth2ClientCertificatePassword = null;
        metadata.AdditionalHeaders = null;

        switch (Model.AuthenticationType)
        {
            case McpClientAuthenticationType.ApiKey:
                metadata.ApiKeyHeaderName = Model.ApiKeyHeaderName?.Trim();
                metadata.ApiKeyPrefix = Model.ApiKeyPrefix?.Trim();
                metadata.ApiKey = ProtectOrReuse(Model.ApiKey, existingApiKey, protector);
                break;
            case McpClientAuthenticationType.Basic:
                metadata.BasicUsername = Model.BasicUsername?.Trim();
                metadata.BasicPassword = ProtectOrReuse(Model.BasicPassword, existingBasicPassword, protector);
                break;
            case McpClientAuthenticationType.OAuth2ClientCredentials:
                metadata.OAuth2TokenEndpoint = Model.OAuth2TokenEndpoint?.Trim();
                metadata.OAuth2ClientId = Model.OAuth2ClientId?.Trim();
                metadata.OAuth2Scopes = Model.OAuth2Scopes?.Trim();
                metadata.OAuth2ClientSecret = ProtectOrReuse(Model.OAuth2ClientSecret, existingOAuth2ClientSecret, protector);
                break;
            case McpClientAuthenticationType.OAuth2PrivateKeyJwt:
                metadata.OAuth2TokenEndpoint = Model.OAuth2TokenEndpoint?.Trim();
                metadata.OAuth2ClientId = Model.OAuth2ClientId?.Trim();
                metadata.OAuth2Scopes = Model.OAuth2Scopes?.Trim();
                metadata.OAuth2KeyId = Model.OAuth2KeyId?.Trim();
                metadata.OAuth2PrivateKey = ProtectOrReuse(Model.OAuth2PrivateKey, existingOAuth2PrivateKey, protector);
                break;
            case McpClientAuthenticationType.OAuth2Mtls:
                metadata.OAuth2TokenEndpoint = Model.OAuth2TokenEndpoint?.Trim();
                metadata.OAuth2ClientId = Model.OAuth2ClientId?.Trim();
                metadata.OAuth2Scopes = Model.OAuth2Scopes?.Trim();
                metadata.OAuth2ClientCertificate = ProtectOrReuse(Model.OAuth2ClientCertificate, existingCert, protector);
                metadata.OAuth2ClientCertificatePassword = ProtectOrReuse(Model.OAuth2ClientCertificatePassword, existingCertPw, protector);
                break;
            case McpClientAuthenticationType.CustomHeaders:
                metadata.AdditionalHeaders = string.IsNullOrWhiteSpace(Model.AdditionalHeaders) ? [] : JsonSerializer.Deserialize<Dictionary<string, string>>(Model.AdditionalHeaders) ?? [];
                break;
        }
        connection.Put(metadata);
    }

    private void ApplyStdIo(McpConnection connection)
    {
        connection.Alter<StdioMcpConnectionMetadata>(metadata =>
        {
            metadata.Command = Model!.Command?.Trim();
            metadata.Arguments = string.IsNullOrWhiteSpace(Model.Arguments) ? [] : JsonSerializer.Deserialize<string[]>(Model.Arguments) ?? [];
            metadata.WorkingDirectory = Model.WorkingDirectory?.Trim();
            metadata.EnvironmentVariables = string.IsNullOrWhiteSpace(Model.EnvironmentVariables) ? [] : JsonSerializer.Deserialize<Dictionary<string, string>>(Model.EnvironmentVariables) ?? [];
        });
    }

    private static string? ProtectOrReuse(string? newValue, string? existingValue, Microsoft.AspNetCore.DataProtection.IDataProtector protector)
    {
        return !string.IsNullOrWhiteSpace(newValue) ? protector.Protect(newValue) : existingValue;
    }

    private sealed class FormModel
    {
        public string? DisplayText { get; set; }
        public string Source { get; set; } = McpConstants.TransportTypes.Sse;
        public string? Endpoint { get; set; }
        public McpClientAuthenticationType AuthenticationType { get; set; }
        public string? ApiKeyHeaderName { get; set; }
        public string? ApiKeyPrefix { get; set; }
        public string? ApiKey { get; set; }
        public string? BasicUsername { get; set; }
        public string? BasicPassword { get; set; }
        public string? OAuth2TokenEndpoint { get; set; }
        public string? OAuth2ClientId { get; set; }
        public string? OAuth2ClientSecret { get; set; }
        public string? OAuth2Scopes { get; set; }
        public string? OAuth2PrivateKey { get; set; }
        public string? OAuth2KeyId { get; set; }
        public string? OAuth2ClientCertificate { get; set; }
        public string? OAuth2ClientCertificatePassword { get; set; }
        public string? AdditionalHeaders { get; set; }
        public string? Command { get; set; }
        public string? Arguments { get; set; } = "[]";
        public string? WorkingDirectory { get; set; }
        public string? EnvironmentVariables { get; set; } = "{}";
    }
}
