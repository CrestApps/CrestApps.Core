@page "/Mcp/Prompts"
@attribute [Authorize(Policy = "Admin")]
@using CrestApps.Core.AI.Mcp.Models
@using CrestApps.Core.Services
@inject INamedCatalog<McpPrompt> Catalog
@inject NavigationManager NavigationManager

<PageTitle>MCP Prompts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-chat-square-text"></i> MCP Prompts</h2>
    <a href="/Mcp/Prompts/Create" class="btn btn-success">
        <i class="bi bi-plus-lg"></i> Add Prompt
    </a>
</div>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

@if (Prompts is null)
{
    <p><em>Loading...</em></p>
}
else if (!Prompts.Any())
{
    <div class="alert alert-info">No MCP prompts are configured yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Technical Name</th>
                    <th>Description</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prompt in Prompts)
                {
                    <tr>
                        <td><strong>@(prompt.Prompt?.Title ?? prompt.Name)</strong></td>
                        <td><code>@prompt.Name</code></td>
                        <td>@prompt.Prompt?.Description</td>
                        <td>
                            <a href="/Mcp/Prompts/Edit/@prompt.ItemId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmDelete(prompt.ItemId)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (ShowDeleteConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Delete this MCP prompt?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ExecuteDelete">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessMessage { get; set; }

    private IReadOnlyCollection<McpPrompt>? Prompts;
    private bool ShowDeleteConfirmation;
    private string? DeleteTargetId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var all = await Catalog.GetAllAsync();
        Prompts = all.OrderBy(p => p.Name, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private void ConfirmDelete(string id)
    {
        DeleteTargetId = id;
        ShowDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        DeleteTargetId = null;
        ShowDeleteConfirmation = false;
    }

    private async Task ExecuteDelete()
    {
        if (!string.IsNullOrEmpty(DeleteTargetId))
        {
            var prompt = await Catalog.FindByIdAsync(DeleteTargetId);
            if (prompt != null) await Catalog.DeleteAsync(prompt);
        }

        ShowDeleteConfirmation = false;
        DeleteTargetId = null;
        SuccessMessage = "MCP prompt deleted successfully.";
        await LoadAsync();
    }
}
