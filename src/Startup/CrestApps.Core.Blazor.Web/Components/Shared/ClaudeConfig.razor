@using CrestApps.Core.AI.Claude.Models

<div class="card mb-3">
    <div class="card-header">
        <h6 class="card-title mb-0"><i class="bi bi-chat-square-dots me-1"></i> Claude Configuration</h6>
    </div>
    <div class="card-body">
        @if (!IsConfigured)
        {
            <div class="alert alert-warning mb-0">
                <strong>Claude is not configured and cannot be used until it has been configured.</strong>
                Go to <a href="/admin/settings"><strong>Settings</strong></a>
                and complete the Claude section first.
            </div>
        }
        else if (AvailableModels?.Any() == true)
        {
            <div class="mb-3">
                <label for="@(Prefix)-ClaudeModel" class="form-label">Claude model</label>
                <select id="@(Prefix)-ClaudeModel" class="form-select"
                        value="@ClaudeModel"
                        @onchange="OnModelChanged">
                    <option value="">Use default model</option>
                    @foreach (var item in AvailableModels)
                    {
                        <option value="@item.Key">@item.Value</option>
                    }
                </select>
                <div class="form-text">Select a Claude model override for this item, or leave it on the configured default.</div>
            </div>

            <div class="mb-0">
                <label for="@(Prefix)-ClaudeEffortLevel" class="form-label">Effort level</label>
                <select id="@(Prefix)-ClaudeEffortLevel" class="form-select"
                        value="@((int)EffortLevel)"
                        @onchange="OnEffortChanged">
                    <option value="@((int)ClaudeEffortLevel.None)">Default</option>
                    <option value="@((int)ClaudeEffortLevel.Low)">Low</option>
                    <option value="@((int)ClaudeEffortLevel.Medium)">Medium</option>
                    <option value="@((int)ClaudeEffortLevel.High)">High</option>
                </select>
                <div class="form-text">Select the reasoning effort level. Higher effort produces more thorough responses but uses more tokens.</div>
            </div>
        }
        else
        {
            <div class="mb-3">
                <label for="@(Prefix)-ClaudeModel" class="form-label">Claude model</label>
                <InputText id="@($"{Prefix}-ClaudeModel")" class="form-control"
                           Value="@ClaudeModel"
                           ValueChanged="ClaudeModelChanged"
                           ValueExpression="() => ClaudeModel"
                           placeholder="Leave empty to use the default model from settings" />
                <div class="form-text">Optionally override the Claude model. Leave empty to use the default model configured in settings.</div>
            </div>

            <div class="mb-0">
                <label for="@(Prefix)-ClaudeEffortLevel" class="form-label">Effort level</label>
                <select id="@(Prefix)-ClaudeEffortLevel" class="form-select"
                        value="@((int)EffortLevel)"
                        @onchange="OnEffortChanged">
                    <option value="@((int)ClaudeEffortLevel.None)">Default</option>
                    <option value="@((int)ClaudeEffortLevel.Low)">Low</option>
                    <option value="@((int)ClaudeEffortLevel.Medium)">Medium</option>
                    <option value="@((int)ClaudeEffortLevel.High)">High</option>
                </select>
                <div class="form-text">Select the reasoning effort level. Higher effort produces more thorough responses but uses more tokens.</div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string Prefix { get; set; } = "anthropic";

    [Parameter]
    public bool IsConfigured { get; set; }

    [Parameter]
    public string ClaudeModel { get; set; }

    [Parameter]
    public EventCallback<string> ClaudeModelChanged { get; set; }

    [Parameter]
    public ClaudeEffortLevel EffortLevel { get; set; }

    [Parameter]
    public EventCallback<ClaudeEffortLevel> EffortLevelChanged { get; set; }

    [Parameter]
    public IEnumerable<KeyValuePair<string, string>> AvailableModels { get; set; }

    private async Task OnModelChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        await ClaudeModelChanged.InvokeAsync(value);
    }

    private async Task OnEffortChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var level))
        {
            await EffortLevelChanged.InvokeAsync((ClaudeEffortLevel)level);
        }
    }
}
