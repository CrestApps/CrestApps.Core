@using CrestApps.Core.AI
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.Blazor.Web.Models
@using CrestApps.Core.Blazor.Web.Services
@using CrestApps.Core.Services
@using Microsoft.Extensions.Options
@implements IDisposable
@inject IAIProfileManager ProfileManager
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions
@inject SiteSettingsStore SiteSettings
@inject NavigationManager NavigationManager
@inject SiteSettingsChangedNotifier SettingsChangedNotifier

@if (_profile != null)
{
    <div id="ai-chat-admin-widget-shell"
         class="ai-chat-admin-widget-shell"
         style="@_widgetShellStyle"
         @key="_profile.ItemId"
         data-coreai-chat-widget-shell-selector="#ai-chat-admin-widget-shell"
         data-coreai-chat-widget-container-selector="#widget-panel"
         data-coreai-chat-widget-toggle-button-selector="#widget-toggle"
         data-coreai-chat-widget-close-button-selector="#widget-close"
         data-coreai-chat-widget-input-selector="#widget-chat-input"
         data-coreai-chat-widget-state-name="@_widgetStateName"
         data-coreai-chat-widget-open-state-value="true"
         data-coreai-chat-widget-closed-state-value="false"
         data-coreai-chat-widget-open-icon-html="<i class='bi bi-x-lg'></i>"
         data-coreai-chat-widget-closed-icon-html="<i class='bi bi-chat-dots-fill'></i>"
         data-coreai-chat-widget-profile-id="@_profile.ItemId"
         data-coreai-chat-widget-profile-name="@_profile.Name"
         data-coreai-chat-widget-profile-display-text="@(_profile.DisplayText ?? _profile.Name)"
         data-coreai-chat-widget-profile-welcome-message="@_profile.WelcomeMessage"
         data-coreai-chat-widget-profile-chat-mode="@_chatMode"
         data-coreai-chat-widget-profile-tts-voice-name="@_ttsVoiceName"
         data-coreai-chat-widget-profile-enable-session-metrics="@_metricsEnabled.ToString().ToLowerInvariant()"
         data-coreai-chat-widget-profile-allow-session-documents="@((_allowSessionDocuments || _allowImageUploads).ToString().ToLowerInvariant())"
         data-coreai-chat-widget-new-chat-button-selector="#widget-new-chat"
         data-coreai-chat-widget-reset-size-button-selector="#widget-reset-size"
         data-coreai-chat-widget-drag-handle-selector=".ai-chat-widget-header"
         data-coreai-chat-widget-enable-dragging="true"
         data-coreai-chat-widget-enable-resizing="true"
         data-coreai-chat-widget-persist-layout="true"
         data-coreai-chat-signalr-hub-url="/hubs/ai-chat"
         data-coreai-chat-app-element-selector="#widget-chat-app"
         data-coreai-chat-container-element-selector="#widget-chat-container"
         data-coreai-chat-input-element-selector="#widget-chat-input"
         data-coreai-chat-send-button-element-selector="#widget-send-btn"
         data-coreai-chat-placeholder-element-selector="#widget-placeholder"
         data-coreai-chat-auto-create-session="true"
         data-coreai-chat-metrics-enabled="@_metricsEnabled.ToString().ToLowerInvariant()"
         data-coreai-chat-mode="@_chatMode"
         data-coreai-chat-mic-button-element-selector="#widget-mic-btn"
         data-coreai-chat-conversation-button-element-selector="#widget-conversation-btn"
         data-coreai-chat-tts-voice-name="@_ttsVoiceName"
         data-coreai-chat-session-documents-enabled="@((_allowSessionDocuments || _allowImageUploads).ToString().ToLowerInvariant())"
         data-coreai-chat-document-bar-selector="#widget-chat-document-bar"
         data-coreai-chat-upload-document-url="/ai/chat-sessions/upload-document"
         data-coreai-chat-remove-document-url="/ai/chat-sessions/remove-document"
         data-coreai-chat-allowed-extensions="@_supportedExtensionsAccept"
         data-coreai-chat-supported-extensions-text="@_supportedExtensionsDisplay">
        <link rel="stylesheet" href="/_content/CrestApps.AI.Resources/styles/chat-widget.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/default.min.css" />

        <!-- Floating toggle button -->
        <button id="widget-toggle" class="ai-chat-widget-toggle" title="Open chat">
            <i class="bi bi-chat-dots-fill"></i>
        </button>

        <!-- Widget container -->
        <div id="widget-panel" class="ai-chat-widget-container">
            <div class="ai-chat-widget-header">
                <span class="title">AI Chat</span>
                <div class="ai-chat-widget-header-actions">
                    <button id="widget-new-chat" title="New Chat"><i class="bi bi-plus-lg"></i></button>
                    <button id="widget-reset-size" class="d-none" title="Reset size"><i class="bi bi-arrows-angle-contract"></i></button>
                    <button id="widget-close" title="Close"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div id="widget-chat-container" class="ai-chat-widget-messages">
                <div id="widget-placeholder">
                    <div class="ai-chat-widget-welcome">
                        <i class="bi bi-robot" style="font-size: 2rem;"></i><br />
                        @_welcomeMessage
                    </div>
                </div>
                <div id="widget-chat-app"></div>
            </div>

            <div id="widget-chat-document-bar" class="border-top bg-light d-none"></div>

            <div class="ai-chat-widget-input">
                <textarea id="widget-chat-input"
                          placeholder="Type a message..."
                          rows="1"
                          data-session-id=""
                          data-profile-id="@_profile.ItemId"></textarea>
                <button type="button" id="widget-mic-btn" class="btn btn-outline-secondary btn-sm" title="Voice input" style="display: none;">
                    <i class="bi bi-mic-fill"></i>
                </button>
                @if (_chatMode == ChatMode.Conversation)
                {
                    <button type="button"
                            id="widget-conversation-btn"
                            class="btn btn-outline-dark btn-sm"
                            title="Start Conversation"
                            data-start-title="Start Conversation"
                            data-end-title="End Conversation"
                            data-start-html="<i class='bi bi-soundwave'></i>"
                            data-end-html="<i class='bi bi-stop-fill me-1'></i> End Conversation">
                        <i class="bi bi-soundwave"></i>
                    </button>
                }
                <button type="button" id="widget-send-btn">
                    <i class="bi bi-send"></i>
                </button>
            </div>
        </div>
    </div>

}

@code {
    private AIProfile _profile;
    private string _welcomeMessage = "What do you want to know?";
    private string _widgetShellStyle = "visibility:hidden;";
    private ChatMode _chatMode = ChatMode.TextInput;
    private bool _metricsEnabled;
    private bool _allowSessionDocuments;
    private bool _textToSpeechEnabled;
    private string _ttsVoiceName;
    private string _supportedExtensionsAccept;
    private string _supportedExtensionsDisplay;
    private bool _allowImageUploads;
    private string _lastProfileId;
    private string _widgetStateName;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        SettingsChangedNotifier.SettingsChanged += OnSettingsChangedAsync;
        await RefreshWidgetStateAsync();
    }

    private async void OnLocationChanged(object sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        await RefreshWidgetStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSettingsChangedAsync()
    {
        await RefreshWidgetStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshWidgetStateAsync()
    {
        var adminWidgetSettings = SiteSettings.Get<AIChatAdminWidgetSettings>();
        var deploymentDefaults = SiteSettings.Get<DefaultAIDeploymentSettings>();

        if (string.IsNullOrWhiteSpace(adminWidgetSettings.ProfileId))
        {
            _profile = null;

            return;
        }

        if (!string.Equals(_lastProfileId, adminWidgetSettings.ProfileId, StringComparison.Ordinal))
        {
            _lastProfileId = adminWidgetSettings.ProfileId;
        }

        var selectedProfile = await ProfileManager.FindByIdAsync(adminWidgetSettings.ProfileId);
        if (selectedProfile == null || selectedProfile.Type != AIProfileType.Chat)
        {
            _profile = null;

            return;
        }

        _profile = selectedProfile;
        _welcomeMessage = !string.IsNullOrWhiteSpace(selectedProfile.WelcomeMessage)
            ? selectedProfile.WelcomeMessage
            : "What do you want to know?";

        var hasTtsDeployment = !string.IsNullOrWhiteSpace(deploymentDefaults.DefaultTextToSpeechDeploymentName);
        var speechToTextEnabled = !string.IsNullOrWhiteSpace(deploymentDefaults.DefaultSpeechToTextDeploymentName);
        _ttsVoiceName = deploymentDefaults.DefaultTextToSpeechVoiceId;

        ChatModeProfileSettings chatModeSettings = null;
        if (selectedProfile.TryGetSettings<ChatModeProfileSettings>(out chatModeSettings))
        {
            _textToSpeechEnabled = (chatModeSettings?.EnableTextToSpeechPlayback ?? false) && hasTtsDeployment;
            if (!string.IsNullOrEmpty(chatModeSettings?.VoiceName))
            {
                _ttsVoiceName = chatModeSettings.VoiceName;
            }
        }

        var configuredChatMode = chatModeSettings?.ChatMode ?? ChatMode.TextInput;
        _chatMode = configuredChatMode switch
        {
            ChatMode.Conversation when speechToTextEnabled && hasTtsDeployment => ChatMode.Conversation,
            ChatMode.AudioInput when speechToTextEnabled => ChatMode.AudioInput,
            ChatMode.Conversation when speechToTextEnabled => ChatMode.AudioInput,
            _ => ChatMode.TextInput,
        };

        _metricsEnabled = selectedProfile.TryGet<AnalyticsMetadata>(out var analyticsMetadata) && analyticsMetadata.EnableSessionMetrics;
        _allowSessionDocuments = selectedProfile.TryGet<AIProfileSessionDocumentsMetadata>(out var sessionDocMeta) && sessionDocMeta.AllowSessionDocuments;
        _allowImageUploads = sessionDocMeta?.AllowSessionImageUploads == true
            && !string.IsNullOrWhiteSpace(deploymentDefaults.DefaultVisionDeploymentName);
        _supportedExtensionsAccept = ChatDocumentOptions.Value.GetAllowedFileExtensionsAcceptValue(_allowImageUploads, _allowSessionDocuments);
        _supportedExtensionsDisplay = ChatDocumentOptions.Value.GetAllowedFileExtensionsDisplayValue(_allowImageUploads, _allowSessionDocuments);

        var widgetStyle = string.IsNullOrWhiteSpace(adminWidgetSettings.PrimaryColor)
            ? null
            : $"--ai-widget-primary: {adminWidgetSettings.PrimaryColor.Trim()};";
        _widgetShellStyle = string.IsNullOrWhiteSpace(widgetStyle) ? "visibility:hidden;" : $"{widgetStyle}visibility:hidden;";

        _widgetStateName = "blazor-admin-chat-widget-" + _profile.ItemId;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        SettingsChangedNotifier.SettingsChanged -= OnSettingsChangedAsync;
    }

}
