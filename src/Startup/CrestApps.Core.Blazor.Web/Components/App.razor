<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>@(PageTitle ?? "Blazor AI Integration Sample")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@@7/css/all.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <HeadOutlet @rendermode="@InteractiveRenderMode" />
</head>
<body>
    <Routes @rendermode="@InteractiveRenderMode" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@latest/dist/browser/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script src="/_content/CrestApps.AI.Resources/scripts/document-drop-zone.js"></script>
    <script src="/_content/CrestApps.AI.Resources/scripts/technical-name-generator.js"></script>
    <script src="/_content/CrestApps.AI.Resources/scripts/ai-chat.js"></script>
    <script src="/_content/CrestApps.AI.Resources/scripts/ai-chat-widget.js"></script>
    <script src="/_content/CrestApps.AI.Resources/scripts/chat-interaction.js"></script>
    <script src="/_content/CrestApps.AI.Resources/scripts/chat-interaction-settings.js"></script>
    <script src="/_framework/blazor.web.js"></script>
    <script>
        window.renderMarkdownArticle = function (markdown) {
            var container = document.getElementById("article-content");
            if (container && typeof marked !== "undefined" && typeof DOMPurify !== "undefined") {
                var html = marked.parse(markdown || "");
                container.innerHTML = DOMPurify.sanitize(html);
            }
        };
    </script>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; }

    private string PageTitle => HttpContext?.Items["PageTitle"] as string;

    // Disable prerendering so EditForm submissions never fall back to a static SSR POST,
    // which would require a FormName on every form. Interactive Server handles submission
    // through the SignalR circuit instead.
    private static readonly InteractiveServerRenderMode InteractiveRenderMode = new(prerender: false);
}
