@inherits LayoutComponentBase
@inject NavigationManager Navigation

<PageTitle>@(Title ?? "Blazor AI Integration Sample")</PageTitle>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <i class="bi bi-robot"></i> Blazor AI Integration Sample
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">
                        <i class="bi bi-house"></i> Home
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                <i class="bi bi-person-circle"></i> @context.User.Identity?.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form method="post" action="/Account/Logout">
                                <AntiforgeryToken />
                                <button type="submit" class="nav-link btn btn-link text-light">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </button>
                            </form>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <a class="nav-link" href="/account/login">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

<div class="d-flex app-layout">
    <AuthorizeView Roles="Administrator">
        <Authorized>
            <NavMenu />
        </Authorized>
    </AuthorizeView>

    <main class="flex-grow-1 p-4 app-content">
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @ErrorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success" role="alert">
                <i class="bi bi-check-circle-fill"></i> @SuccessMessage
            </div>
        }

        @Body
    </main>
</div>

<AuthorizeView>
    <Authorized>
        <ChatWidget />
    </Authorized>
</AuthorizeView>

@code {
    #nullable enable

    private string? Title { get; set; }
    private string? ErrorMessage { get; set; }
    private string? SuccessMessage { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
}
