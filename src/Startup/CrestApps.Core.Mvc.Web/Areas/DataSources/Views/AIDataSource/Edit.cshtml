@using CrestApps.Core.AI.Models
@using CrestApps.Core.Mvc.Web.Areas.DataSources.ViewModels
@model AIDataSourceViewModel
@{
    ViewData["Title"] = "Edit Data Source";
}

<h2><i class="bi bi-pencil"></i> Edit Data Source</h2>
<hr />

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ItemId" />
    <div class="row">
        <div class="col-md-8">
            <div class="mb-3">
                <label asp-for="DisplayText" class="form-label">Title <span class="text-danger">*</span></label>
                <input asp-for="DisplayText" class="form-control" required placeholder="e.g., Product Catalog" />
                <span asp-validation-for="DisplayText" class="text-danger"></span>
                <div class="form-text">A human-readable name for this data source.</div>
            </div>

            <hr />
            <h5>Source</h5>

            <div class="mb-3">
                <label asp-for="Source" class="form-label">Source type <span class="text-danger">*</span></label>
                <select asp-for="Source" asp-items="Model.SourceTypes" class="form-select" required>
                    <option value="">Select source type</option>
                </select>
                <span asp-validation-for="Source" class="text-danger"></span>
                <div class="form-text">Choose how source documents are read into the knowledge base.</div>
            </div>

            <div class="mb-3" id="source-index-profile-settings"@(string.Equals(Model.Source, AIDataSourceSourceTypes.SearchIndexProfile, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                <label asp-for="SourceIndexProfileName" class="form-label">Source index profile <span class="text-danger">*</span></label>
                <select asp-for="SourceIndexProfileName" asp-items="Model.SourceIndexProfiles" class="form-select">
                    <option value="">Select index profile</option>
                </select>
                <span asp-validation-for="SourceIndexProfileName" class="text-danger"></span>
                <div class="form-text">Used when the source type is <strong>Search Index Profile</strong>.</div>
            </div>

            <div id="elasticsearch-source-settings"@(string.Equals(Model.Source, AIDataSourceSourceTypes.Elasticsearch, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                <hr />
                <h5>Elasticsearch Source Settings</h5>
                <div class="alert alert-info">
                    Configure the remote Elasticsearch source that CrestApps.Core should read from before chunking and embedding documents.
                </div>

                <div class="mb-3">
                    <label asp-for="ElasticsearchEnvironmentType" class="form-label">Elasticsearch environment</label>
                    <select asp-for="ElasticsearchEnvironmentType" class="form-select">
                        <option value="@ElasticsearchSourceMetadata.SelfManagedEnvironmentType">Self-managed</option>
                        <option value="@ElasticsearchSourceMetadata.CloudHostedEnvironmentType">Cloud hosted deployment</option>
                    </select>
                    <span asp-validation-for="ElasticsearchEnvironmentType" class="text-danger"></span>
                </div>

                <div class="mb-3" id="elasticsearch-url-settings"@(string.Equals(Model.ElasticsearchEnvironmentType, ElasticsearchSourceMetadata.SelfManagedEnvironmentType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <label asp-for="ElasticsearchUrl" class="form-label">Elasticsearch URL</label>
                    <input asp-for="ElasticsearchUrl" class="form-control" placeholder="https://elastic.example.com:9200" />
                    <span asp-validation-for="ElasticsearchUrl" class="text-danger"></span>
                    <div class="form-text">Required for self-managed clusters or endpoint-based hosted deployments.</div>
                </div>

                <div class="mb-3" id="elasticsearch-cloud-id-settings"@(string.Equals(Model.ElasticsearchEnvironmentType, ElasticsearchSourceMetadata.CloudHostedEnvironmentType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <label asp-for="ElasticsearchCloudId" class="form-label">Elastic Cloud ID</label>
                    <input asp-for="ElasticsearchCloudId" class="form-control" placeholder="deployment-name:dXMtZWFzdC0x..." />
                    <span asp-validation-for="ElasticsearchCloudId" class="text-danger"></span>
                    <div class="form-text">Required for Elastic Cloud hosted deployments.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="ElasticsearchIndexName" class="form-label">Elasticsearch index name</label>
                    <input asp-for="ElasticsearchIndexName" class="form-control" placeholder="products" />
                    <span asp-validation-for="ElasticsearchIndexName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ElasticsearchAuthenticationType" class="form-label">Authentication type</label>
                    <select asp-for="ElasticsearchAuthenticationType" class="form-select">
                        <option value="@ElasticsearchSourceMetadata.NoneAuthenticationType">None</option>
                        <option value="@ElasticsearchSourceMetadata.BasicAuthenticationType">Basic</option>
                        <option value="@ElasticsearchSourceMetadata.ApiKeyAuthenticationType">API key</option>
                        <option value="@ElasticsearchSourceMetadata.Base64ApiKeyAuthenticationType">Base64 API key</option>
                        <option value="@ElasticsearchSourceMetadata.KeyIdAndKeyAuthenticationType">Key ID and key</option>
                    </select>
                    <span asp-validation-for="ElasticsearchAuthenticationType" class="text-danger"></span>
                </div>

                <div id="elasticsearch-basic-auth-settings"@(string.Equals(Model.ElasticsearchAuthenticationType, ElasticsearchSourceMetadata.BasicAuthenticationType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <div class="mb-3">
                        <label asp-for="ElasticsearchUsername" class="form-label">Elasticsearch username</label>
                        <input asp-for="ElasticsearchUsername" class="form-control" placeholder="elastic" />
                        <span asp-validation-for="ElasticsearchUsername" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ElasticsearchPassword" class="form-label">Elasticsearch password</label>
                        <input asp-for="ElasticsearchPassword" class="form-control" type="password" placeholder="Leave empty to keep the saved password" />
                        <span asp-validation-for="ElasticsearchPassword" class="text-danger"></span>
                    </div>
                </div>

                <div id="elasticsearch-api-key-settings"@(string.Equals(Model.ElasticsearchAuthenticationType, ElasticsearchSourceMetadata.ApiKeyAuthenticationType, StringComparison.OrdinalIgnoreCase) || string.Equals(Model.ElasticsearchAuthenticationType, ElasticsearchSourceMetadata.KeyIdAndKeyAuthenticationType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <div class="mb-3">
                        <label asp-for="ElasticsearchApiKey" class="form-label">Elasticsearch API key</label>
                        <input asp-for="ElasticsearchApiKey" class="form-control" type="password" placeholder="Leave empty to keep the saved API key" />
                        <span asp-validation-for="ElasticsearchApiKey" class="text-danger"></span>
                    </div>
                </div>

                <div id="elasticsearch-base64-api-key-settings"@(string.Equals(Model.ElasticsearchAuthenticationType, ElasticsearchSourceMetadata.Base64ApiKeyAuthenticationType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <div class="mb-3">
                        <label asp-for="ElasticsearchBase64ApiKey" class="form-label">Base64 API key</label>
                        <input asp-for="ElasticsearchBase64ApiKey" class="form-control" type="password" placeholder="Leave empty to keep the saved base64 API key" />
                        <span asp-validation-for="ElasticsearchBase64ApiKey" class="text-danger"></span>
                    </div>
                </div>

                <div id="elasticsearch-key-id-settings"@(string.Equals(Model.ElasticsearchAuthenticationType, ElasticsearchSourceMetadata.KeyIdAndKeyAuthenticationType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <div class="mb-3">
                        <label asp-for="ElasticsearchApiKeyId" class="form-label">Elasticsearch API key ID</label>
                        <input asp-for="ElasticsearchApiKeyId" class="form-control" />
                        <span asp-validation-for="ElasticsearchApiKeyId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ElasticsearchCertificateFingerprint" class="form-label">Certificate fingerprint</label>
                    <input asp-for="ElasticsearchCertificateFingerprint" class="form-control" placeholder="AB:CD:..." />
                    <span asp-validation-for="ElasticsearchCertificateFingerprint" class="text-danger"></span>
                </div>
            </div>

            <div id="azure-ai-search-source-settings"@(string.Equals(Model.Source, AIDataSourceSourceTypes.AzureAISearch, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                <hr />
                <h5>Azure AI Search Source Settings</h5>
                <div class="alert alert-info">
                    Configure the remote Azure AI Search index that CrestApps.Core should read from before chunking and embedding documents.
                </div>

                <div class="mb-3">
                    <label asp-for="AzureAISearchEndpoint" class="form-label">Azure AI Search endpoint</label>
                    <input asp-for="AzureAISearchEndpoint" class="form-control" placeholder="https://example.search.windows.net" />
                    <span asp-validation-for="AzureAISearchEndpoint" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AzureAISearchIndexName" class="form-label">Azure AI Search index name</label>
                    <input asp-for="AzureAISearchIndexName" class="form-control" placeholder="products" />
                    <span asp-validation-for="AzureAISearchIndexName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AzureAISearchAuthenticationType" class="form-label">Authentication type</label>
                    <select asp-for="AzureAISearchAuthenticationType" class="form-select">
                        <option value="@AzureAISearchSourceMetadata.ApiKeyAuthenticationType">API key</option>
                        <option value="@AzureAISearchSourceMetadata.DefaultAuthenticationType">Default credential</option>
                        <option value="@AzureAISearchSourceMetadata.ManagedIdentityAuthenticationType">Managed identity</option>
                    </select>
                    <span asp-validation-for="AzureAISearchAuthenticationType" class="text-danger"></span>
                </div>

                <div id="azure-ai-search-identity-settings"@(string.Equals(Model.AzureAISearchAuthenticationType, AzureAISearchSourceMetadata.ApiKeyAuthenticationType, StringComparison.OrdinalIgnoreCase) ? " hidden" : null)>
                    <div class="mb-3">
                        <label asp-for="AzureAISearchIdentityClientId" class="form-label">Managed identity client ID</label>
                        <input asp-for="AzureAISearchIdentityClientId" class="form-control" placeholder="Optional for system-assigned identity" />
                        <span asp-validation-for="AzureAISearchIdentityClientId" class="text-danger"></span>
                        <div class="form-text">Optional for Default credential and Managed identity authentication.</div>
                    </div>
                </div>

                <div id="azure-ai-search-api-key-settings"@(string.Equals(Model.AzureAISearchAuthenticationType, AzureAISearchSourceMetadata.ApiKeyAuthenticationType, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                    <div class="mb-3">
                        <label asp-for="AzureAISearchApiKey" class="form-label">Azure AI Search API key</label>
                        <input asp-for="AzureAISearchApiKey" class="form-control" type="password" placeholder="Leave empty to keep the saved API key" />
                        <span asp-validation-for="AzureAISearchApiKey" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div id="postgresql-source-settings"@(string.Equals(Model.Source, AIDataSourceSourceTypes.PostgreSQL, StringComparison.OrdinalIgnoreCase) ? null : " hidden")>
                <hr />
                <h5>PostgreSQL Source Settings</h5>
                <div class="alert alert-info">
                    Configure the remote PostgreSQL table that CrestApps.Core should read from before chunking and embedding documents.
                </div>

                <div class="mb-3">
                    <label asp-for="PostgreSQLTableName" class="form-label">PostgreSQL table name</label>
                    <input asp-for="PostgreSQLTableName" class="form-control" placeholder="products" />
                    <span asp-validation-for="PostgreSQLTableName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PostgreSQLConnectionString" class="form-label">PostgreSQL connection string</label>
                    <input asp-for="PostgreSQLConnectionString" class="form-control" type="password" placeholder="Leave empty to keep the saved connection string" />
                    <span asp-validation-for="PostgreSQLConnectionString" class="text-danger"></span>
                </div>
            </div>

            <hr />
            <h5>Knowledge Base</h5>

            <div class="mb-3">
                <label asp-for="AIKnowledgeBaseIndexProfileName" class="form-label">Knowledge base index profile</label>
                <select asp-for="AIKnowledgeBaseIndexProfileName" asp-items="Model.KnowledgeBaseIndexProfiles" class="form-select">
                    <option value="">Select index profile</option>
                </select>
                <span asp-validation-for="AIKnowledgeBaseIndexProfileName" class="text-danger"></span>
                <div class="form-text">The index where chunked and embedded documents are stored for AI retrieval.</div>
            </div>

            <hr />
            <h5>Field Mapping</h5>

            <div class="mb-3">
                <label asp-for="KeyFieldName" class="form-label">Key field name</label>
                <input asp-for="KeyFieldName" class="form-control" placeholder="e.g., id" />
                <span asp-validation-for="KeyFieldName" class="text-danger"></span>
                <div class="form-text">The source field that maps to the document key. Leave empty to use the native document ID.</div>
            </div>

            <div class="mb-3">
                <label asp-for="TitleFieldName" class="form-label">Title field name</label>
                <input asp-for="TitleFieldName" class="form-control" placeholder="e.g., title" />
                <span asp-validation-for="TitleFieldName" class="text-danger"></span>
                <div class="form-text">The source field that maps to the document title.</div>
            </div>

            <div class="mb-3">
                <label asp-for="ContentFieldName" class="form-label">Content field name <span class="text-danger">*</span></label>
                <input asp-for="ContentFieldName" class="form-control" required placeholder="e.g., content" />
                <span asp-validation-for="ContentFieldName" class="text-danger"></span>
                <div class="form-text">The source field that maps to the document content (text body). Field mapping is still required for external sources so the knowledge-base pipeline knows which fields hold the key, title, and content.</div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Save
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </div>
    </div>
</form>

@await Html.PartialAsync("_SourceSettingsScript")
