@model CrestApps.Core.AI.Models.AIChatSessionResult
@{
    var profile = ViewData["Profile"] as CrestApps.Core.AI.Models.AIProfile;
    ViewData["Title"] = "Chat History - " + (profile?.DisplayText ?? profile?.Name ?? "Unknown");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-clock-history"></i> Chat History — @(profile?.DisplayText ?? profile?.Name)</h2>
    <div class="d-flex gap-2">
        <form asp-action="CreateSession" method="post" class="d-inline">
            <input type="hidden" name="profileId" value="@profile?.ItemId" />
            <button type="submit" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> New Chat
            </button>
        </form>
        @if (Model.Sessions.Any())
        {
            <form asp-action="DeleteAllSessions" method="post" class="d-inline">
                <input type="hidden" name="profileId" value="@profile?.ItemId" />
                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete all chat sessions for this profile? This cannot be undone.')">
                    <i class="bi bi-trash"></i> Delete All
                </button>
            </form>
        }
        <a asp-area="AI" asp-controller="AIProfile" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Profiles
        </a>
    </div>
</div>

@if (!Model.Sessions.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No chat sessions found for this profile. Start a new chat to get going.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Created</th>
                    <th>Last Activity</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model.Sessions.OrderByDescending(s => s.CreatedUtc))
                {
                    <tr>
                        <td>
                            <a asp-action="Chat" asp-route-sessionId="@session.SessionId" class="text-decoration-none">
                                <strong>@(session.Title ?? "Untitled")</strong>
                            </a>
                        </td>
                        <td>
                            <small class="text-muted">@session.CreatedUtc.ToString("g")</small>
                        </td>
                        <td>
                            <small class="text-muted">@session.LastActivityUtc.ToString("g")</small>
                        </td>
                        <td>
                            <a asp-action="Chat" asp-route-sessionId="@session.SessionId" class="btn btn-sm btn-outline-primary" title="Resume chat">
                                <i class="bi bi-chat-left-text"></i> Resume
                            </a>
                            <form asp-action="DeleteSession" method="post" class="d-inline">
                                <input type="hidden" name="sessionId" value="@session.SessionId" />
                                <input type="hidden" name="returnProfileId" value="@profile?.ItemId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this session?')" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
