@using CrestApps.Core
@using CrestApps.Core.AI
@using CrestApps.Core.AI.Documents.Models
@using CrestApps.Core.AI.Models
@using CrestApps.Core.AI.Profiles
@using CrestApps.Core.Mvc.Web.Areas.AIChat.Models
@using Microsoft.Extensions.Options

@inject IAIProfileManager ProfileManager
@inject IOptions<ChatDocumentsOptions> ChatDocumentOptions
@inject CrestApps.Core.Startup.Shared.Services.SiteSettingsStore SiteSettings

@{
    var adminWidgetSettings = SiteSettings.Get<AIChatAdminWidgetSettings>();
    var defaultDeploymentSettings = SiteSettings.Get<DefaultAIDeploymentSettings>();

    var selectedProfile = string.IsNullOrWhiteSpace(adminWidgetSettings.ProfileId)
        ? null
        : await ProfileManager.FindByIdAsync(adminWidgetSettings.ProfileId);

    var configuredChatMode = ChatMode.TextInput;
    var hasTtsDeployment = !string.IsNullOrWhiteSpace(defaultDeploymentSettings.DefaultTextToSpeechDeploymentName);
    var textToSpeechEnabled = false;
    var ttsVoiceName = defaultDeploymentSettings.DefaultTextToSpeechVoiceId;

    if (selectedProfile?.TryGetSettings<ChatModeProfileSettings>(out var profileChatModeSettings) == true)
    {
        configuredChatMode = profileChatModeSettings.ChatMode;
        textToSpeechEnabled = (profileChatModeSettings?.EnableTextToSpeechPlayback ?? false) && hasTtsDeployment;

        if (!string.IsNullOrEmpty(profileChatModeSettings?.VoiceName))
        {
            ttsVoiceName = profileChatModeSettings.VoiceName;
        }
    }

    var speechToTextEnabled = !string.IsNullOrWhiteSpace(defaultDeploymentSettings.DefaultSpeechToTextDeploymentName);
    var effectiveChatMode = configuredChatMode switch
    {
        ChatMode.Conversation when speechToTextEnabled && hasTtsDeployment => ChatMode.Conversation,
        ChatMode.AudioInput when speechToTextEnabled => ChatMode.AudioInput,
        ChatMode.Conversation when speechToTextEnabled => ChatMode.AudioInput,
        _ => ChatMode.TextInput,
    };

    var allowImageUploads = false;
    var allowSessionDocuments = false;
    if (selectedProfile != null && selectedProfile.TryGet<AIProfileSessionDocumentsMetadata>(out var sessionDocMeta))
    {
        allowImageUploads = sessionDocMeta.AllowSessionImageUploads
            && !string.IsNullOrWhiteSpace(defaultDeploymentSettings.DefaultVisionDeploymentName);
        allowSessionDocuments = sessionDocMeta.AllowSessionDocuments;
    }

    var supportedExtensionsAccept = ChatDocumentOptions.Value.GetAllowedFileExtensionsAcceptValue(allowImageUploads, allowSessionDocuments);
    var supportedExtensionsDisplay = ChatDocumentOptions.Value.GetAllowedFileExtensionsDisplayValue(allowImageUploads, allowSessionDocuments);
    var profile = selectedProfile is null || selectedProfile.Type != AIProfileType.Chat
        ? null
        : new
        {
            chatMode = effectiveChatMode.ToString(),
            ttsVoiceName = ttsVoiceName,
            id = selectedProfile.ItemId,
            name = selectedProfile.Name,
            displayText = selectedProfile.DisplayText ?? selectedProfile.Name,
            welcomeMessage = selectedProfile.WelcomeMessage,
            initialPrompt = selectedProfile.TryGet<AIProfileMetadata>(out var profileMetadata)
                ? profileMetadata.InitialPrompt?.Trim()
                : null,
            enableSessionMetrics = selectedProfile.TryGet<AnalyticsMetadata>(out var analyticsMetadata) && analyticsMetadata.EnableSessionMetrics,
            allowSessionDocuments = allowSessionDocuments || allowImageUploads,
        };

    if (profile == null)
    {
        return;
    }

    var widgetStyle = string.IsNullOrWhiteSpace(adminWidgetSettings.PrimaryColor)
        ? null
        : $"--ai-widget-primary: {adminWidgetSettings.PrimaryColor.Trim()};";
    var widgetShellStyle = string.IsNullOrWhiteSpace(widgetStyle)
        ? "visibility:hidden;"
        : $"{widgetStyle}visibility:hidden;";
    var widgetStateName = "mvc-admin-chat-widget-" + profile.id;
}

<div id="ai-chat-admin-widget-shell"
     class="ai-chat-admin-widget-shell"
     style="@widgetShellStyle"
     data-coreai-chat-widget-shell-selector="#ai-chat-admin-widget-shell"
     data-coreai-chat-widget-container-selector="#widget-panel"
     data-coreai-chat-widget-toggle-button-selector="#widget-toggle"
     data-coreai-chat-widget-close-button-selector="#widget-close"
     data-coreai-chat-widget-input-selector="#widget-chat-input"
     data-coreai-chat-widget-state-name="@widgetStateName"
     data-coreai-chat-widget-open-state-value="true"
     data-coreai-chat-widget-closed-state-value="false"
     data-coreai-chat-widget-open-icon-html="<i class='bi bi-x-lg'></i>"
     data-coreai-chat-widget-closed-icon-html="<i class='bi bi-chat-dots-fill'></i>"
     data-coreai-chat-widget-message-template-selector="#widget-chat-message-template"
     data-coreai-chat-widget-indicator-template-selector="#widget-chat-indicator-template"
     data-coreai-chat-widget-profile-id="@profile.id"
     data-coreai-chat-widget-profile-name="@profile.name"
     data-coreai-chat-widget-profile-display-text="@profile.displayText"
     data-coreai-chat-widget-profile-welcome-message="@profile.welcomeMessage"
     data-coreai-chat-widget-profile-initial-prompt="@profile.initialPrompt"
     data-coreai-chat-widget-profile-chat-mode="@profile.chatMode"
     data-coreai-chat-widget-profile-tts-voice-name="@profile.ttsVoiceName"
     data-coreai-chat-widget-profile-enable-session-metrics="@profile.enableSessionMetrics.ToString().ToLowerInvariant()"
     data-coreai-chat-widget-profile-allow-session-documents="@profile.allowSessionDocuments.ToString().ToLowerInvariant()"
     data-coreai-chat-widget-new-chat-button-selector="#widget-new-chat"
     data-coreai-chat-widget-reset-size-button-selector="#widget-reset-size"
     data-coreai-chat-widget-drag-handle-selector=".ai-chat-widget-header"
     data-coreai-chat-widget-enable-dragging="true"
     data-coreai-chat-widget-enable-resizing="true"
     data-coreai-chat-widget-persist-layout="true"
     data-coreai-chat-signalr-hub-url="/hubs/ai-chat"
     data-coreai-chat-app-element-selector="#widget-chat-app"
     data-coreai-chat-container-element-selector="#widget-chat-container"
     data-coreai-chat-input-element-selector="#widget-chat-input"
     data-coreai-chat-send-button-element-selector="#widget-send-btn"
     data-coreai-chat-placeholder-element-selector="#widget-placeholder"
     data-coreai-chat-initial-prompt="@profile.initialPrompt"
     data-coreai-chat-metrics-enabled="@profile.enableSessionMetrics.ToString().ToLowerInvariant()"
     data-coreai-chat-mode="@profile.chatMode"
     data-coreai-chat-mic-button-element-selector="#widget-mic-btn"
     data-coreai-chat-conversation-button-element-selector="#widget-conversation-btn"
     data-coreai-chat-tts-voice-name="@profile.ttsVoiceName"
     data-coreai-chat-session-documents-enabled="@profile.allowSessionDocuments.ToString().ToLowerInvariant()"
     data-coreai-chat-document-bar-selector="#widget-chat-document-bar"
     data-coreai-chat-upload-document-url="@Url.Content("~/ai/chat-sessions/upload-document")"
     data-coreai-chat-remove-document-url="@Url.Content("~/ai/chat-sessions/remove-document")"
     data-coreai-chat-allowed-extensions="@supportedExtensionsAccept"
     data-coreai-chat-supported-extensions-text="@supportedExtensionsDisplay"
     data-coreai-chat-user-label="You"
     data-coreai-chat-assistant-label="Assistant">
    <link rel="stylesheet" href="~/_content/CrestApps.AI.Resources/styles/chat-widget.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/default.min.css" />

    <template id="widget-chat-message-template">
        <div class="ai-chat-messages">
            <div v-for="(message, index) in messages" :key="'msg-' + index" class="ai-chat-message-item">
                <div>
                    <div v-if="message.role === 'user'" class="ai-chat-message-heading ai-chat-message-heading-user">
                        <span class="ai-chat-msg-role ai-chat-msg-role-user">{{ userLabel }}</span>
                    </div>
                    <div v-else-if="message.role !== 'indicator'" class="ai-chat-message-heading ai-chat-message-heading-assistant">
                        <div :class="getAssistantRoleClasses(message)">
                            <span :class="getAssistantIconClasses(message, index)"><i :class="getAssistantIcon(message)"></i></span>
                            <span class="ai-chat-message-role-label">{{ getAssistantLabel(message) }}</span>
                        </div>
                    </div>
                    <div class="ai-chat-message-body lh-base">
                        <h4 v-if="message.title">{{ message.title }}</h4>
                        <div v-html="message.htmlContent"></div>
                        <ol v-if="message.citationReferences && message.citationReferences.length" class="ai-chat-citation-list">
                            <li v-for="citation in message.citationReferences" :key="'citation-' + (citation.referenceKey || citation.displayIndex)" class="ai-chat-citation-item">
                                <a v-if="citation.link" :href="citation.link" :target="citation.isDownload ? null : '_blank'" :rel="citation.isDownload ? null : 'noopener noreferrer'">{{ citation.label }}</a>
                                <span v-else>{{ citation.label }}</span>
                            </li>
                        </ol>
                        <span class="message-buttons-container" v-if="!isIndicator(message)">
                            <template v-if="metricsEnabled && message.role === 'assistant'">
                                <span class="ai-chat-message-assistant-feedback" :data-message-id="message.id">
                                    <button type="button" class="btn btn-sm btn-link text-success p-0 me-2 button-message-toolbox rate-up-btn" @@click="rateMessage(message, true, $event)" :title="thumbsUpTitle">
                                        <i class="fa-regular fa-thumbs-up"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-link text-danger p-0 me-2 button-message-toolbox rate-down-btn" @@click="rateMessage(message, false, $event)" :title="thumbsDownTitle">
                                        <i class="fa-regular fa-thumbs-down"></i>
                                    </button>
                                </span>
                            </template>
                            <button type="button" v-if="textToSpeechEnabled && !isConversationMode && message.role === 'assistant' && !message.isStreaming" class="btn btn-sm btn-link text-secondary p-0 me-1 button-message-toolbox" :class="{ 'tts-playing': ttsPlayingMessageIndex === index }" :data-tts-message-index="index" @@click="toggleMessageTts(message, index)" :title="ttsPlayingMessageIndex === index ? 'Pause audio' : 'Read aloud'">
                                <span :class="ttsPlayingMessageIndex === index ? 'fa-solid fa-circle-pause' : 'fa-solid fa-circle-play'"></span>
                            </button>
                            <button type="button" class="btn btn-sm btn-link p-0 button-message-toolbox ai-response-copy-btn" :class="copiedMessageIndex === index ? 'text-success' : 'text-secondary'" :data-copy-message-index="index" @@click="copyResponse(message, index, $event)" :title="copiedMessageIndex === index ? copiedTitle : copyTitle">
                                <i :class="copiedMessageIndex === index ? 'fa-solid fa-check' : 'fa-solid fa-copy'"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
            <div v-for="notification in notifications" :key="'notif-' + notification.type" class="ai-chat-notification" :class="'ai-chat-notification-' + (notification.type || 'info') + ' ' + (notification.cssClass || '')">
                <div class="ai-chat-notification-content">
                    <i v-if="notification.icon" :class="notification.icon" class="ai-chat-notification-icon"></i>
                    <span class="ai-chat-notification-text">{{ notification.content }}</span>
                    <button type="button" v-if="notification.dismissible" class="btn btn-sm btn-link p-0 ms-2 ai-chat-notification-dismiss" @@click="dismissNotification(notification.type)" title="Dismiss">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div v-if="notification.actions && notification.actions.length" class="ai-chat-notification-actions">
                    <button type="button" v-for="action in notification.actions" :key="action.name" class="btn btn-sm" :class="action.cssClass || 'btn-outline-secondary'" @@click="handleNotificationAction(notification.type, action.name)">
                        <i v-if="action.icon" :class="action.icon" class="me-1"></i>
                        {{ action.label }}
                    </button>
                </div>
            </div>
        </div>
    </template>

    <template id="widget-chat-indicator-template">
        <div class="ai-chat-message-heading ai-chat-message-heading-assistant">
            <div class="ai-chat-msg-role ai-chat-msg-role-assistant">
                <span class="ai-streaming-icon"><i class="fa fa-robot" style="display: inline-block;"></i></span>
                <span class="ai-chat-message-role-label">{{ assistantLabel }}</span>
            </div>
        </div>
    </template>

    <!-- Floating toggle button -->
    <button id="widget-toggle" class="ai-chat-widget-toggle" title="Open chat">
        <i class="bi bi-chat-dots-fill"></i>
    </button>

    <!-- Widget container -->
    <div id="widget-panel" class="ai-chat-widget-container">
        <div class="ai-chat-widget-header">
            <span class="title">AI Chat</span>
            <div class="ai-chat-widget-header-actions">
                <button id="widget-new-chat" title="New Chat"><i class="bi bi-plus-lg"></i></button>
                <button id="widget-reset-size" class="d-none" title="Reset size"><i class="bi bi-arrows-angle-contract"></i></button>
                <button id="widget-close" title="Close"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div id="widget-chat-container" class="ai-chat-widget-messages">
            <div id="widget-placeholder">
                <div class="ai-chat-widget-welcome">
                    <i class="bi bi-robot" style="font-size: 2rem;"></i><br>
                    @(string.IsNullOrWhiteSpace(profile.welcomeMessage) ? "What do you want to know?" : profile.welcomeMessage)
                </div>
            </div>
            <div id="widget-chat-app"></div>
        </div>

        <div id="widget-chat-document-bar" class="border-top bg-light d-none"></div>

        <div class="ai-chat-widget-input">
            <textarea id="widget-chat-input"
                      placeholder="Type a message..."
                      rows="1"
                      data-session-id=""
                      data-profile-id="@profile.id"></textarea>
            <button type="button" id="widget-mic-btn" class="btn btn-outline-secondary btn-sm" title="Voice input" style="display: none;">
                <i class="bi bi-mic-fill"></i>
            </button>
            @if (profile.chatMode == nameof(ChatMode.Conversation))
            {
                <button type="button"
                        id="widget-conversation-btn"
                        class="btn btn-outline-dark btn-sm"
                        title="Start Conversation"
                        data-start-title="Start Conversation"
                        data-end-title="End Conversation"
                        data-start-html="<i class='bi bi-soundwave'></i>"
                        data-end-html="<i class='bi bi-stop-fill me-1'></i> End Conversation">
                    <i class="bi bi-soundwave"></i>
                </button>
            }
            <button type="button" id="widget-send-btn">
                <i class="bi bi-send"></i>
            </button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@latest/dist/browser/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script src="~/_content/CrestApps.AI.Resources/scripts/ai-chat-widget.js"></script>
    <script src="~/_content/CrestApps.AI.Resources/scripts/ai-chat.js"></script>
</div>
