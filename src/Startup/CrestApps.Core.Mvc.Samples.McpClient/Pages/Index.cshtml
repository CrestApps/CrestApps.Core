@page
@inject SampleServerSelectionService ServerSelection
@{
    var currentServer = ServerSelection.GetCurrent(HttpContext);
}
@model CrestApps.Core.Mvc.Samples.McpClient.Pages.IndexModel

<h1>MCP Client Sample</h1>

<p class="lead">This sample app connects to the selected MCP server and demonstrates listing tools, prompts, resources, and resource templates against either the MVC or Blazor sample host.</p>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Prerequisites</h5>
        <ol class="mb-0">
            <li>Start <strong>CrestApps.Core.Mvc.Web</strong>, <strong>CrestApps.Core.Blazor.Web</strong>, or the combined Aspire host.</li>
            <li>Use the <strong>Server</strong> buttons in the top navigation bar to switch between the available MVC Web and Blazor Web hosts.</li>
            <li>Ensure the selected server exposes its MCP endpoint.</li>
        </ol>
    </div>
</div>

<div class="alert alert-secondary">
    Active server: <strong>@currentServer.DisplayName</strong> (<code>@currentServer.Endpoint</code>)
</div>

<p>Use the navigation tabs above to explore each MCP capability:</p>

<div class="row g-3">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Tools</h5>
                <p class="card-text">List all tools exposed by the MCP server and invoke them with custom arguments.</p>
                <a asp-page="/Tools" class="btn btn-primary btn-sm">Go to Tools</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Prompts</h5>
                <p class="card-text">List all MCP prompts and retrieve the details of each prompt.</p>
                <a asp-page="/Prompts" class="btn btn-primary btn-sm">Go to Prompts</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Resources</h5>
                <p class="card-text">List concrete MCP resources with fixed URIs and read their content directly.</p>
                <a asp-page="/Resources" class="btn btn-primary btn-sm">Go to Resources</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Resource Templates</h5>
                <p class="card-text">Browse parameterized resource templates, fill in variables, and read content.</p>
                <a asp-page="/ResourceTemplates" class="btn btn-primary btn-sm">Go to Templates</a>
            </div>
        </div>
    </div>
</div>
