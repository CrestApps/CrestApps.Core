@inject SampleServerSelectionService ServerSelection
@{
    var currentServer = ServerSelection.GetCurrent(Context);
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MCP Client Sample</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">MCP Client Sample</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-page="/Index">Home</a>
                <a class="nav-link" asp-page="/Tools">Tools</a>
                <a class="nav-link" asp-page="/Prompts">Prompts</a>
                <a class="nav-link" asp-page="/Resources">Resources</a>
                <a class="nav-link" asp-page="/ResourceTemplates">Resource Templates</a>
            </div>
            <div class="d-flex align-items-center gap-2 ms-auto">
                <span class="navbar-text text-light small">Server:</span>
                @foreach (var server in ServerSelection.GetServers())
                {
                    var buttonClass = string.Equals(server.Name, currentServer.Name, StringComparison.OrdinalIgnoreCase)
                        ? "btn btn-sm btn-warning"
                        : "btn btn-sm btn-outline-light";

                    <a class="@buttonClass"
                       href="/server-selection?server=@Uri.EscapeDataString(server.Name)&returnUrl=@Uri.EscapeDataString(returnUrl)">
                        @server.DisplayName
                    </a>
                }
            </div>
        </div>
    </nav>
    <div class="container pb-4">
        <div class="alert alert-info py-2 small">
            Connected server: <strong>@currentServer.DisplayName</strong>
            <span class="text-muted">(@currentServer.Endpoint)</span>
            <span class="d-block text-muted mt-1">Use the <strong>Server</strong> buttons in the navbar to switch between the available hosts.</span>
        </div>
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
