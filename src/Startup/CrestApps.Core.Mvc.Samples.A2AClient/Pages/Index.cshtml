@page
@inject SampleServerSelectionService ServerSelection
@{
    var currentServer = ServerSelection.GetCurrent(HttpContext);
}
@model CrestApps.Core.Mvc.Samples.A2AClient.Pages.IndexModel

<h1>A2A Client Sample</h1>

<p class="lead">This sample app connects to the selected A2A host and demonstrates listing agents and sending messages against either the MVC or Blazor sample server.</p>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Prerequisites</h5>
        <ol class="mb-0">
            <li>Start <strong>CrestApps.Core.Mvc.Web</strong>, <strong>CrestApps.Core.Blazor.Web</strong>, or the combined Aspire host.</li>
            <li>Use the <strong>Server</strong> buttons in the top navigation bar to switch between the available MVC Web and Blazor Web hosts.</li>
            <li>Create at least one AI Profile of type <strong>Agent</strong> on the selected server so the host has agents to expose.</li>
        </ol>
    </div>
</div>

<div class="alert alert-secondary">
    Active server: <strong>@currentServer.DisplayName</strong> (<code>@currentServer.Endpoint</code>)
</div>

<p>Use the navigation tabs above to explore A2A capabilities:</p>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Agents</h5>
                <p class="card-text">Discover all agents exposed by the A2A host, view their skills, and send messages.</p>
                <a asp-page="/Agents" class="btn btn-primary btn-sm">Go to Agents</a>
            </div>
        </div>
    </div>
</div>
